<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ settings.text_direction | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="theme-color" content="#F4F3F1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}{% if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- elsif request.page_type == 'index' and settings.brand_tagline != blank -%}
      <meta name="description" content="{{ settings.brand_tagline | escape }}">
    {%- endif -%}

    {% render 'sorella-fonts' %}

    {{ content_for_header }}

    {%- comment -%} Light storefront design system (ported from the approved prototype) {%- endcomment -%}
    {{ 'sorella-store.css' | asset_url | stylesheet_tag }}
    {{ 'sorella-interactive.css' | asset_url | stylesheet_tag }}
    {%- if request.page_type == 'product' -%}
      {{ 'sorella-pdp.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
  </head>

  <body class="template-{{ request.page_type | handle }}">
    <a class="skip-to-content visually-hidden" href="#main-content">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.cart_drawer_enabled -%}
      {% section 'sorella-cart-drawer' %}
    {%- endif -%}

    {%- comment -%} Quick-buy modal — JS fetches /products/{handle}?section_id=sorella-quick-buy into the body {%- endcomment -%}
    <div id="quick-buy" class="quickbuy" data-panel aria-hidden="true" role="dialog" aria-modal="true" aria-label="Quick view"
      data-quick-buy-loading="{{ 'products.product.quick_buy_loading' | t | escape }}"
      data-quick-buy-error="{{ 'products.product.quick_buy_error' | t | escape }}"
      data-quick-buy-link="{{ 'products.product.quick_buy_view_full' | t | escape }}">
      <div class="quickbuy__scrim" data-close></div>
      <div class="quickbuy__panel">
        <button class="quickbuy__close" data-close aria-label="{{ 'general.accessibility.close' | t | default: 'Close' }}">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <div class="quickbuy__body" data-quick-buy-body></div>
      </div>
    </div>

    <script>window.Sorella = window.Sorella || {}; window.Sorella.moneyFormat = {{ shop.money_format | json }};</script>
    <script src="{{ 'sorella.js' | asset_url }}" defer></script>
  </body>
</html>
