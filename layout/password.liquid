<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{{ settings.text_direction | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.colors_navy | default: '#000000' }}">
    <title>{{ page_title }} &ndash; {{ shop.name }}</title>
    {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    {% render 'sorella-fonts' %}
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {% render 'sorella-color-vars' %}
  </head>
  <body class="template-password surface-gradient">
    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
