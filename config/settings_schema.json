[
  {
    "name": "theme_info",
    "theme_name": "Sorella",
    "theme_version": "1.0.0",
    "theme_author": "Sorella",
    "theme_documentation_url": "https://sorella-eg.com",
    "theme_support_url": "https://sorella-eg.com/pages/contact"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo (full wordmark)"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140
      },
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "Sorella"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Tagline",
        "info": "Used as the homepage meta description when no page description is set.",
        "default": "From our bond to your senses"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "select",
        "id": "text_direction",
        "label": "Text direction",
        "options": [
          { "value": "ltr", "label": "Left to right" },
          { "value": "rtl", "label": "Right to left (Arabic)" }
        ],
        "default": "ltr"
      }
    ]
  },
  {
    "name": "Social links",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL",
        "default": "https://www.instagram.com/sorella.fragrances"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL",
        "default": "https://www.tiktok.com/@sorella.fragrances"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "contact_email",
        "label": "Contact email",
        "info": "Shown in the footer and on the contact page."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Core palette"
      },
      {
        "type": "paragraph",
        "content": "Defaults match the Sorella navy design system. Changing these updates the whole theme — translucent glass surfaces follow automatically."
      },
      {
        "type": "color",
        "id": "colors_navy",
        "label": "Canvas (navy)",
        "default": "#0a1420"
      },
      {
        "type": "color",
        "id": "colors_parchment",
        "label": "Text (parchment)",
        "default": "#F2EEE7"
      },
      {
        "type": "color",
        "id": "colors_gold",
        "label": "Accent (gold)",
        "default": "#C79C5A"
      },
      {
        "type": "color",
        "id": "colors_ink",
        "label": "Ink (footer, text on gold, photo overlays)",
        "default": "#1C1F24"
      },
      {
        "type": "color",
        "id": "colors_slate",
        "label": "Slate (secondary surfaces)",
        "default": "#3A4452"
      },
      {
        "type": "color",
        "id": "colors_mist",
        "label": "Mist (muted text, hairlines)",
        "default": "#9AA3AD"
      },
      {
        "type": "header",
        "content": "Navy elevation scale"
      },
      {
        "type": "color",
        "id": "colors_navy_lowest",
        "label": "Navy — deepest wells",
        "default": "#050f1b"
      },
      {
        "type": "color",
        "id": "colors_navy_low",
        "label": "Navy — low containers",
        "default": "#121c29"
      },
      {
        "type": "color",
        "id": "colors_navy_container",
        "label": "Navy — cards & panels",
        "default": "#16202d"
      },
      {
        "type": "color",
        "id": "colors_navy_high",
        "label": "Navy — raised containers",
        "default": "#212b38"
      },
      {
        "type": "color",
        "id": "colors_navy_bright",
        "label": "Navy — media placeholder",
        "default": "#2b3543"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer_enabled",
        "label": "Use cart drawer",
        "default": true
      },
      {
        "type": "range",
        "id": "free_gift_threshold",
        "min": 0,
        "max": 5000,
        "step": 50,
        "unit": "LE",
        "label": "Free 5ml gift threshold",
        "default": 1100
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Card image ratio",
        "options": [
          { "value": "media--1x1", "label": "Square (1:1)" },
          { "value": "media--4x5", "label": "Portrait (4:5)" },
          { "value": "media--3x4", "label": "Portrait (3:4)" }
        ],
        "default": "media--4x5"
      },
      {
        "type": "checkbox",
        "id": "card_quick_add",
        "label": "Show quick-add on hover",
        "default": true
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency code (e.g. LE)",
        "info": "Applies to all prices rendered by the theme (product cards, product page, cart).",
        "default": true
      }
    ]
  }
]
