{%- comment -%} Gift card — standalone page (own layout) {%- endcomment -%}
{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{{ settings.text_direction | default: 'ltr' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    {%- assign gc_value = gift_card.initial_value | money -%}
    <title>{{ 'gift_cards.issued.title' | t: value: gc_value, shop: shop.name }} — {{ shop.name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body class="template-gift-card surface-gradient">
    <main class="sorella-account" style="display:flex; align-items:center; justify-content:center; min-height:100vh;">
      <div class="container container--read">
        <div class="glass-panel glass-panel--xl sorella-account__card" style="align-items:center; text-align:center;">
          <span class="t-eyebrow text-gold">{{ shop.name }}</span>
          <h1 class="t-display-md">A gift for you</h1>

          <div class="sorella-giftcard__amount t-display-hero text-gold">{{ gift_card.balance | money }}</div>
          {%- if gift_card.balance != gift_card.initial_value -%}
            <p class="t-caption text-mist">Original value {{ gift_card.initial_value | money }}</p>
          {%- endif -%}

          {%- if gift_card.expired -%}
            <p class="sorella-account__error t-caption">This gift card has expired.</p>
          {%- elsif gift_card.expires_on -%}
            <p class="t-caption text-mist">Expires {{ gift_card.expires_on | date: '%B %-d, %Y' }}</p>
          {%- endif -%}

          <div class="sorella-giftcard__qr" style="margin-block: var(--space-md);">
            <img src="/services/gift_card/qr/{{ gift_card.qr_identifier }}.png" alt="Gift card QR code" width="160" height="160" style="margin-inline:auto; border-radius: var(--radius-md);">
          </div>

          <div class="sorella-field" style="width:100%; max-width:360px; margin-inline:auto;">
            <label class="t-caption-strong" for="gc-code">Gift card code</label>
            <input id="gc-code" type="text" readonly value="{{ gift_card.code | format_code }}" onclick="this.select()" style="text-align:center; font-variant-numeric: tabular-nums;">
          </div>

          {% render 'sorella-button', label: 'Start shopping', href: shop.url, style: 'primary' %}
        </div>
      </div>
    </main>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
