{%- comment -%} Customer addresses — list + add/edit/delete {%- endcomment -%}
<section class="sorella-account surface-ink">
  <div class="container container--read">
    <div class="sorella-account__head">
      <span class="t-eyebrow text-gold">{{ 'customer.account.addresses' | t }}</span>
      <h1 class="t-display-md">{{ 'customer.account.addresses' | t }}</h1>
      <a class="t-caption" href="{{ routes.account_url }}">← {{ 'customer.account.title' | t }}</a>
    </div>

    {%- comment -%} New address {%- endcomment -%}
    <details class="glass-panel sorella-account__card" style="margin-block-end: var(--space-lg);">
      <summary class="t-body-strong">{{ 'customer.addresses.add_new' | t }}</summary>
      {%- form 'customer_address', customer.new_address, class: 'sorella-account__form', style: 'margin-block-start: var(--space-md);' -%}
        <div class="sorella-account__row">
          <div class="sorella-field"><label class="t-caption-strong" for="new_first">{{ 'customer.addresses.first_name' | t }}</label><input type="text" id="new_first" name="address[first_name]" autocomplete="given-name"></div>
          <div class="sorella-field"><label class="t-caption-strong" for="new_last">{{ 'customer.addresses.last_name' | t }}</label><input type="text" id="new_last" name="address[last_name]" autocomplete="family-name"></div>
        </div>
        <div class="sorella-field"><label class="t-caption-strong" for="new_addr1">{{ 'customer.addresses.address' | t }}</label><input type="text" id="new_addr1" name="address[address1]" autocomplete="address-line1"></div>
        <div class="sorella-account__row">
          <div class="sorella-field"><label class="t-caption-strong" for="new_city">{{ 'customer.addresses.city' | t }}</label><input type="text" id="new_city" name="address[city]" autocomplete="address-level2"></div>
          <div class="sorella-field"><label class="t-caption-strong" for="new_country">{{ 'customer.addresses.country' | t }}</label><select id="new_country" name="address[country]">{{ all_country_option_tags }}</select></div>
        </div>
        <div class="sorella-field"><label class="t-caption-strong" for="new_phone">{{ 'customer.addresses.phone' | t }}</label><input type="tel" id="new_phone" name="address[phone]" autocomplete="tel"></div>
        <button type="submit" class="btn btn--primary">{{ 'customer.addresses.save' | t }}</button>
      {%- endform -%}
    </details>

    {%- for address in customer.addresses -%}
      <div class="glass-panel sorella-account__card" style="margin-block-end: var(--space-md);">
        <p class="t-body-sm text-mist">{{ address | format_address }}</p>
        <details>
          <summary class="t-caption text-gold">{{ 'customer.addresses.edit' | t }}</summary>
          {%- form 'customer_address', address, class: 'sorella-account__form', style: 'margin-block-start: var(--space-md);' -%}
            <div class="sorella-account__row">
              <div class="sorella-field"><label class="t-caption-strong" for="first_{{ address.id }}">{{ 'customer.addresses.first_name' | t }}</label><input type="text" id="first_{{ address.id }}" name="address[first_name]" value="{{ address.first_name }}"></div>
              <div class="sorella-field"><label class="t-caption-strong" for="last_{{ address.id }}">{{ 'customer.addresses.last_name' | t }}</label><input type="text" id="last_{{ address.id }}" name="address[last_name]" value="{{ address.last_name }}"></div>
            </div>
            <div class="sorella-field"><label class="t-caption-strong" for="addr1_{{ address.id }}">{{ 'customer.addresses.address' | t }}</label><input type="text" id="addr1_{{ address.id }}" name="address[address1]" value="{{ address.address1 }}"></div>
            <div class="sorella-account__row">
              <div class="sorella-field"><label class="t-caption-strong" for="city_{{ address.id }}">{{ 'customer.addresses.city' | t }}</label><input type="text" id="city_{{ address.id }}" name="address[city]" value="{{ address.city }}"></div>
              <div class="sorella-field"><label class="t-caption-strong" for="country_{{ address.id }}">{{ 'customer.addresses.country' | t }}</label><select id="country_{{ address.id }}" name="address[country]">{{ all_country_option_tags }}</select></div>
            </div>
            <div class="sorella-field"><label class="t-caption-strong" for="phone_{{ address.id }}">{{ 'customer.addresses.phone' | t }}</label><input type="tel" id="phone_{{ address.id }}" name="address[phone]" value="{{ address.phone }}"></div>
            <div class="sorella-account__links">
              <button type="submit" class="btn btn--primary btn--sm">{{ 'customer.addresses.update' | t }}</button>
              <a class="btn btn--text" href="#" data-address-delete="{{ address.url_to_delete }}">{{ 'customer.addresses.delete' | t }}</a>
            </div>
          {%- endform -%}
        </details>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  document.querySelectorAll('[data-address-delete]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      if (!confirm({{ 'customer.addresses.delete_confirm' | t | json }})) return;
      var f = document.createElement('form');
      f.method = 'post'; f.action = link.getAttribute('data-address-delete');
      f.innerHTML = '<input type="hidden" name="_method" value="delete">';
      document.body.appendChild(f); f.submit();
    });
  });
</script>
