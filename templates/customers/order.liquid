{%- comment -%} Customer order detail {%- endcomment -%}
<section class="sorella-account surface-ink">
  <div class="container container--lock">
    <div class="sorella-account__head">
      <span class="t-eyebrow text-gold">{{ 'customer.account.orders' | t }}</span>
      <h1 class="t-display-md">{{ order.name }}</h1>
      <p class="t-caption text-mist">{{ order.created_at | date: '%B %-d, %Y' }} · {{ order.financial_status_label }} · {{ order.fulfillment_status_label }}</p>
      <a class="t-caption" href="{{ routes.account_url }}">← {{ 'customer.account.title' | t }}</a>
    </div>

    <div class="glass-panel sorella-account__card">
      <table class="sorella-account__table t-caption">
        <thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead>
        <tbody>
          {%- for line in order.line_items -%}
            <tr>
              <td><a class="text-gold" href="{{ line.product.url }}">{{ line.title }}</a></td>
              <td>{{ line.quantity }}</td>
              <td>{{ line.price | money }}</td>
              <td>{{ line.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr><th colspan="3">{{ 'cart.general.subtotal' | t }}</th><td>{{ order.line_items_subtotal_price | money }}</td></tr>
          {%- for shipping in order.shipping_methods -%}
            <tr><th colspan="3">{{ shipping.title }}</th><td>{{ shipping.price | money }}</td></tr>
          {%- endfor -%}
          <tr><th colspan="3">Total</th><td class="text-gold">{{ order.total_net_amount | money }}</td></tr>
        </tfoot>
      </table>
    </div>

    <div class="glass-panel sorella-account__card" style="margin-block-start: var(--space-lg);">
      <h2 class="t-headline">Shipping address</h2>
      <p class="t-body-sm text-mist">{{ order.shipping_address | format_address }}</p>
    </div>
  </div>
</section>
