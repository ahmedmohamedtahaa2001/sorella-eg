{%- comment -%} Customer account dashboard — orders + addresses link {%- endcomment -%}
<section class="sorella-account surface-ink">
  <div class="container container--lock">
    <div class="sorella-account__head">
      <span class="t-eyebrow text-gold">{{ 'customer.account.title' | t }}</span>
      <h1 class="t-display-md">{{ customer.name | default: customer.email }}</h1>
      <a class="t-caption" href="{{ routes.account_logout_url }}">{{ 'customer.account.logout' | t }}</a>
    </div>

    <div class="sorella-account__grid">
      <aside class="glass-panel sorella-account__card">
        <h2 class="t-headline">{{ 'customer.account.addresses' | t }}</h2>
        {%- if customer.default_address -%}
          <p class="t-body-sm text-mist">{{ customer.default_address | format_address }}</p>
        {%- endif -%}
        {% render 'sorella-button', label: 'customer.account.addresses' | t, href: routes.account_addresses_url, style: 'ghost', size: 'sm' %}
      </aside>

      <div class="glass-panel sorella-account__card">
        <h2 class="t-headline">{{ 'customer.account.orders' | t }}</h2>
        {%- if customer.orders.size > 0 -%}
          <table class="sorella-account__table t-caption">
            <thead>
              <tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th></tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td><a class="text-gold" href="{{ order.customer_url }}">{{ order.name }}</a></td>
                  <td>{{ order.created_at | date: '%b %-d, %Y' }}</td>
                  <td>{{ order.total_net_amount | money }}</td>
                  <td>{{ order.financial_status_label }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          {% render 'sorella-empty-state', heading: 'No orders yet.', cta_label: 'general.404.cta' | t, cta_url: routes.all_products_collection_url, icon: 'bag' %}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
