      "type": "sorella-faq",
      "settings": {
        "eyebrow": "Before you buy",
        "heading": "Everything you'd ask a <em>sister</em>.",
        "subheading": "Shipping, longevity, and how to try a scent before you commit.",
        "body": "<p>We keep an honest shop — real delivery times, no dark patterns, and a 5ml tester so nobody buys a bottle on faith alone. If your question isn't here, we're a message away.</p>",
        "support_heading": "Still wondering?",
        "support_text": "Message us on Instagram — we answer like a sister, usually the same day.",
        "support_button_label": "Ask @sorella.fragrances",
        "support_button_url": "https://instagram.com/sorella.fragrances",
        "tester_note": "New to Sorella? Try any scent first for LE 85.",
        "tester_url": "/collections/5-ml-testers",
        "anchor_id": "faq"
      },
      "blocks": {
        "q1": {
          "type": "qa",
          "settings": {
            "question": "How long does the scent last?",
            "answer": "<p>Our oil-rich blends are built to last — most customers report all-day wear on skin and days on clothing.</p>",
            "open": true
          }
        },
        "q2": {
          "type": "qa",
          "settings": {
            "question": "Can I try a scent before buying the full size?",
            "answer": "<p>Yes — every full-size fragrance has a 5ml tester for LE 85. Try it first, commit only when you love it.</p>"
          }
        },
        "q3": {
          "type": "qa",
          "settings": {
            "question": "How fast is shipping?",
            "answer": "<p>Orders ship from Egypt in 2–4 days, blended fresh and poured to order.</p>"
          }
        },
        "q4": {
          "type": "qa",
          "settings": {
            "question": "What is your returns / exchange policy?",
            "answer": "<p>Because fragrance is personal, we can't accept opened returns — which is why we offer the 5ml tester first. Unopened items can be exchanged within 7 days.</p>"
          }
        }
      },
