{%- comment -%}
  Sorella — Bestseller carousel (audit §2.3)
  Horizontally scroll-snapping carousel of product cards with prev/next arrows.
  CSS scroll-snap; arrows use the shared [data-carousel] handler in sorella.js.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign coll = s.collection
  assign count = s.product_count
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="sec__head">
      <div>
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
      </div>
      <div class="carousel__head-right">
        {%- if s.link_label != blank -%}<a class="link-arrow" href="{{ s.link_url | default: coll.url | default: '#' }}">{{ s.link_label }} →</a>{%- endif -%}
        <div class="carousel__nav">
          <button type="button" class="carousel__arrow" data-carousel-prev aria-label="Previous">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="carousel__arrow" data-carousel-next aria-label="Next">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="carousel" data-carousel>
      <div class="carousel__track" data-carousel-track>
        {%- if coll != blank and coll.products.size > 0 -%}
          {%- for product in coll.products limit: count -%}
            <div class="carousel__item">{% render 'sorella-product-card', product: product, variant: s.card_variant %}</div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..count) -%}
            <div class="carousel__item">{% render 'sorella-product-card', variant: s.card_variant %}</div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestseller carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The most loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bestsellers this month" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_count", "label": "Products shown", "min": 3, "max": 16, "step": 1, "default": 8 },
    {
      "type": "select", "id": "card_variant", "label": "Card style", "default": "add",
      "options": [
        { "value": "add", "label": "Add to bag (always visible)" },
        { "value": "cta", "label": "Add + Buy now" },
        { "value": "plus", "label": "Quick + add" },
        { "value": "default", "label": "Reveal on hover" }
      ]
    },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop all" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "bestsellers" }
  ],
  "presets": [{ "name": "Bestseller carousel" }]
}
{% endschema %}
