{%- comment -%}
  sorella-rich-text — Generic reading column (Page Templates Report §2.2, §4.3).
  Readability first: no glass/bento. Renders a richtext block or the current
  page's body inside a .rte reading column. Used on Policy, About, any page.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign align = s.align | default: 'start'
  assign width = s.width | default: 'read'
  assign surface = s.surface | default: 'surface-ink'
  if width == 'lock'
    assign container_class = 'container--lock'
  else
    assign container_class = 'container--read'
  endif
-%}
<section class="sorella-rich-text {{ surface }}" data-section-id="{{ section.id }}">
  <div class="container {{ container_class }} section-pad sorella-rich-text__inner sorella-rich-text--{{ align }}">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head sorella-rich-text__head">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="rte">
      {%- if s.source == 'page_content' -%}
        {{ page.content }}
      {%- else -%}
        {{ s.content }}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-rich-text__inner { display: flex; flex-direction: column; gap: var(--space-lg); }
  .sorella-rich-text__head { display: flex; flex-direction: column; gap: var(--space-xs); }
  .sorella-rich-text--center { text-align: center; align-items: center; }
  .sorella-rich-text--center .rte { text-align: start; inline-size: 100%; }
{% endstylesheet %}

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "settings": [
    {
      "type": "select", "id": "source", "label": "Content source", "default": "richtext",
      "options": [
        { "value": "richtext", "label": "Rich text setting" },
        { "value": "page_content", "label": "Current page content" }
      ]
    },
    { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add your copy here.</p>" },
    { "type": "header", "content": "Heading (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "width", "label": "Column width", "default": "read",
      "options": [
        { "value": "read", "label": "Reading (narrow)" },
        { "value": "lock", "label": "Locked (wide)" }
      ]
    },
    {
      "type": "select", "id": "align", "label": "Alignment", "default": "start",
      "options": [
        { "value": "start", "label": "Start" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select", "id": "surface", "label": "Surface", "default": "surface-ink",
      "options": [
        { "value": "surface-parchment", "label": "Parchment" },
        { "value": "surface-ink", "label": "Ink" }
      ]
    }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
