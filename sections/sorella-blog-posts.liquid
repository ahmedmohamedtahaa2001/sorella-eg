{%- comment -%}
  sorella-blog-posts — article preview grid (Page Templates Report §5.1).
  Renders {{ blog.articles }} paginated as glass article cards; branded empty state.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-blog-posts surface-ink section-pad" data-section-id="{{ section.id }}">
  <div class="container container--catalog">
    {%- paginate blog.articles by s.posts_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="catalog-grid">
          {%- for article in blog.articles -%}
            {%- capture card -%}
              {%- if article.image -%}
                <a href="{{ article.url }}" class="sorella-article-card__media media media--16x9" tabindex="-1" aria-hidden="true">
                  {{ article.image | image_url: width: 1200 | image_tag:
                    loading: 'lazy', sizes: '(max-width: 720px) 100vw, 33vw',
                    widths: '400, 600, 800, 1200', alt: article.title | escape }}
                </a>
              {%- endif -%}
              <div class="sorella-article-card__body">
                {%- if s.show_date -%}
                  <span class="sorella-article-card__meta t-caption text-mist">{{ article.published_at | date: '%B %-d, %Y' }}</span>
                {%- endif -%}
                <h2 class="t-headline"><a href="{{ article.url }}" class="sorella-article-card__title">{{ article.title }}</a></h2>
                {%- if s.show_excerpt -%}
                  <p class="sorella-article-card__excerpt t-body text-mist">{{ article.excerpt_or_content | strip_html | truncatewords: 24 }}</p>
                {%- endif -%}
                {%- if s.show_author -%}
                  <span class="sorella-article-card__author t-caption text-mist">{{ article.author }}</span>
                {%- endif -%}
                {% render 'sorella-button', label: s.read_more_label, href: article.url, style: 'text' %}
              </div>
            {%- endcapture -%}
            {% render 'sorella-glass-panel', content: card, variant: 'card', class: 'sorella-article-card' %}
          {%- endfor -%}
        </div>
        {% render 'sorella-pagination', paginate: paginate %}
      {%- else -%}
        {% render 'sorella-empty-state', heading: 'No stories yet.', text: 'Check back soon.', cta_label: 'Back to shop', cta_url: routes.all_products_collection_url, icon: 'sparkle' %}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% stylesheet %}
  .sorella-article-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .sorella-article-card__media {
    display: block;
  }
  .sorella-article-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
  }
  .sorella-article-card__title {
    color: inherit;
    text-decoration: none;
  }
  .sorella-article-card__title:hover {
    color: var(--color-gold);
  }
  .sorella-article-card__excerpt {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog Posts",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 6, "max": 24, "step": 3, "default": 9 },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": false },
    { "type": "text", "id": "read_more_label", "label": "Read more label", "default": "Read more" }
  ],
  "presets": [{ "name": "Blog posts" }]
}
{% endschema %}
