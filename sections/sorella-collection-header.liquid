{%- comment -%}
  sorella-collection-header — Editorial header for a collection/catalog page (Page Templates §2.2, §3.2).
  Renders the current {{ collection }} object: eyebrow, title (t-display-lg), optional description + product count.
  When a cover image is present and enabled, the header becomes a .blob-scene with the image + hero-scrim;
  otherwise it falls back to a plain surface-ink header.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign align = s.text_align | default: 'start'
  assign has_cover = false
  if s.show_cover and collection.image != blank
    assign has_cover = true
  endif
-%}
{%- if has_cover -%}
  <section class="sorella-collection-header sorella-collection-header--cover blob-scene" data-section-id="{{ section.id }}">
    <div class="sorella-collection-header__media">
      {{ collection.image | image_url: width: 2000 | image_tag:
        loading: 'eager', fetchpriority: 'high',
        sizes: '100vw', widths: '800, 1200, 1600, 2000',
        alt: collection.title | escape }}
    </div>
    <span class="sorella-collection-header__scrim" aria-hidden="true"></span>
    <div class="container container--catalog sorella-collection-header__container sorella-collection-header__container--{{ align }}">
      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      <h1 class="t-display-lg">{{ collection.title }}</h1>
      {%- if s.show_description and collection.description != blank -%}
        <div class="sorella-collection-header__desc rte t-body-lg">{{ collection.description }}</div>
      {%- endif -%}
      {%- if s.count_noun != blank -%}
        <p class="sorella-collection-header__count t-caption-strong text-gold">{{ collection.products_count }} {{ s.count_noun }}</p>
      {%- endif -%}
    </div>
  </section>
{%- else -%}
  <section class="sorella-collection-header surface-gradient section-pad" data-section-id="{{ section.id }}">
    <div class="container container--catalog sorella-collection-header__container sorella-collection-header__container--{{ align }}">
      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      <h1 class="t-display-lg">{{ collection.title }}</h1>
      {%- if s.show_description and collection.description != blank -%}
        <div class="sorella-collection-header__desc rte t-body-lg">{{ collection.description }}</div>
      {%- endif -%}
      {%- if s.count_noun != blank -%}
        <p class="sorella-collection-header__count t-caption-strong text-gold">{{ collection.products_count }} {{ s.count_noun }}</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .sorella-collection-header__container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .sorella-collection-header__container--center {
    align-items: center;
    text-align: center;
  }
  .sorella-collection-header__desc { max-width: var(--container-read); }
  .sorella-collection-header__count { margin-block-start: var(--space-xs); }

  .sorella-collection-header--cover {
    display: flex;
    align-items: flex-end;
    min-height: 320px;
    padding-block: calc(var(--nav-height-top) + var(--space-xl)) var(--space-xxl);
    color: var(--color-parchment);
  }
  .sorella-collection-header--cover .sorella-collection-header__container { width: 100%; }
  .sorella-collection-header__media { position: absolute; inset: 0; z-index: 0; }
  .sorella-collection-header__media img { width: 100%; height: 100%; object-fit: cover; }
  .sorella-collection-header__scrim {
    position: absolute; inset: 0; z-index: 0;
    background: var(--gradient-hero-scrim);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Header",
  "tag": "section",
  "enabled_on": { "templates": ["collection"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collection" },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "checkbox", "id": "show_cover", "label": "Show collection image as cover", "default": true },
    { "type": "text", "id": "count_noun", "label": "Product count noun", "default": "fragrances" },
    {
      "type": "select", "id": "text_align", "label": "Text alignment", "default": "start",
      "options": [
        { "value": "start", "label": "Start" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "presets": [{ "name": "Collection header" }]
}
{% endschema %}
