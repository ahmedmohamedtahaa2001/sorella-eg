{%- comment -%}
  sorella-list-collections — the "all collections" index (Page Templates Report §6.5).
  Iterates the platform's {{ collections }} list (data, not blocks) and renders each
  as a uniform category tile via the sorella-bento-cell snippet. Uniform .catalog-grid
  (not asymmetric bento) — an index favors scannability over marketing hierarchy.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-list-collections surface-ink" data-section-id="{{ section.id }}">
  <div class="container container--bento section-pad">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow section-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h1 class="t-display-lg">{{ s.heading }}</h1>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="catalog-grid">
      {%- for collection in collections -%}
        {%- liquid
          if s.hide_empty and collection.products_count == 0
            continue
          endif
          assign subheading = ''
          if s.show_count
            assign subheading = collection.products_count | append: ' ' | append: s.count_noun
          endif
        -%}
        <div class="sorella-list-collections__cell">
          {% render 'sorella-bento-cell',
            image: collection.featured_image,
            heading: collection.title,
            subheading: subheading,
            link: collection.url,
            cta: s.cta_label %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-list-collections__cell { display: flex; }
  .sorella-list-collections__cell .sorella-bento-cell { min-block-size: 100%; inline-size: 100%; }
{% endstylesheet %}

{% schema %}
{
  "name": "List Collections",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "All collections" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop" },
    { "type": "checkbox", "id": "show_count", "label": "Show product count", "default": true },
    { "type": "text", "id": "count_noun", "label": "Count noun", "default": "fragrances" },
    { "type": "checkbox", "id": "hide_empty", "label": "Hide empty collections", "default": true }
  ],
  "presets": [
    { "name": "List collections" }
  ]
}
{% endschema %}
