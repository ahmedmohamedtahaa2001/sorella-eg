{%- comment -%}
  sorella-brand-story — Brand-Story Block (Art Direction §10, §7.3).
  Full-bleed ALTERNATING glass panels over a photographic background,
  ONE blob per panel with alternating hues (§7.3). Parchment text,
  t-display-lg headings. Reused on About page AND homepage.
  Zero hardcoded content — all copy/images come from section & block settings.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-brand-story surface-ink" data-section-id="{{ section.id }}">
  {%- if s.eyebrow != blank or s.heading != blank -%}
    <div class="container container--lock sorella-brand-story__intro">
      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- liquid
      assign side = block.settings.side
      if side == blank
        assign side = 'start'
        assign side_parity = forloop.index0 | modulo: 2
        if side_parity != 0
          assign side = 'end'
        endif
      endif
    -%}
    <div class="sorella-brand-story__panel blob-scene" {{ block.shopify_attributes }}>
      {%- if block.settings.image != blank -%}
        <div class="sorella-brand-story__media" aria-hidden="true">
          {{ block.settings.image | image_url: width: 2000 | image_tag:
            loading: 'lazy',
            sizes: '100vw', widths: '800, 1200, 1600, 2000',
            alt: block.settings.heading | escape }}
        </div>
      {%- endif -%}
      <span class="sorella-brand-story__scrim" aria-hidden="true"></span>

      {% render 'sorella-blob', single: true, scheme: block.settings.blob_scheme %}

      <div class="container container--lock sorella-brand-story__inner sorella-brand-story__inner--{{ side }}">
        <div class="sorella-brand-story__card glass-panel glass-panel--xl glass-panel--sheen">
          {%- if block.settings.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ block.settings.eyebrow }}</span>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h3 class="t-display-lg">{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="rte t-body-lg">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}
</section>

{% stylesheet %}
  .sorella-brand-story__intro {
    display: flex; flex-direction: column; gap: var(--space-sm);
    padding-block: var(--space-section) var(--space-xxl);
    text-align: center; align-items: center;
    color: var(--color-parchment);
  }
  .sorella-brand-story__panel {
    position: relative;
    display: flex; align-items: center;
    min-height: clamp(480px, 70vh, 720px);
    padding-block: var(--space-section);
  }
  .sorella-brand-story__media { position: absolute; inset: 0; z-index: 0; }
  .sorella-brand-story__media img { width: 100%; height: 100%; object-fit: cover; }
  .sorella-brand-story__scrim { position: absolute; inset: 0; z-index: 0; background: var(--gradient-hero-scrim); }
  .sorella-brand-story__inner { position: relative; z-index: 1; width: 100%; display: flex; }
  .sorella-brand-story__inner--start { justify-content: flex-start; }
  .sorella-brand-story__inner--end { justify-content: flex-end; }
  .sorella-brand-story__card {
    display: flex; flex-direction: column; gap: var(--space-md);
    max-width: 560px; padding: var(--space-xxl);
    color: var(--color-parchment);
  }
  @media (max-width: 640px) {
    .sorella-brand-story__card { padding: var(--space-xl) var(--space-lg); }
    .sorella-brand-story__inner--start,
    .sorella-brand-story__inner--end { justify-content: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand-Story Block",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Section eyebrow" },
    { "type": "text", "id": "heading", "label": "Section heading" }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" },
        {
          "type": "select", "id": "side", "label": "Card side", "default": "start",
          "options": [
            { "value": "start", "label": "Start" },
            { "value": "end", "label": "End" }
          ]
        },
        {
          "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "gold",
          "options": [
            { "value": "gold", "label": "Gold" },
            { "value": "slate", "label": "Slate" },
            { "value": "rose", "label": "Rose" },
            { "value": "gold-rose", "label": "Gold + Rose" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand story",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "eyebrow": "Get to know us",
            "heading": "Two sisters, one bond",
            "text": "<p>At Sorella, we believe the best bonds are the ones we share. We're two sisters, connected not just by family but by a love for fragrance and the memories scents create. Our journey began with a simple wish: to bring people closer through scent.</p>",
            "side": "start",
            "blob_scheme": "gold"
          }
        },
        {
          "type": "panel",
          "settings": {
            "eyebrow": "Why Sorella",
            "heading": "From our bond to your senses",
            "text": "<p>The name Sorella reflects our sisterly bond, and it's our mission to share that connection with you. Every fragrance is crafted to evoke emotion, hold memory, and celebrate the moments that make life special.</p>",
            "side": "end",
            "blob_scheme": "slate"
          }
        },
        {
          "type": "panel",
          "settings": {
            "eyebrow": "Fragrance with a story",
            "heading": "Made fresh in Egypt",
            "text": "<p>Our love for perfume isn't only about beautiful scents — it's about telling stories and inspiring connection. Each fragrance reflects the closeness we share, made fresh in Egypt.</p>",
            "side": "start",
            "blob_scheme": "rose"
          }
        }
      ]
    }
  ]
}
{% endschema %}
