{%- comment -%}
  Sorella — Brand story (audit §2.4)
  Two-line brand statement + link to the full story, optional image.
  Layout: text-only / image-left / image-right.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign layout = s.layout | default: 'image-right'
  assign has_img = false
  if s.image != blank and layout != 'text-only'
    assign has_img = true
  endif
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="brandstory brandstory--{{ layout }}{% if has_img %} brandstory--has-img{% endif %}">
      {%- if has_img -%}
        <div class="brandstory__media">
          {%- assign bw = 1000 -%}
          {%- assign bh = bw | divided_by: s.image.aspect_ratio | round -%}
          <img src="{{ s.image | image_url: width: bw }}" alt="{{ s.image.alt | default: s.heading | escape }}" width="{{ bw }}" height="{{ bh }}" loading="lazy">
        </div>
      {%- endif -%}
      <div class="brandstory__copy">
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="brandstory__h serif">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.body != blank -%}<div class="brandstory__body rte">{{ s.body }}</div>{%- endif -%}
        {%- if s.link_label != blank -%}
          <a class="link-arrow brandstory__link" href="{{ s.link_url | default: '#' }}">{{ s.link_label }} →</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Two sisters, one signature" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made fresh in Egypt, poured to order — the scent she remembers you by." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Sorella began as a bond between sisters and a shared obsession with fragrance. Every scent is blended in small batches and true to the original — built to last from morning into the evening.</p>" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Read our story" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "layout", "label": "Layout", "default": "image-right",
      "options": [
        { "value": "text-only", "label": "Text only" },
        { "value": "image-left", "label": "Image left" },
        { "value": "image-right", "label": "Image right" }
      ]
    },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "story" }
  ],
  "presets": [{ "name": "Brand story" }]
}
{% endschema %}
