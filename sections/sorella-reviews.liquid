{%- liquid
  assign s = section.settings
-%}
<section class="sec sec--center">
  <div class="wrap">
    <div class="sec__head">
      {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
      {%- if s.avg != blank -%}
        <div class="rsum"><b>{{ s.avg }}</b><span class="stars">★★★★★</span>{% if s.count_text != blank %}<span class="muted">· {{ s.count_text }}</span>{% endif %}</div>
      {%- endif -%}
    </div>
    <div class="reviews">
      {%- for block in section.blocks -%}
        {% render 'sorella-review-card',
          quote: block.settings.quote,
          author: block.settings.author,
          verified: block.settings.verified,
          rating: block.settings.rating,
          size: block.settings.size,
          variant: 'default',
          shopify_attributes: block.shopify_attributes %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From our sisters" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved, in her own words." },
    { "type": "text", "id": "avg", "label": "Average rating", "default": "4.8" },
    { "type": "text", "id": "count_text", "label": "Count label", "default": "1,288 verified reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Bordeaux zay el original bezabt — btesbat awiii, compliments into the evening." },
        { "type": "text", "id": "author", "label": "Author", "default": "Farida M." },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "size", "label": "Size / meta", "default": "50ml" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "quote": "Bordeaux zay el original bezabt — btesbat awiii, compliments into the evening.", "author": "Farida M.", "size": "50ml" } },
        { "type": "review", "settings": { "quote": "El reeha btefdal 3 ayam 3al hodoom — I get asked what I'm wearing every single time.", "author": "Nour A.", "size": "Bundle" } },
        { "type": "review", "settings": { "quote": "Ordered the 5ml tester first, fell in love, came back for the 50ml. Wsel fe 3 ayam.", "author": "Mariam S.", "size": "5ml → 50ml" } }
      ]
    }
  ]
}
{% endschema %}
