{%- comment -%}
  sorella-product-carousel — product row/rail (Art Direction §10).
  Reused for homepage "Best sellers" AND product-page "related products"
  (same section, different source). No hardcoded content — all from settings.
  Renders sorella-product-card snippet; does not reimplement cards.
  Optional bestseller rank badges + trust footnote for conversion context.
{%- endcomment -%}
{%- liquid
  assign s = section.settings

  assign source_products = s.collection.products
  assign source_url = s.collection.url

  assign wants_recommendations = false
  if s.collection == blank
    if product != blank or recommendations.performed
      assign wants_recommendations = true
    endif
  endif

  if wants_recommendations
    if recommendations.performed and recommendations.products_count > 0
      assign source_products = recommendations.products
      assign source_url = blank
    elsif product != blank
      assign fallback_collection = product.collections.first
      assign source_products = fallback_collection.products
      assign source_url = fallback_collection.url
    endif
  endif
-%}
{% style %}
  #shopify-section-{{ section.id }} .sorella-carousel__pad {
    padding-block-start: {{ s.padding_top }}px;
    padding-block-end: {{ s.padding_bottom }}px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sorella-carousel__pad {
      padding-block-start: {{ s.mobile_padding_top }}px;
      padding-block-end: {{ s.mobile_padding_bottom }}px;
    }
  }
{% endstyle %}
{%- if source_products.size > 0 -%}
  <section class="sorella-carousel surface-ink" data-section-id="{{ section.id }}"
    {%- if wants_recommendations %}
    data-recommendations
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ s.product_count | at_most: 10 }}"
    {%- endif %}>
    <div class="container container--catalog sorella-carousel__pad">
      <div class="section-head sorella-carousel__head">
        <div class="sorella-carousel__head-text">
          {%- if s.eyebrow != blank -%}
            <span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>
          {%- endif -%}
          {%- if s.heading != blank -%}
            <h2 class="t-display-md">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.support_text != blank -%}
            <p class="t-body sorella-carousel__support">{{ s.support_text }}</p>
          {%- endif -%}
        </div>
        {%- if s.show_view_all and s.view_all_label != blank and source_url != blank -%}
          <div class="sorella-carousel__head-action">
            {% render 'sorella-button', label: s.view_all_label, href: source_url, style: s.view_all_style, icon: 'arrow-right' %}
          </div>
        {%- endif -%}
      </div>

      <div class="sorella-carousel__body sorella-carousel__body--{{ s.layout }}">
        {%- liquid
          assign rank = 0
        -%}
        {%- if s.layout == 'rail' -%}
          <ul class="sorella-carousel__track" role="list">
            {%- for card_product in source_products limit: s.product_count -%}
              {%- unless card_product.id == product.id -%}
                {%- assign rank = rank | plus: 1 -%}
                <li class="sorella-carousel__item sorella-carousel__slot">
                  {%- if s.show_rank -%}
                    <span class="sorella-carousel__rank t-eyebrow t-eyebrow--micro">{{ s.rank_prefix }} {{ rank }}</span>
                  {%- endif -%}
                  {% render 'sorella-product-card', product: card_product, variant: s.card_variant %}
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        {%- else -%}
          <div class="catalog-grid">
            {%- for card_product in source_products limit: s.product_count -%}
              {%- unless card_product.id == product.id -%}
                {%- assign rank = rank | plus: 1 -%}
                <div class="sorella-carousel__slot">
                  {%- if s.show_rank -%}
                    <span class="sorella-carousel__rank t-eyebrow t-eyebrow--micro">{{ s.rank_prefix }} {{ rank }}</span>
                  {%- endif -%}
                  {% render 'sorella-product-card', product: card_product, variant: s.card_variant %}
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- if s.footnote != blank -%}
        <p class="sorella-carousel__footnote t-caption text-mist">{{ s.footnote }}</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  /* .section-head in components.css loads later and re-sets flex-direction;
     double the class specificity so this row layout wins the cascade. */
  .section-head.sorella-carousel__head {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
  }
  .sorella-carousel__head-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: start;
    gap: var(--space-sm);
  }
  .sorella-carousel__support {
    color: var(--color-parchment-65);
    color: color-mix(in srgb, var(--color-parchment) 72%, transparent);
    max-width: 46ch;
    margin: 0;
  }
  .sorella-carousel__head-action { flex: none; padding-block-end: 4px; }

  .sorella-carousel__slot { position: relative; }
  /* Top-right so it never collides with sale/sold-out badges (top-left) */
  .sorella-carousel__rank {
    position: absolute; z-index: 2;
    inset-block-start: var(--space-sm); inset-inline-end: var(--space-sm);
    padding: 6px 12px; border-radius: var(--radius-pill);
    background: var(--color-ink-90);
    border: 1px solid var(--color-gold-40);
    color: var(--color-gold);
    pointer-events: none;
  }

  .sorella-carousel__track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-block-end: var(--space-sm);
    margin-inline: calc(var(--space-lg) * -1);
    padding-inline: var(--space-lg);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-mist-40) transparent;
  }
  .sorella-carousel__track::-webkit-scrollbar { height: 6px; }
  .sorella-carousel__track::-webkit-scrollbar-thumb {
    background: var(--color-mist-40);
    border-radius: var(--radius-pill);
  }
  .sorella-carousel__item {
    flex: 0 0 auto;
    min-width: clamp(220px, 60vw, 280px);
    scroll-snap-align: start;
  }

  .sorella-carousel__footnote {
    display: flex; align-items: center; justify-content: center;
    gap: var(--space-md);
    margin-block-start: var(--space-xl);
    text-align: center;
  }
  .sorella-carousel__footnote::before,
  .sorella-carousel__footnote::after {
    content: ""; flex: 0 1 64px; height: 1px;
    background: var(--color-mist-25);
  }

  @media (max-width: 640px) {
    .section-head.sorella-carousel__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "textarea", "id": "support_text", "label": "Support text", "default": "Worn, reordered, and gifted — the scents our customers can't put down." },
    { "type": "collection", "id": "collection", "label": "Collection (source)" },
    { "type": "range", "id": "product_count", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 8 },
    {
      "type": "select", "id": "card_variant", "label": "Card variant", "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "quick-add", "label": "Quick add" },
        { "value": "compact", "label": "Compact (impulse / testers)" }
      ]
    },
    { "type": "header", "content": "Social proof" },
    { "type": "checkbox", "id": "show_rank", "label": "Show bestseller rank badges", "info": "Numbered pills on each card — use for bestseller rows, not related products.", "default": false },
    { "type": "text", "id": "rank_prefix", "label": "Rank prefix", "default": "Nº" },
    { "type": "text", "id": "footnote", "label": "Trust footnote", "info": "Short reassurance line under the products, e.g. delivery or freshness promise.", "default": "Made fresh in Egypt" },
    { "type": "header", "content": "View all link" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show \"View all\" link", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    {
      "type": "select", "id": "view_all_style", "label": "View all style", "default": "text-link",
      "options": [
        { "value": "text-link", "label": "Quiet link" },
        { "value": "ghost", "label": "Ghost button" },
        { "value": "primary", "label": "Gold button" }
      ]
    },
    {
      "type": "select", "id": "layout", "label": "Layout", "default": "rail",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "rail", "label": "Rail (horizontal scroll)" }
      ]
    },
    { "type": "header", "content": "Layout & Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "mobile_padding_top", "label": "Padding top (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Padding bottom (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 }
  ],
  "presets": [{ "name": "Product carousel" }]
}
{% endschema %}
