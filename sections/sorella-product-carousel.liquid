{%- comment -%}
  sorella-product-carousel — product row/rail (Art Direction §10).
  Reused for homepage "Best sellers" AND product-page "related products"
  (same section, different source). No hardcoded content — all from settings.
  Renders sorella-product-card snippet; does not reimplement cards.
  Optional bestseller rank badges + trust footnote for conversion context.
  Optional conversion card content: description excerpt + Buy Now button that
  opens a per-product quantity modal (sorella-quick-buy-modal) wired to the
  theme's AJAX cart.
{%- endcomment -%}
{%- liquid
  assign s = section.settings

  assign source_products = s.collection.products
  assign source_url = s.collection.url

  assign wants_recommendations = false
  if s.collection == blank
    if product != blank or recommendations.performed
      assign wants_recommendations = true
    endif
  endif

  if wants_recommendations
    if recommendations.performed and recommendations.products_count > 0
      assign source_products = recommendations.products
      assign source_url = blank
    elsif product != blank
      assign fallback_collection = product.collections.first
      assign source_products = fallback_collection.products
      assign source_url = fallback_collection.url
    endif
  endif
-%}
{% style %}
  #shopify-section-{{ section.id }} .sorella-carousel__pad {
    padding-block-start: {{ s.padding_top }}px;
    padding-block-end: {{ s.padding_bottom }}px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sorella-carousel__pad {
      padding-block-start: {{ s.mobile_padding_top }}px;
      padding-block-end: {{ s.mobile_padding_bottom }}px;
    }
  }
{% endstyle %}
{%- liquid
  assign wants_arrows = false
  assign wants_progress = false
  if s.layout == 'rail'
    if s.show_arrows
      assign wants_arrows = true
    endif
    if s.show_progress
      assign wants_progress = true
    endif
  endif
-%}
{%- if source_products.size > 0 -%}
  <section class="sorella-carousel surface-ink" data-section-id="{{ section.id }}"
    {%- if s.layout == 'rail' %} data-carousel-root{% endif %}
    {%- if s.layout == 'rail' and s.autoplay %} data-carousel-autoplay="{{ s.autoplay_interval | times: 1000 }}"{% endif %}
    {%- if wants_recommendations %}
    data-recommendations
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ s.product_count | at_most: 10 }}"
    {%- endif %}>
    <div class="container container--catalog sorella-carousel__pad">
      <div class="section-head sorella-carousel__head">
        <div class="sorella-carousel__head-text">
          {%- if s.eyebrow != blank -%}
            <span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>
          {%- endif -%}
          {%- if s.heading != blank -%}
            <h2 class="t-display-md">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.support_text != blank -%}
            <p class="t-body sorella-carousel__support">{{ s.support_text }}</p>
          {%- endif -%}
        </div>
        {%- liquid
          assign wants_view_all = false
          if s.show_view_all and s.view_all_label != blank and source_url != blank
            assign wants_view_all = true
          endif
        -%}
        {%- if wants_view_all -%}
          <div class="sorella-carousel__head-action">
            {% render 'sorella-button', label: s.view_all_label, href: source_url, style: s.view_all_style, icon: 'arrow-right' %}
          </div>
        {%- endif -%}
      </div>

      <div class="sorella-carousel__body sorella-carousel__body--{{ s.layout }}">
        {%- liquid
          assign rank = 0
        -%}
        {%- if s.layout == 'rail' -%}
          <ul class="sorella-carousel__track{% if wants_progress %} has-progress{% endif %}" role="list" data-carousel-track>
            {%- for card_product in source_products limit: s.product_count -%}
              {%- unless card_product.id == product.id -%}
                {%- assign rank = rank | plus: 1 -%}
                <li class="sorella-carousel__item sorella-carousel__slot">
                  {%- if s.show_rank -%}
                    <span class="sorella-carousel__rank t-eyebrow t-eyebrow--micro">{{ s.rank_prefix }} {{ rank }}</span>
                  {%- endif -%}
                  {%- liquid
                    assign modal_target = blank
                    if s.enable_quick_buy
                      assign modal_target = 'quick-buy-' | append: section.id | append: '-' | append: card_product.id
                    endif
                  -%}
                  {% render 'sorella-product-card', product: card_product, variant: s.card_variant,
                    show_description: s.show_card_description, description_words: s.card_description_words,
                    buy_now_target: modal_target, buy_now_label: s.buy_now_label, buy_now_style: s.buy_now_style %}
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
          {%- if wants_arrows or wants_progress -%}
            <div class="sorella-carousel__controls">
              {%- if wants_arrows -%}
                <button class="sorella-carousel__arrow" type="button" data-carousel-prev aria-label="{{ 'general.accessibility.previous' | t }}">
                  {% render 'sorella-icon', name: 'chevron-left', size: 20 %}
                </button>
              {%- endif -%}
              {%- if wants_progress -%}
                <div class="sorella-carousel__progress" aria-hidden="true">
                  <span class="sorella-carousel__progress-fill" data-carousel-progress></span>
                </div>
              {%- else -%}
                <span class="sorella-carousel__spacer" aria-hidden="true"></span>
              {%- endif -%}
              {%- if wants_arrows -%}
                <button class="sorella-carousel__arrow" type="button" data-carousel-next aria-label="{{ 'general.accessibility.next' | t }}">
                  {% render 'sorella-icon', name: 'chevron-right', size: 20 %}
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="catalog-grid">
            {%- for card_product in source_products limit: s.product_count -%}
              {%- unless card_product.id == product.id -%}
                {%- assign rank = rank | plus: 1 -%}
                <div class="sorella-carousel__slot">
                  {%- if s.show_rank -%}
                    <span class="sorella-carousel__rank t-eyebrow t-eyebrow--micro">{{ s.rank_prefix }} {{ rank }}</span>
                  {%- endif -%}
                  {%- liquid
                    assign modal_target = blank
                    if s.enable_quick_buy
                      assign modal_target = 'quick-buy-' | append: section.id | append: '-' | append: card_product.id
                    endif
                  -%}
                  {% render 'sorella-product-card', product: card_product, variant: s.card_variant,
                    show_description: s.show_card_description, description_words: s.card_description_words,
                    buy_now_target: modal_target, buy_now_label: s.buy_now_label, buy_now_style: s.buy_now_style %}
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- if s.footnote != blank -%}
        <p class="sorella-carousel__footnote t-caption text-mist">{{ s.footnote }}</p>
      {%- endif -%}
    </div>

    {%- if s.enable_quick_buy -%}
      {%- for card_product in source_products limit: s.product_count -%}
        {%- unless card_product.id == product.id or card_product.available == false -%}
          {% render 'sorella-quick-buy-modal', product: card_product, uid: section.id, description_words: s.card_description_words %}
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}
  </section>
{%- endif -%}

{% stylesheet %}
  /* .section-head in components.css loads later and re-sets flex-direction;
     double the class specificity so this row layout wins the cascade. */
  .section-head.sorella-carousel__head {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
  }
  .sorella-carousel__head-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: start;
    gap: var(--space-sm);
  }
  .sorella-carousel__support {
    color: var(--color-parchment-65);
    color: color-mix(in srgb, var(--color-parchment) 72%, transparent);
    max-width: 46ch;
    margin: 0;
  }
  .sorella-carousel__head-action { flex: none; padding-block-end: 4px; }

  /* Control bar under the rail — arrows flank the gold progress thread */
  .sorella-carousel__controls {
    display: flex; align-items: center; gap: var(--space-md);
    margin-block-start: var(--space-md);
  }
  .sorella-carousel__spacer { flex: 1; }
  .sorella-carousel__arrow {
    width: 44px; height: 44px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--color-mist-25); border-radius: var(--radius-full);
    background: transparent; color: var(--color-parchment);
    transition: border-color var(--dur-hover) var(--ease-out),
                color var(--dur-hover) var(--ease-out),
                background-color var(--dur-hover) var(--ease-out),
                opacity var(--dur-hover) var(--ease-out);
  }
  .sorella-carousel__arrow:hover {
    border-color: var(--color-gold-40); color: var(--color-gold);
    background: var(--color-gold-15);
  }
  .sorella-carousel__arrow.is-disabled { opacity: 0.35; pointer-events: none; }
  [dir="rtl"] .sorella-carousel__arrow svg { transform: scaleX(-1); }
  @media (max-width: 749px) {
    .sorella-carousel__arrow { width: 38px; height: 38px; }
  }

  /* Progress thread — a gold line between the arrows replaces the scrollbar */
  .sorella-carousel__progress {
    flex: 1; height: 2px;
    background: var(--color-parchment-12); border-radius: var(--radius-pill);
    overflow: hidden;
  }
  .sorella-carousel__progress-fill {
    display: block; height: 100%; width: 0%;
    background: var(--color-gold); border-radius: inherit;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sorella-carousel__progress-fill { transition: width 120ms linear; }
  }
  .sorella-carousel__track.has-progress {
    scrollbar-width: none;
    padding-block-end: 0;
  }
  .sorella-carousel__track.has-progress::-webkit-scrollbar { display: none; }

  /* Drag to scroll — snap releases while the pointer holds the rail */
  .sorella-carousel__track { cursor: grab; }
  .sorella-carousel__track.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
    user-select: none;
  }

  /* Uniform slots — the slot stretches to the row/track height and the card
     fills it, so every card ends on the same ledger line. */
  .sorella-carousel__slot {
    position: relative;
    display: flex; flex-direction: column;
  }
  .sorella-carousel__slot .sorella-card { flex: 1; }
  /* Top-right so it never collides with sale/sold-out badges (top-left) */
  .sorella-carousel__rank {
    position: absolute; z-index: 2;
    inset-block-start: var(--space-sm); inset-inline-end: var(--space-sm);
    padding: 6px 12px; border-radius: var(--radius-pill);
    background: var(--color-ink-90);
    border: 1px solid var(--color-gold-40);
    color: var(--color-gold);
    pointer-events: none;
  }

  .sorella-carousel__track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-block-end: var(--space-sm);
    margin-inline: calc(var(--space-lg) * -1);
    padding-inline: var(--space-lg);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-mist-40) transparent;
  }
  .sorella-carousel__track::-webkit-scrollbar { height: 6px; }
  .sorella-carousel__track::-webkit-scrollbar-thumb {
    background: var(--color-mist-40);
    border-radius: var(--radius-pill);
  }
  /* Fixed rail width = unified cards; track items stretch to the tallest. */
  .sorella-carousel__item {
    flex: 0 0 min(272px, 78vw);
    min-width: 0;
    scroll-snap-align: start;
  }

  .sorella-carousel__footnote {
    display: flex; align-items: center; justify-content: center;
    gap: var(--space-md);
    margin-block-start: var(--space-xl);
    text-align: center;
  }
  .sorella-carousel__footnote::before,
  .sorella-carousel__footnote::after {
    content: ""; flex: 0 1 64px; height: 1px;
    background: var(--color-mist-25);
  }

  @media (max-width: 640px) {
    .section-head.sorella-carousel__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "textarea", "id": "support_text", "label": "Support text", "default": "Worn, reordered, and gifted — the scents our customers can't put down." },
    { "type": "collection", "id": "collection", "label": "Collection (source)" },
    { "type": "range", "id": "product_count", "label": "Products to show", "min": 4, "max": 16, "step": 1, "default": 8 },
    {
      "type": "select", "id": "card_variant", "label": "Card variant", "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "quick-add", "label": "Quick add" },
        { "value": "compact", "label": "Compact (impulse / testers)" }
      ]
    },
    { "type": "header", "content": "Card content" },
    { "type": "checkbox", "id": "show_card_description", "label": "Show product description", "info": "Plain-text excerpt from the product description.", "default": false },
    { "type": "range", "id": "card_description_words", "label": "Description length", "min": 8, "max": 40, "step": 2, "unit": "wds", "default": 18 },
    { "type": "checkbox", "id": "enable_quick_buy", "label": "Show Buy Now button", "info": "Opens a quantity dialog with Add to cart — no page reload.", "default": false },
    { "type": "text", "id": "buy_now_label", "label": "Buy Now label", "default": "Buy Now" },
    {
      "type": "select", "id": "buy_now_style", "label": "Buy Now style", "default": "primary",
      "options": [
        { "value": "primary", "label": "Gold button" },
        { "value": "ghost", "label": "Ghost button" }
      ]
    },
    { "type": "header", "content": "Social proof" },
    { "type": "checkbox", "id": "show_rank", "label": "Show bestseller rank badges", "info": "Numbered pills on each card — use for bestseller rows, not related products.", "default": false },
    { "type": "text", "id": "rank_prefix", "label": "Rank prefix", "default": "Nº" },
    { "type": "text", "id": "footnote", "label": "Trust footnote", "info": "Short reassurance line under the products, e.g. delivery or freshness promise.", "default": "Made fresh in Egypt" },
    { "type": "header", "content": "View all link" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show \"View all\" link", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    {
      "type": "select", "id": "view_all_style", "label": "View all style", "default": "text-link",
      "options": [
        { "value": "text-link", "label": "Quiet link" },
        { "value": "ghost", "label": "Ghost button" },
        { "value": "primary", "label": "Gold button" }
      ]
    },
    {
      "type": "select", "id": "layout", "label": "Layout", "default": "rail",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "rail", "label": "Rail (horizontal scroll)" }
      ]
    },
    { "type": "header", "content": "Carousel controls", "info": "Apply to the Rail layout only." },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "info": "Previous / next buttons at the ends of the progress line.", "default": true },
    { "type": "checkbox", "id": "show_progress", "label": "Show progress line", "info": "A thin gold line under the products that tracks scroll position, replacing the grey scrollbar.", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-rotate", "info": "Advances one card at a time and returns to the start after the last one. Pauses while shoppers point at, touch, or focus the products.", "default": false },
    { "type": "range", "id": "autoplay_interval", "label": "Rotate every", "min": 2, "max": 10, "step": 1, "unit": "s", "default": 4 },
    { "type": "header", "content": "Layout & Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "mobile_padding_top", "label": "Padding top (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Padding bottom (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 20 }
  ],
  "presets": [{ "name": "Product carousel" }]
}
{% endschema %}
