{%- comment -%}
  sorella-testimonials — structured reviews, 3-up glass cards (Art Direction §10).
  Reused on homepage + PDP reviews. Renders sorella-testimonial-card per block.
  Zero hardcoded content — all values come from section/block settings.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-testimonials surface-ink section-pad" data-section-id="{{ section.id }}">
  <div class="container container--lock">
    {%- if s.eyebrow != blank or s.heading != blank or s.show_summary -%}
      <div class="section-head section-head--center">
        {%- if s.eyebrow != blank -%}
          <span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="t-display-md">{{ s.heading }}</h2>
        {%- endif -%}
        {%- if s.show_summary and s.summary_rating != blank -%}
          <div class="sorella-testimonials__summary">
            <span class="t-display-md text-gold">{{ s.summary_rating }}</span>
            {% render 'sorella-star-rating', value: 5 %}
            {%- if s.summary_label != blank -%}
              <span class="t-body-strong">{{ s.summary_label }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sorella-testimonials__grid">
        {%- for block in section.blocks -%}
          <div class="sorella-testimonials__item" {{ block.shopify_attributes }}>
            {% render 'sorella-testimonial-card',
              quote: block.settings.quote,
              author: block.settings.author,
              date: block.settings.date,
              rating: block.settings.rating,
              verified: block.settings.verified %}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .sorella-testimonials__summary {
    display: inline-flex; align-items: center; flex-wrap: wrap;
    justify-content: center; gap: var(--space-sm);
    margin-block-start: var(--space-xs);
  }
  .sorella-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }
  .sorella-testimonials__item { display: flex; }
  .sorella-testimonials__item > * { width: 100%; }
  @media (max-width: 735px) {
    .sorella-testimonials__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our customers tell it better than we do" },
    { "type": "header", "content": "Summary" },
    { "type": "checkbox", "id": "show_summary", "label": "Show summary rating", "default": true },
    { "type": "text", "id": "summary_rating", "label": "Summary rating", "default": "4.9" },
    { "type": "text", "id": "summary_label", "label": "Summary label", "default": "Excellent" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author", "default": "Verified buyer" },
        { "type": "text", "id": "date", "label": "Date" },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
