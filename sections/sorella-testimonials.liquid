{%- comment -%}
  sorella-testimonials — structured reviews wall (Art Direction §10).
  Two layouts, merchant-selectable:
    "split" (default) — one parent grid: intro column (eyebrow, heading, lead,
      summary rating) on the inline-start side, and an infinitely looping
      vertical marquee of uniform review cards on the inline-end side. The
      track holds two copies of the card list (second copy aria-hidden) and
      translates -50% for a seamless loop. Pauses on hover/focus, falls back
      to a static scrollable column under prefers-reduced-motion.
    "grid" — the legacy centered head + card grid with featured pull-quote.
  Reused on homepage + PDP reviews.
  Zero hardcoded content — all values come from section/block settings.
  Product context: product.metafields.sorella.reviews (list of metaobjects OR a
  JSON list with quote/author/rating/verified/role/date/context fields) takes
  precedence over section blocks; blocks remain the demo/default fallback.
{%- endcomment -%}
{%- liquid
  assign s = section.settings

  assign metafield_reviews = blank
  if product
    assign reviews_field = product.metafields.sorella.reviews
    if reviews_field != blank
      assign metafield_reviews = reviews_field.value
    endif
  endif
-%}
{% style %}
  #shopify-section-{{ section.id }} .sorella-testimonials {
    padding-block-start: {{ s.padding_top }}px;
    padding-block-end: {{ s.padding_bottom }}px;
    --tm-height: {{ s.carousel_height }}px;
    --tm-duration: {{ s.scroll_speed }}s;
    --tm-gap: {{ s.card_gap }}px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sorella-testimonials {
      padding-block-start: {{ s.mobile_padding_top }}px;
      padding-block-end: {{ s.mobile_padding_bottom }}px;
      --tm-height: {{ s.carousel_height_mobile }}px;
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .sorella-testimonials__split {
      grid-template-columns: minmax(0, 1fr) {{ s.reviews_width }}%;
    }
  }
  #shopify-section-{{ section.id }} .sorella-testimonials__marquee {
    padding: {{ s.carousel_padding }}px;
  }
{% endstyle %}
<section class="sorella-testimonials {{ s.surface | default: 'surface-ink' }}" data-section-id="{{ section.id }}">
  <div class="container container--lock">
    {%- if s.layout == 'split' -%}
      <div class="sorella-testimonials__split">
        <header class="sorella-testimonials__intro">
          {%- if s.eyebrow != blank -%}
            <span class="section-head__eyebrow t-eyebrow t-eyebrow--wide">{{ s.eyebrow }}</span>
          {%- endif -%}
          {%- if s.heading != blank -%}
            <h2 class="t-display-lg">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.lead != blank -%}
            <div class="sorella-testimonials__lead t-lead text-mist">{{ s.lead }}</div>
          {%- endif -%}
          {%- if s.show_stats -%}
            {%- liquid
              assign stat1_value = 0
              if s.stat1_collection != blank
                assign stat1_value = s.stat1_collection.all_products_count
              elsif s.stat1_use_all
                assign stat1_value = collections.all.all_products_count
              elsif s.stat1_number > 0
                assign stat1_value = s.stat1_number
              endif

              assign stat2_value = 0
              if s.stat2_collection != blank
                assign stat2_value = s.stat2_collection.all_products_count
              elsif s.stat2_number > 0
                assign stat2_value = s.stat2_number
              endif
            -%}
            {%- if stat1_value > 0 or stat2_value > 0 -%}
              <div class="sorella-testimonials__stats">
                {%- if stat1_value > 0 -%}
                  <div class="sorella-testimonials__stat">
                    <span class="sorella-testimonials__stat-value t-display-lg text-gold">
                      <span data-sorella-countup data-count-to="{{ stat1_value }}" data-count-duration="{{ s.count_duration }}">{{ stat1_value }}</span>{{ s.stat1_suffix }}
                    </span>
                    {%- if s.stat1_label != blank -%}
                      <span class="sorella-testimonials__stat-label t-caption text-mist">{{ s.stat1_label }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- if stat2_value > 0 -%}
                  <div class="sorella-testimonials__stat">
                    <span class="sorella-testimonials__stat-value t-display-lg text-gold">
                      <span data-sorella-countup data-count-to="{{ stat2_value }}" data-count-duration="{{ s.count_duration }}">{{ stat2_value }}</span>{{ s.stat2_suffix }}
                    </span>
                    {%- if s.stat2_label != blank -%}
                      <span class="sorella-testimonials__stat-label t-caption text-mist">{{ s.stat2_label }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}
          {%- if s.show_summary and s.summary_rating != blank -%}
            {%- assign summary_value = s.summary_rating | times: 1.0 -%}
            <div class="sorella-testimonials__summary">
              <span class="t-display-lg text-gold">{{ s.summary_rating }}</span>
              {% render 'sorella-star-rating', value: summary_value %}
              {%- if s.summary_label != blank -%}
                <span class="t-body-strong">{{ s.summary_label }}</span>
              {%- endif -%}
            </div>
            {%- if s.summary_note != blank -%}
              <p class="sorella-testimonials__note t-caption text-mist">{{ s.summary_note }}</p>
            {%- endif -%}
          {%- endif -%}
        </header>

        <div class="sorella-testimonials__marquee" role="region" aria-label="{{ 'testimonials.reviews_region' | t }}" tabindex="0">
          <div class="sorella-testimonials__track">
            {%- for copy in (1..2) -%}
              <div class="sorella-testimonials__list"{% if copy == 2 %} aria-hidden="true"{% endif %}>
                {%- if metafield_reviews != blank and metafield_reviews.size > 0 -%}
                  {%- for item in metafield_reviews -%}
                    {%- liquid
                      assign r_quote = item.quote.value | default: item.quote
                      assign r_author = item.author.value | default: item.author
                      assign r_role = item.role.value | default: item.role
                      assign r_date = item.date.value | default: item.date
                      assign r_context = item.context.value | default: item.context
                      assign r_rating = item.rating.value | default: item.rating | default: 5
                      assign r_verified = item.verified.value | default: item.verified, allow_false: true
                      assign r_avatar = item.avatar.value | default: item.avatar
                    -%}
                    <div class="sorella-testimonials__cell">
                      {% render 'sorella-testimonial-card',
                        quote: r_quote,
                        author: r_author,
                        role: r_role,
                        date: r_date,
                        context_label: r_context,
                        rating: r_rating,
                        verified: r_verified,
                        avatar: r_avatar %}
                    </div>
                  {%- endfor -%}
                {%- else -%}
                  {%- for block in section.blocks -%}
                    <div class="sorella-testimonials__cell"{% if copy == 1 %} {{ block.shopify_attributes }}{% endif %}>
                      {% render 'sorella-testimonial-card',
                        quote: block.settings.quote,
                        author: block.settings.author,
                        date: block.settings.date,
                        rating: block.settings.rating,
                        verified: block.settings.verified,
                        avatar: block.settings.avatar,
                        product: block.settings.product,
                        context_label: block.settings.context_label %}
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- else -%}
      {%- if s.eyebrow != blank or s.heading != blank or s.show_summary -%}
        <div class="section-head section-head--center">
          {%- if s.eyebrow != blank -%}
            <span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>
          {%- endif -%}
          {%- if s.heading != blank -%}
            <h2 class="t-display-md">{{ s.heading }}</h2>
          {%- endif -%}
          {%- if s.show_summary and s.summary_rating != blank -%}
            {%- assign summary_value = s.summary_rating | times: 1.0 -%}
            <div class="sorella-testimonials__summary">
              <span class="t-display-md text-gold">{{ s.summary_rating }}</span>
              {% render 'sorella-star-rating', value: summary_value %}
              {%- if s.summary_label != blank -%}
                <span class="t-body-strong">{{ s.summary_label }}</span>
              {%- endif -%}
            </div>
            {%- if s.summary_note != blank -%}
              <p class="sorella-testimonials__note t-caption text-mist">{{ s.summary_note }}</p>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if metafield_reviews != blank and metafield_reviews.size > 0 -%}
        <div class="sorella-testimonials__grid">
          {%- for item in metafield_reviews -%}
            {%- liquid
              assign r_quote = item.quote.value | default: item.quote
              assign r_author = item.author.value | default: item.author
              assign r_role = item.role.value | default: item.role
              assign r_date = item.date.value | default: item.date
              assign r_context = item.context.value | default: item.context
              assign r_rating = item.rating.value | default: item.rating | default: 5
              assign r_verified = item.verified.value | default: item.verified, allow_false: true
              assign r_avatar = item.avatar.value | default: item.avatar
            -%}
            <div class="sorella-testimonials__item">
              {% render 'sorella-testimonial-card',
                quote: r_quote,
                author: r_author,
                role: r_role,
                date: r_date,
                context_label: r_context,
                rating: r_rating,
                verified: r_verified,
                avatar: r_avatar %}
            </div>
          {%- endfor -%}
        </div>
      {%- elsif section.blocks.size > 0 -%}
        <div class="sorella-testimonials__grid">
          {%- for block in section.blocks -%}
            <div class="sorella-testimonials__item{% if block.settings.featured %} sorella-testimonials__item--featured{% endif %}" {{ block.shopify_attributes }}>
              {% render 'sorella-testimonial-card',
                quote: block.settings.quote,
                author: block.settings.author,
                date: block.settings.date,
                rating: block.settings.rating,
                verified: block.settings.verified,
                avatar: block.settings.avatar,
                product: block.settings.product,
                context_label: block.settings.context_label,
                featured: block.settings.featured %}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .sorella-testimonials__summary {
    display: inline-flex; align-items: center; flex-wrap: wrap;
    justify-content: center; gap: var(--space-sm);
    margin-block-start: var(--space-xs);
  }
  .sorella-testimonials__note { margin-block-start: var(--space-xxs); }

  /* ── Split layout: intro + infinite vertical marquee ─────────── */
  .sorella-testimonials__split {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--space-xxl);
    align-items: center;
  }
  .sorella-testimonials__intro {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: var(--space-md);
    position: sticky;
    top: calc(var(--nav-height-scrolled, 72px) + var(--space-lg));
  }
  .sorella-testimonials__lead { max-width: 52ch; }
  .sorella-testimonials__intro .sorella-testimonials__summary {
    justify-content: flex-start;
    gap: var(--space-md);
    margin-block-start: var(--space-sm);
  }
  .sorella-testimonials__intro .sorella-stars .sorella-icon {
    width: 22px; height: 22px;
  }
  .sorella-testimonials__stats {
    display: flex; flex-wrap: wrap;
    gap: var(--space-lg) var(--space-xxl);
    width: 100%;
    padding-block-start: var(--space-lg);
    border-block-start: var(--border-hairline);
  }
  .sorella-testimonials__stat {
    display: flex; flex-direction: column; gap: var(--space-xxs);
  }
  .sorella-testimonials__stat-value {
    font-variant-numeric: tabular-nums;
  }
  @media (min-width: 990px) {
    .sorella-testimonials__intro {
      min-height: var(--tm-height, 520px);
      justify-content: flex-start;
    }
    .sorella-testimonials__intro .sorella-testimonials__lead {
      margin-block-start: var(--space-sm);
    }
    .sorella-testimonials__intro .sorella-testimonials__summary,
    .sorella-testimonials__intro .sorella-testimonials__stats {
      margin-block-start: auto;
    }
    .sorella-testimonials__intro .sorella-testimonials__stats ~ .sorella-testimonials__summary {
      margin-block-start: var(--space-md);
    }
  }
  @media (max-width: 989px) {
    .sorella-testimonials__stats { justify-content: center; text-align: center; }
    .sorella-testimonials__stat { align-items: center; }
  }
  .sorella-testimonials__marquee {
    position: relative;
    height: var(--tm-height, 520px);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 14%, #000 86%, transparent);
    mask-image: linear-gradient(to bottom, transparent, #000 14%, #000 86%, transparent);
  }
  .sorella-testimonials__track {
    display: flex; flex-direction: column;
    animation: sorella-tm-scroll var(--tm-duration, 40s) linear infinite;
  }
  .sorella-testimonials__list {
    display: flex; flex-direction: column;
    gap: var(--tm-gap, 24px);
    padding-block-end: var(--tm-gap, 24px);
  }
  .sorella-testimonials__cell { display: flex; }
  .sorella-testimonials__cell > * { width: 100%; }
  /* Narrow marquee cards: stack buyer + product chip vertically */
  .sorella-testimonials__cell .sorella-testimonial__meta {
    flex-direction: column;
    align-items: stretch;
  }
  .sorella-testimonials__cell .sorella-testimonial__context {
    width: 100%;
    justify-content: space-between;
  }
  .sorella-testimonials__marquee {
    scrollbar-width: thin;
    scrollbar-color: var(--color-gold-40) transparent;
  }
  .sorella-testimonials__marquee::-webkit-scrollbar { width: 6px; }
  .sorella-testimonials__marquee::-webkit-scrollbar-track { background: transparent; }
  .sorella-testimonials__marquee::-webkit-scrollbar-thumb {
    background: var(--color-gold-40);
    border-radius: var(--radius-pill);
  }
  .sorella-testimonials__marquee::-webkit-scrollbar-thumb:hover {
    background: var(--color-gold);
  }
  @keyframes sorella-tm-scroll {
    to { transform: translateY(-50%); }
  }
  .sorella-testimonials__marquee:hover .sorella-testimonials__track,
  .sorella-testimonials__marquee:focus-within .sorella-testimonials__track,
  .sorella-testimonials__marquee:focus .sorella-testimonials__track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .sorella-testimonials__track { animation: none; }
    .sorella-testimonials__marquee {
      overflow-y: auto;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .sorella-testimonials__list[aria-hidden="true"] { display: none; }
  }
  @media (max-width: 989px) {
    .sorella-testimonials__split { grid-template-columns: 1fr; gap: var(--space-xl); }
    .sorella-testimonials__intro {
      position: static;
      align-items: center; text-align: center;
    }
    .sorella-testimonials__intro .sorella-testimonials__summary {
      justify-content: center;
    }
  }

  /* ── Legacy grid layout ───────────────────────────────────────── */
  .sorella-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .sorella-testimonials__item { display: flex; }
  .sorella-testimonials__item > * { width: 100%; }
  .sorella-testimonials__item--featured { grid-column: span 2; }

  .sorella-testimonial {
    display: flex; flex-direction: column; gap: var(--space-md);
  }
  .sorella-testimonial:hover,
  .sorella-testimonial:focus-within {
    border-color: var(--color-gold-40);
  }
  @media (prefers-reduced-motion: no-preference) {
    .sorella-testimonial { transition: border-color 0.3s ease; }
  }
  .sorella-testimonial__top {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: var(--space-sm);
  }
  .sorella-testimonial__date { white-space: nowrap; }
  .sorella-testimonial__quote {
    flex-grow: 1;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.55;
  }
  .sorella-testimonial--featured .sorella-testimonial__quote {
    font-size: 24px;
    line-height: 1.45;
  }
  .sorella-testimonial--featured .sorella-testimonial__quote::before {
    content: "\201C";
    display: block;
    font-family: var(--font-display);
    font-style: normal;
    font-size: 56px;
    line-height: 0.6;
    color: var(--color-gold);
    margin-block-end: var(--space-sm);
  }
  .sorella-testimonial__meta {
    display: flex; align-items: center; flex-wrap: wrap;
    justify-content: space-between; gap: var(--space-sm);
    border-block-start: var(--border-hairline);
    padding-block-start: var(--space-md);
  }
  .sorella-testimonial__buyer {
    display: flex; align-items: center; gap: var(--space-sm); min-width: 0;
  }
  .sorella-testimonial__avatar {
    width: 40px; height: 40px;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }
  .sorella-testimonial__monogram {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; flex-shrink: 0;
    border-radius: var(--radius-full);
    background: var(--color-gold-15);
    border: 1px solid var(--color-gold-40);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 16px;
  }
  .sorella-testimonial__person {
    display: flex; flex-direction: column; gap: 2px; min-width: 0;
  }
  .sorella-testimonial__name {
    display: inline-flex; align-items: center; gap: var(--space-xxs);
  }
  .sorella-testimonial__verified {
    display: inline-flex; align-items: center; justify-content: center;
    width: 16px; height: 16px; flex-shrink: 0;
    border-radius: var(--radius-full);
    background: var(--color-gold);
    color: var(--color-ink);
  }
  .sorella-testimonial__verified .sorella-icon { stroke-width: 3.4; }
  .sorella-testimonial__context {
    display: inline-flex; align-items: center; gap: var(--space-xs);
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-gold-40);
    color: var(--color-gold);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }
  .sorella-testimonial__context-text {
    display: inline-flex; align-items: baseline; gap: var(--space-xxs);
    min-width: 0; overflow: hidden;
  }
  .sorella-testimonial__context-name {
    font-weight: 600;
    overflow: hidden; text-overflow: ellipsis;
  }
  .sorella-testimonial__context .sorella-icon { flex-shrink: 0; }
  a.sorella-testimonial__context:hover,
  a.sorella-testimonial__context:focus-visible {
    background: var(--color-gold-15);
  }
  a.sorella-testimonial__context:hover .sorella-icon {
    transform: translateX(2px);
  }
  @media (prefers-reduced-motion: no-preference) {
    a.sorella-testimonial__context .sorella-icon { transition: transform 0.2s ease; }
  }
  @media (max-width: 989px) {
    .sorella-testimonials__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 735px) {
    .sorella-testimonials__grid { grid-template-columns: 1fr; }
    .sorella-testimonials__item--featured { grid-column: span 1; }
    .sorella-testimonial--featured .sorella-testimonial__quote { font-size: 20px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    'use strict';

    function formatValue(value, decimals) {
      return new Intl.NumberFormat(undefined, {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals
      }).format(value);
    }

    function animateCount(el, to, decimals, duration) {
      var start = null;
      function step(ts) {
        if (start === null) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 4);
        el.textContent = formatValue(to * eased, decimals);
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = formatValue(to, decimals);
      }
      requestAnimationFrame(step);
    }

    function initCountUps(root) {
      var els = (root || document).querySelectorAll('[data-sorella-countup]:not([data-count-done])');
      if (!els.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      els.forEach(function (el) {
        el.setAttribute('data-count-done', '');
        var raw = el.getAttribute('data-count-to') || '0';
        var to = parseFloat(raw);
        if (isNaN(to)) return;
        var decimals = raw.indexOf('.') > -1 ? (raw.split('.')[1] || '').length : 0;
        var duration = (parseFloat(el.getAttribute('data-count-duration')) || 2) * 1000;
        if (reduce || !('IntersectionObserver' in window)) {
          el.textContent = formatValue(to, decimals);
          return;
        }
        el.textContent = formatValue(0, decimals);
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            io.unobserve(el);
            animateCount(el, to, decimals, duration);
          });
        }, { threshold: 0.4 });
        io.observe(el);
      });
    }

    initCountUps(document);
    document.addEventListener('shopify:section:load', function (event) {
      initCountUps(event.target);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our customers tell it better than we do" },
    {
      "type": "select",
      "id": "surface",
      "label": "Background surface",
      "options": [
        { "value": "surface-ink", "label": "Ink" },
        { "value": "surface-ink--well", "label": "Ink (well)" },
        { "value": "surface-parchment", "label": "Parchment" }
      ],
      "default": "surface-ink"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "split", "label": "Split — intro + scrolling reviews" },
        { "value": "grid", "label": "Grid — centered head + cards" }
      ],
      "default": "split"
    },
    { "type": "header", "content": "Split layout" },
    {
      "type": "richtext",
