{%- comment -%}
  sorella-feature-trio — generic educational / value trio (StitchDesign "Olfactory
  Architecture" & "Art of Inspiration" value cards). Numbered or icon glass cards in a
  row with an optional connector line. Zero hardcoded content — all from block settings.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-feature-trio blob-scene {{ s.surface | default: 'surface-ink--well' }} section-pad" data-section-id="{{ section.id }}">
  {%- if s.show_blob -%}
    {% render 'sorella-blob', scheme: s.blob_scheme, single: true %}
  {%- endif -%}

  <div class="container container--bento sorella-feature-trio__inner">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head section-head--center">
        {%- if s.eyebrow != blank -%}<span class="section-head__eyebrow t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-lg">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="sorella-feature-trio__grid{% if s.show_connector %} sorella-feature-trio__grid--connected{% endif %}">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <article class="sorella-feature-trio__card glass-panel glass-panel--md glass-panel--sheen{% if b.emphasis %} is-emphasis{% endif %}" {{ block.shopify_attributes }}>
          {%- if b.badge != blank or b.icon != blank -%}
            <span class="sorella-feature-trio__badge">
              {%- if b.icon != blank -%}{% render 'sorella-icon', name: b.icon, size: 22 %}{%- else -%}{{ b.badge }}{%- endif -%}
            </span>
          {%- endif -%}
          {%- if b.heading != blank -%}<h3 class="t-headline">{{ b.heading }}</h3>{%- endif -%}
          {%- if b.label != blank -%}<span class="t-eyebrow text-gold sorella-feature-trio__label">{{ b.label }}</span>{%- endif -%}
          {%- if b.text != blank -%}<p class="t-body-sm sorella-feature-trio__text">{{ b.text }}</p>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-feature-trio__inner { position: relative; z-index: 1; }
  .section-head--center { text-align: center; align-items: center; display: flex; flex-direction: column; gap: var(--space-sm); margin-block-end: var(--space-xxl); }
  .sorella-feature-trio__grid {
    position: relative;
    display: grid; gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .sorella-feature-trio__grid--connected::before {
    content: ""; position: absolute; inset-inline: 6%; inset-block-start: 50%;
    height: 1px; background: var(--color-gold-40); z-index: 0;
  }
  @media (max-width: 767px) { .sorella-feature-trio__grid--connected::before { display: none; } }
  .sorella-feature-trio__card {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-sm);
    padding: var(--space-xl);
    transition: transform var(--dur-hover) var(--ease-out), border-color var(--dur-hover) var(--ease-out);
  }
  .sorella-feature-trio__card:hover { transform: translateY(-6px); }
  .sorella-feature-trio__card.is-emphasis { border-color: var(--color-gold-40); }
  .sorella-feature-trio__badge {
    display: inline-flex; align-items: center; justify-content: center;
    width: 64px; height: 64px; border-radius: var(--radius-full);
    background: var(--color-gold-15); border: 1px solid var(--color-gold-40);
    color: var(--color-gold); font-family: var(--font-display); font-size: 20px;
    margin-block-end: var(--space-xs);
  }
  .sorella-feature-trio__card.is-emphasis .sorella-feature-trio__badge { background: rgba(199,156,90,0.22); border-color: var(--color-gold); }
  .sorella-feature-trio__label { display: block; }
  .sorella-feature-trio__text { color: var(--color-parchment-65); max-width: 34ch; }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature Trio",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Complexity" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Olfactory Architecture" },
    { "type": "checkbox", "id": "show_connector", "label": "Show connector line", "default": true },
    { "type": "header", "content": "Surface & atmosphere" },
    {
      "type": "select", "id": "surface", "label": "Surface", "default": "surface-ink--well",
      "options": [
        { "value": "surface-ink--well", "label": "Deep well" },
        { "value": "surface-ink", "label": "Navy" },
        { "value": "surface-gradient", "label": "Gradient" }
      ]
    },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob", "default": true },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "slate",
      "options": [
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "gold-slate", "label": "Gold + Slate" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge (number)", "default": "01" },
        { "type": "text", "id": "icon", "label": "Icon name (overrides badge)", "info": "e.g. diamond, verified — uses the theme icon set." },
        { "type": "text", "id": "heading", "label": "Heading", "default": "The Opening" },
        { "type": "text", "id": "label", "label": "Label", "default": "Top Notes" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "The immediate impression — volatile citrus and light herbals that awaken the senses." },
        { "type": "checkbox", "id": "emphasis", "label": "Emphasise (gold border)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature trio",
      "blocks": [
        { "type": "step", "settings": { "badge": "01", "heading": "The Opening", "label": "Top Notes", "text": "The immediate impression — volatile citrus and light herbals that awaken the senses for the first 15 minutes." } },
        { "type": "step", "settings": { "badge": "02", "heading": "The Soul", "label": "Heart Notes", "text": "The true character of the fragrance. Rich florals and spices that emerge as the top notes fade, lasting for hours.", "emphasis": true } },
        { "type": "step", "settings": { "badge": "03", "heading": "The Anchor", "label": "Base Notes", "text": "The final depth. Heavy resins, musks, and woods that bind to the skin, creating a lingering trail of memory." } }
      ]
    }
  ]
}
{% endschema %}
