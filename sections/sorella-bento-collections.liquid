{%- comment -%}
  sorella-bento-collections — curated CATEGORY bento grid (Art Direction §5).
  Marketing surface: asymmetric spans signal importance. Per §7.3 category cells
  are photographic tiles only — NO blob field here.
  Reuses the sorella-bento-cell snippet; each cell falls back to its linked collection.
  Homepage guardrail: max 9 cells (≤9) — enforced via schema max_blocks.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-bento-collections surface-ink" data-section-id="{{ section.id }}">
  <div class="container container--bento section-pad">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow section-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="bento">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b = block.settings
          assign coll = collections[b.collection]
          assign link = coll.url
          assign heading = b.heading | default: coll.title
          assign image = b.image | default: coll.featured_image
        -%}
        <div class="bento__cell--{{ b.span }}" {{ block.shopify_attributes }}>
          {% render 'sorella-bento-cell',
            image: image,
            heading: heading,
            subheading: b.subheading,
            link: link,
            cta: b.cta,
            eyebrow: b.eyebrow,
            variant: b.variant %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-bento-collections .bento { align-items: stretch; }
{% endstylesheet %}

{% schema %}
{
  "name": "Bento Collections",
  "tag": "section",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by mood" }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Overrides the collection featured image." },
        { "type": "text", "id": "heading", "label": "Heading", "info": "Overrides the collection title." },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "text", "id": "cta", "label": "CTA label", "default": "Shop" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        {
          "type": "select", "id": "variant", "label": "Style", "default": "default",
          "options": [
            { "value": "default", "label": "Photo tile" },
            { "value": "panel", "label": "Split panel (image + text block)" },
            { "value": "campaign", "label": "Campaign (badge + centered)" }
          ]
        },
        {
          "type": "select", "id": "span", "label": "Span", "default": "1x1",
          "options": [
            { "value": "1x1", "label": "1×1" },
            { "value": "2x1", "label": "2×1 (wide)" },
            { "value": "1x2", "label": "1×2 (tall)" },
            { "value": "2x2", "label": "2×2 (feature)" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bento collections",
      "blocks": [
        { "type": "cell", "settings": { "heading": "For Her", "span": "1x1" } },
        { "type": "cell", "settings": { "heading": "For Him", "span": "1x1" } },
        { "type": "cell", "settings": { "heading": "Unisex", "span": "1x2", "variant": "panel", "subheading": "Shared skin scents that blur the line.", "cta": "Shop Unisex" } },
        { "type": "cell", "settings": { "heading": "The Seasonal Edit", "span": "2x1", "variant": "campaign", "eyebrow": "Limited Edition", "subheading": "A rotating capsule for the season.", "cta": "Shop the Edit" } },
        { "type": "cell", "settings": { "heading": "Perfume Oil", "span": "1x1" } },
        { "type": "cell", "settings": { "heading": "Bundles", "span": "1x1" } }
      ]
    }
  ]
}
{% endschema %}
