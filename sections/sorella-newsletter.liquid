{%- liquid
  assign s = section.settings
-%}
<section class="sec sec--tight">
  <div class="wrap">
    <div class="news">
      {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
      {%- if s.text != blank -%}<p>{{ s.text }}</p>{%- endif -%}
      {%- form 'customer', class: 'news__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="{{ s.placeholder | escape }}" aria-label="Email" required>
        <button class="btn btn--light" type="submit">{{ s.button_label }}</button>
        {%- if form.posted_successfully? -%}
          <p class="news__note">{{ s.success_text }}</p>
        {%- elsif form.errors -%}
          <p class="news__note">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .news__note{ color:rgba(255,255,255,.85); margin-top:14px; font-size:14px; }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "First to know when a scent drops." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Join the list for new releases, restocks, and the occasional free 5ml." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Sign up" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thanks — you're on the list." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
