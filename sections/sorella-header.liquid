{%- liquid
  assign brand = section.settings.brand_name | default: shop.name
  assign menu = section.settings.menu
  assign panel_id = 'MobileNav-' | append: section.id
-%}
<header class="header">
  <div class="wrap header__row">
    <a class="brand" href="{{ routes.root_url }}">{{ brand }}</a>

    <nav class="mainnav" aria-label="Primary">
      {%- if menu != blank and menu.links.size > 0 -%}
        {%- for link in menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="navitem navitem--has-children">
              <a class="navitem__top" href="{{ link.url }}" aria-haspopup="true">{{ link.title }}<svg class="navitem__caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
              <div class="navdrop">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a class="navitem__top" href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a class="navitem__top" href="{{ routes.all_products_collection_url }}">For Her</a>
        <a class="navitem__top" href="{{ routes.all_products_collection_url }}">For Him</a>
        <a class="navitem__top" href="{{ routes.all_products_collection_url }}">Bestsellers</a>
        <a class="navitem__top" href="{{ routes.all_products_collection_url }}">Oils</a>
      {%- endif -%}
    </nav>

    <div class="utils">
      <button class="iconbtn header__burger" type="button" data-menu-toggle="{{ panel_id }}" aria-label="Menu" aria-controls="{{ panel_id }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
      <a class="iconbtn" href="{{ routes.search_url }}" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </a>
      <a class="iconbtn" href="{{ routes.account_url }}" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6.5 8-6.5S20 17 20 21"/></svg>
      </a>
      <a class="iconbtn" href="{{ routes.cart_url }}" aria-label="Bag"{% if settings.cart_drawer_enabled %} data-cart-toggle="cart-drawer"{% endif %}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
        <span class="cartdot"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<div class="mnav" id="{{ panel_id }}" data-panel>
  <div class="mnav__scrim" data-close></div>
  <div class="mnav__panel" role="dialog" aria-label="Menu">
    <button class="mnav__close" type="button" data-close aria-label="Close">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="m6 6 12 12M18 6 6 18"/></svg>
    </button>
    <nav aria-label="Mobile">
      {%- if menu != blank and menu.links.size > 0 -%}
        {%- for link in menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            {%- for child in link.links -%}
              <a class="mnav__child" href="{{ child.url }}">{{ child.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">For Her</a>
        <a href="{{ routes.all_products_collection_url }}">For Him</a>
        <a href="{{ routes.all_products_collection_url }}">Bestsellers</a>
        <a href="{{ routes.all_products_collection_url }}">Oils</a>
      {%- endif -%}
    </nav>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .header__burger{ display:none; }
  @media(max-width:900px){ #shopify-section-{{ section.id }} .header__burger{ display:inline-flex; } }
  /* nav dropdown */
  #shopify-section-{{ section.id }} .navitem{ position:relative; display:inline-flex; align-items:center; }
  #shopify-section-{{ section.id }} .navitem__top{ display:inline-flex; align-items:center; gap:4px; }
  #shopify-section-{{ section.id }} .navitem__caret{ transition:transform .2s ease; }
  #shopify-section-{{ section.id }} .navitem--has-children:hover .navitem__caret,
  #shopify-section-{{ section.id }} .navitem--has-children:focus-within .navitem__caret{ transform:rotate(180deg); }
  #shopify-section-{{ section.id }} .navdrop{ position:absolute; top:100%; inset-inline-start:0; min-width:190px; background:#1A1A1A; border:1px solid rgba(255,255,255,.12); border-radius:12px; padding:8px; box-shadow:0 18px 40px rgba(0,0,0,.5); display:flex; flex-direction:column; gap:2px; opacity:0; visibility:hidden; transform:translateY(6px); transition:opacity .2s ease, transform .2s ease, visibility .2s ease; z-index:60; }
  #shopify-section-{{ section.id }} .navitem--has-children:hover .navdrop,
  #shopify-section-{{ section.id }} .navitem--has-children:focus-within .navdrop{ opacity:1; visibility:visible; transform:translateY(4px); }
  #shopify-section-{{ section.id }} .navdrop a{ padding:9px 12px; border-radius:8px; white-space:nowrap; font-size:14px; }
  #shopify-section-{{ section.id }} .navdrop a:hover{ background:rgba(255,255,255,.08); }
  .mnav__panel nav a.mnav__child{ font-family:var(--font-body,inherit); font-size:15px; padding:9px 0 9px 16px; opacity:.7; border-bottom:1px solid rgba(255,255,255,.10); }
  .mnav{ position:fixed; inset:0; z-index:80; visibility:hidden; opacity:0; transition:opacity .3s ease, visibility .3s ease; }
  .mnav.is-open{ visibility:visible; opacity:1; }
  .mnav__scrim{ position:absolute; inset:0; background:rgba(0,0,0,.42); }
  .mnav__panel{ position:absolute; inset-block:0; inset-inline-start:0; width:min(82vw,320px); background:#111111; color:#E8E8E8; padding:22px 24px; display:flex; flex-direction:column; gap:6px; transform:translateX(-100%); transition:transform .32s var(--ease); }
  .mnav.is-open .mnav__panel{ transform:none; }
  .mnav__close{ align-self:flex-end; width:44px; height:44px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%; margin-bottom:8px; }
  .mnav__panel nav{ display:flex; flex-direction:column; }
  .mnav__panel nav a{ font-family:var(--font-display); font-size:22px; padding:12px 0; border-bottom:1px solid rgba(255,255,255,.10); }
  body.is-locked{ overflow:hidden; }
</style>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "header-section",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand wordmark",
      "info": "Leave blank to use the store name."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    }
  ]
}
{% endschema %}
