{%- comment -%}
  sorella-header — Adaptive Nav Dock (Art Direction §9).
  Two scroll states: transparent-top (over hero) → glass dock (scrolled).
  Center links from a linklist; top-level items with children become mega-menus.
{%- endcomment -%}
{%- liquid
  assign start_top = false
  if template.name == 'index' and section.settings.transparent_top
    assign start_top = true
  endif
  assign dock_class = 'nav-dock--docked'
  if start_top
    assign dock_class = 'nav-dock--top'
  endif
-%}

<header class="nav-dock {{ dock_class }}"
  data-nav-dock
  data-scroll-hide="{{ section.settings.scroll_hide }}"
  role="banner">
  <div class="nav-dock__inner">
    {%- comment -%} Left — logo {%- endcomment -%}
    <a class="nav-dock__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name -%}
        <img class="nav-dock__logo-full" src="{{ settings.logo | image_url: width: 400 }}"
          width="{{ settings.logo_width }}" height="{{ settings.logo_width | divided_by: settings.logo.aspect_ratio | round }}" alt="{{ logo_alt | escape }}"
          style="width: {{ settings.logo_width }}px; height: auto;">
        {%- if settings.logo_mark != blank -%}
          <img class="nav-dock__logo-mark" src="{{ settings.logo_mark | image_url: width: 120 }}" width="120" height="{{ 120 | divided_by: settings.logo_mark.aspect_ratio | round }}" alt="{{ logo_alt | escape }}">
        {%- endif -%}
      {%- else -%}
        <span class="nav-dock__wordmark t-title">{{ settings.brand_name | default: shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Center — primary links {%- endcomment -%}
    <nav class="nav-dock__nav" aria-label="Primary">
      <ul class="nav-dock__links">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links != blank -%}
            <li class="nav-dock__item" data-megamenu>
              <a class="nav-dock__link t-nav-link" href="{{ link.url }}"
                data-megamenu-trigger aria-expanded="false" aria-haspopup="true">
                {{ link.title }} {% render 'sorella-icon', name: 'chevron-down', size: 14 %}
              </a>
              <div class="nav-dock__mega" data-megamenu-panel>
                {% render 'sorella-blob', single: true, scheme: 'gold', drift: false %}
                <div class="nav-dock__mega-inner glass-panel">
                  <ul class="nav-dock__mega-grid">
                    {%- for child in link.links -%}
                      <li>
                        <a class="nav-dock__mega-link t-body-strong" href="{{ child.url }}">{{ child.title }}</a>
                        {%- if child.links != blank -%}
                          <ul class="nav-dock__mega-sub">
                            {%- for grandchild in child.links -%}
                              <li><a class="t-body-sm text-mist" href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            </li>
          {%- else -%}
            <li class="nav-dock__item">
              <a class="nav-dock__link t-nav-link" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} Right — utility icons {%- endcomment -%}
    <div class="nav-dock__utils">
      <button class="nav-dock__icon" type="button" data-open-target="search-drawer" aria-label="{{ 'general.search.title' | t }}">
        {% render 'sorella-icon', name: 'search', size: 22 %}
      </button>
      <a class="nav-dock__icon nav-dock__icon--account" href="{{ routes.account_url }}" aria-label="{{ 'customer.account.title' | t }}">
        {% render 'sorella-icon', name: 'user', size: 22 %}
      </a>
      <a class="nav-dock__icon nav-dock__icon--cart" href="{{ routes.cart_url }}"
        {% if settings.cart_drawer_enabled %}data-open-target="cart-drawer"{% endif %} aria-label="{{ 'cart.general.title' | t }}">
        {% render 'sorella-icon', name: 'bag', size: 22 %}
        {% render 'sorella-badge', variant: 'cart', count: cart.item_count %}
      </a>
      <button class="nav-dock__icon nav-dock__icon--menu" type="button" data-open-target="mobile-drawer" aria-label="{{ 'general.accessibility.open_menu' | t }}">
        {% render 'sorella-icon', name: 'menu', size: 24 %}
      </button>
    </div>
  </div>
</header>

{%- comment -%} Mobile drawer — full-height glass (§9.5, §10) {%- endcomment -%}
<aside class="sorella-drawer sorella-drawer--start" id="mobile-drawer" data-panel data-scrim="[data-shared-scrim]" aria-hidden="true" aria-label="Menu">
  <div class="sorella-drawer__panel glass-panel">
    <div class="sorella-drawer__head">
      <span class="t-title">{{ settings.brand_name | default: shop.name }}</span>
      <button class="nav-dock__icon" type="button" data-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
        {% render 'sorella-icon', name: 'close', size: 22 %}
      </button>
    </div>
    <nav class="sorella-drawer__nav" aria-label="Mobile">
      <ul>
        {%- for link in section.settings.menu.links -%}
          <li>
            <a class="sorella-drawer__link t-headline" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links != blank -%}
              <ul class="sorella-drawer__sub">
                {%- for child in link.links -%}
                  <li><a class="t-body" href="{{ child.url }}">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
    <div class="sorella-drawer__foot">
      {% render 'sorella-social-links' %}
    </div>
  </div>
</aside>

{%- comment -%} Search drawer {%- endcomment -%}
<aside class="sorella-drawer sorella-drawer--top" id="search-drawer" data-panel data-scrim="[data-shared-scrim]" aria-hidden="true" aria-label="{{ 'general.search.title' | t }}">
  <div class="sorella-drawer__panel sorella-drawer__panel--search glass-panel">
    <form action="{{ routes.search_url }}" method="get" role="search" class="sorella-search-form">
      <input type="hidden" name="type" value="product">
      <label class="visually-hidden" for="header-search">{{ 'general.search.title' | t }}</label>
      <input type="search" id="header-search" name="q" placeholder="{{ 'general.search.placeholder' | t }}" autocomplete="off">
      {% render 'sorella-button', label: 'general.search.submit' | t, style: 'primary', type: 'submit' %}
      <button class="nav-dock__icon" type="button" data-close aria-label="{{ 'general.accessibility.close' | t }}">{% render 'sorella-icon', name: 'close', size: 22 %}</button>
    </form>
  </div>
</aside>

{{ 'chrome.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "checkbox", "id": "transparent_top", "label": "Transparent over homepage hero", "default": true },
    { "type": "checkbox", "id": "scroll_hide", "label": "Hide dock on scroll down, reveal on scroll up", "default": true }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
