{%- comment -%}
  sorella-password — coming-soon / password page over blob + glass (reuses hero pattern).
  Rendered inside layout/password.liquid. Holds the storefront password form + newsletter.
{%- endcomment -%}
{%- liquid assign s = section.settings -%}
<section class="sorella-password blob-scene surface-gradient">
  {%- if s.show_blob -%}{% render 'sorella-blob', scheme: s.blob_scheme %}{%- endif -%}

  <div class="container container--read sorella-password__inner">
    <div class="glass-panel glass-panel--xl glass-panel--sheen sorella-password__card">
      {%- if settings.logo != blank -%}
        <img class="sorella-password__logo" src="{{ settings.logo | image_url: width: 360 }}" width="{{ settings.logo_width }}" alt="{{ shop.name | escape }}" style="width: {{ settings.logo_width }}px; height: auto;">
      {%- else -%}
        <span class="t-title">{{ settings.brand_name | default: shop.name }}</span>
      {%- endif -%}

      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h1 class="t-display-lg">{{ s.heading }}</h1>{%- endif -%}
      {%- if s.subheading != blank -%}<p class="t-lead">{{ s.subheading }}</p>{%- endif -%}

      {%- if s.show_newsletter -%}
        <div class="sorella-password__newsletter">{% render 'sorella-newsletter-form', layout: 'inline' %}</div>
      {%- endif -%}

      <div class="sorella-password__enter">
        {%- form 'storefront_password', class: 'sorella-account__form' -%}
          {%- if form.errors -%}<div class="sorella-account__error t-caption">{{ form.errors | default_errors }}</div>{%- endif -%}
          <div class="sorella-field">
            <label class="sorella-field__label t-caption-strong" for="password">{{ s.password_label }}</label>
            <input type="password" name="password" id="password" autocomplete="current-password">
          </div>
          <button type="submit" class="btn btn--ghost btn--sm">{{ s.password_button }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-password { position: relative; min-height: 100vh; display: flex; align-items: center; padding-block: var(--space-section); }
  .sorella-password__inner { position: relative; z-index: 1; }
  .sorella-password__card { display: flex; flex-direction: column; gap: var(--space-md); align-items: center; text-align: center; padding: var(--space-xxl); color: var(--color-parchment); }
  .sorella-password__logo { margin-block-end: var(--space-sm); }
  .sorella-password__newsletter, .sorella-password__enter { width: 100%; max-width: 420px; }
  .sorella-password__enter { margin-block-start: var(--space-md); padding-block-start: var(--space-md); border-block-start: var(--border-hairline); }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Coming soon" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Something beautiful is on its way" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Sign up to be the first to know when we open." },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "password_label", "label": "Password field label", "default": "Enter store password" },
    { "type": "text", "id": "password_button", "label": "Password button", "default": "Enter" },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob field", "default": true },
    { "type": "select", "id": "blob_scheme", "label": "Blob colours", "default": "gold-slate",
      "options": [
        { "value": "gold-slate", "label": "Gold + Slate" },
        { "value": "gold", "label": "Gold" },
        { "value": "rose", "label": "Rose" }
      ] }
  ],
  "presets": [{ "name": "Password" }]
}
{% endschema %}
