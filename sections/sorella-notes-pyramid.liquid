{%- comment -%}
  sorella-notes-pyramid — the fragrance notes pyramid (Art Direction §10, Full Redesign Report §3).
  Top / heart / base tiers as stacked mini-cards with progressive inset (§9).
  Zero hardcoded content: the notes come from product metafields (namespace "sorella").
  Renders nothing when all three tiers are blank. PDP allows 1 blob behind the notes card (§7.3).
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign notes_top = product.metafields.sorella.notes_top.value | default: product.metafields.sorella.notes_top
  assign notes_heart = product.metafields.sorella.notes_heart.value | default: product.metafields.sorella.notes_heart
  assign notes_base = product.metafields.sorella.notes_base.value | default: product.metafields.sorella.notes_base
-%}
{%- if notes_top != blank or notes_heart != blank or notes_base != blank -%}
  <section class="sorella-notes-pyramid blob-scene surface-gradient section-pad" data-section-id="{{ section.id }}">
    {%- if s.show_blob -%}
      {% render 'sorella-blob', scheme: s.blob_scheme, single: true %}
    {%- endif -%}

    <div class="container container--read sorella-notes-pyramid__inner">
      {%- if s.eyebrow != blank or s.heading != blank -%}
        <div class="section-head">
          {%- if s.eyebrow != blank -%}
            <span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>
          {%- endif -%}
          {%- if s.heading != blank -%}
            <h2 class="t-display-md">{{ s.heading }}</h2>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="sorella-notes">
        {% render 'sorella-note-tier', tier: 'top', label: s.label_top, notes: notes_top %}
        {% render 'sorella-note-tier', tier: 'heart', label: s.label_heart, notes: notes_heart %}
        {% render 'sorella-note-tier', tier: 'base', label: s.label_base, notes: notes_base %}
      </div>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .sorella-notes-pyramid__inner { position: relative; z-index: 1; }
{% endstylesheet %}

{% schema %}
{
  "name": "Notes Pyramid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The notes" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How it unfolds" },
    { "type": "header", "content": "Tier labels" },
    { "type": "text", "id": "label_top", "label": "Top notes label", "default": "Top notes" },
    { "type": "text", "id": "label_heart", "label": "Heart notes label", "default": "Heart notes" },
    { "type": "text", "id": "label_base", "label": "Base notes label", "default": "Base notes" },
    { "type": "header", "content": "Atmosphere" },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob", "default": false, "info": "The product page allows one blob — the product info section keeps it by default." },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "slate",
      "options": [
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "rose", "label": "Rose" },
        { "value": "gold-rose", "label": "Gold + Rose" }
      ]
    }
  ],
  "presets": [{ "name": "Notes pyramid" }]
}
{% endschema %}
