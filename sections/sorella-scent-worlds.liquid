{%- liquid
  assign s = section.settings
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="sec__head">
      <div>
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
      </div>
      <div class="carousel__head-right">
        {%- if s.link_label != blank -%}<a class="link-arrow" href="{{ s.link_url | default: '#' }}">{{ s.link_label }}</a>{%- endif -%}
        <div class="carousel__nav">
          <button type="button" class="carousel__arrow" data-carousel-prev aria-label="Previous">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="carousel__arrow" data-carousel-next aria-label="Next">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="carousel worlds-carousel" data-carousel>
      <div class="carousel__track worlds-track" data-carousel-track>
        {%- for block in section.blocks -%}
          <div class="carousel__item" {{ block.shopify_attributes }}>
            {% render 'sorella-scent-tile',
              title: block.settings.title,
              kicker: block.settings.kicker,
              url: block.settings.url,
              scheme: block.settings.scheme,
              image: block.settings.image,
              image_url: block.settings.image_url %}
          </div>
        {%- endfor -%}
      </div>
      <div class="carousel__dots" data-carousel-dots></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scent worlds",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by scent world" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four worlds, one signature." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "worlds", "info": "Used for in-page links (e.g. #worlds)." }
  ],
  "blocks": [
    {
      "type": "world",
      "name": "World",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Gourmand" },
        { "type": "text", "id": "title", "label": "Title", "default": "Dessert Table" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL", "info": "External background image URL. Overrides the image picker above." },
        {
          "type": "select",
          "id": "scheme",
          "label": "Color scheme",
          "default": "1",
          "options": [
            { "value": "1", "label": "1 — Dark" },
            { "value": "2", "label": "2 — Stone" },
            { "value": "3", "label": "3 — Charcoal" },
            { "value": "4", "label": "4 — Light" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scent worlds",
      "blocks": [
        { "type": "world", "settings": { "kicker": "Gourmand", "title": "Dessert Table", "scheme": "1" } },
        { "type": "world", "settings": { "kicker": "Solar · Beachy", "title": "Sahel Summer", "scheme": "2" } },
        { "type": "world", "settings": { "kicker": "Oriental · Evening", "title": "Golden Hour", "scheme": "3" } },
        { "type": "world", "settings": { "kicker": "Musks · Oils", "title": "Second Skin", "scheme": "4" } }
      ]
    }
  ]
}
{% endschema %}
