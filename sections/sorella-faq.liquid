{%- comment -%}
  Sorella — FAQ accordion (audit §3 / §8) — native <details>/<summary>, no JS.
  Reuses the .acc accordion styling from assets/sorella-pdp.css.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="faq">
      <div class="faq__head">
        <div class="faq__intro">
          {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="serif faq__h">{{ s.heading }}</h2>{%- endif -%}
          {%- if s.subheading != blank -%}<p class="muted faq__sub">{{ s.subheading }}</p>{%- endif -%}
          {%- if s.body != blank -%}<div class="faq__body rte">{{ s.body }}</div>{%- endif -%}
        </div>

        {%- if s.support_heading != blank or s.support_text != blank or s.support_button_label != blank or s.tester_note != blank -%}
          <div class="faq__contact">
            {%- if s.support_heading != blank -%}<span class="faq__contact-label">{{ s.support_heading }}</span>{%- endif -%}
            {%- if s.support_button_label != blank -%}
              <a class="faq__contact-link serif" href="{{ s.support_button_url | default: '#' }}">
                {{ s.support_button_label }}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            {%- endif -%}
            {%- if s.support_text != blank -%}<p class="faq__contact-note">{{ s.support_text }}</p>{%- endif -%}
            {%- if s.tester_note != blank -%}
              <p class="faq__tester">
                {%- if s.tester_url != blank -%}<a href="{{ s.tester_url }}">{{ s.tester_note }}</a>{%- else -%}{{ s.tester_note }}{%- endif -%}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      <div class="acc faq__acc">
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank -%}
            <details {{ block.shopify_attributes }}{% if block.settings.open %} open{% endif %}>
              <summary>{{ block.settings.question }}</summary>
              <div class="acc__body rte">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Header column" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Before you buy" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "info": "Italicise your accent word with <em>…</em>.", "default": "Everything you'd ask a <em>sister</em>." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Shipping, longevity, and how to try a scent before you commit." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We keep an honest shop — real delivery times, no dark patterns, and a 5ml tester so nobody buys a bottle on faith alone. If your question isn't here, we're a message away.</p>" },
    { "type": "header", "content": "Support card" },
    { "type": "text", "id": "support_heading", "label": "Support heading", "default": "Still wondering?" },
    { "type": "textarea", "id": "support_text", "label": "Support text", "default": "Message us on Instagram — we answer like a sister, usually the same day." },
    { "type": "text", "id": "support_button_label", "label": "Support button", "default": "Ask @sorella.fragrances" },
    { "type": "url", "id": "support_button_url", "label": "Support button link" },
    { "type": "text", "id": "tester_note", "label": "Tester note", "default": "New to Sorella? Try any scent first for LE 85." },
    { "type": "url", "id": "tester_url", "label": "Tester note link" },
    { "type": "header", "content": "General" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "faq" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does it last?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Our oil-rich blends are built to last from morning into the evening — most customers report all-day wear on skin and days on clothing.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How long does the scent last?", "open": true } },
        { "type": "qa", "settings": { "question": "Can I try a scent before buying the full size?" } },
        { "type": "qa", "settings": { "question": "How fast is shipping?" } },
        { "type": "qa", "settings": { "question": "What is your returns / exchange policy?" } }
      ]
    }
  ]
}
{% endschema %}
