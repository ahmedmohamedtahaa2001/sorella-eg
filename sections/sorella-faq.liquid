{%- comment -%}
  Sorella — FAQ accordion (audit §3 / §8) — native <details>/<summary>, no JS.
  Reuses the .acc accordion styling from assets/sorella-pdp.css.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="faq">
      <div class="faq__head">
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="serif faq__h">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.subheading != blank -%}<p class="muted faq__sub">{{ s.subheading }}</p>{%- endif -%}
      </div>
      <div class="acc faq__acc">
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank -%}
            <details {{ block.shopify_attributes }}{% if block.settings.open %} open{% endif %}>
              <summary>{{ block.settings.question }}</summary>
              <div class="acc__body rte">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Before you buy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Everything about shipping, longevity, and trying a scent first." },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "faq" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does it last?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Our oil-rich blends are built to last from morning into the evening — most customers report all-day wear on skin and days on clothing.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How long does the scent last?", "open": true } },
        { "type": "qa", "settings": { "question": "Can I try a scent before buying the full size?" } },
        { "type": "qa", "settings": { "question": "How fast is shipping?" } },
        { "type": "qa", "settings": { "question": "What is your returns / exchange policy?" } }
      ]
    }
  ]
}
{% endschema %}
