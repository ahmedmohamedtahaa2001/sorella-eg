{%- comment -%}
  sorella-faq — Glass accordion Q&A (Page Templates Report §4.4).
  Shares the sorella-accordion-item snippet with the product details accordion.
  All copy is merchant-editable via section + block settings. Zero hardcoded content.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-faq surface-ink section-pad" data-section-id="{{ section.id }}">
  <div class="container container--read">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <header class="section-head">
        {%- if s.eyebrow != blank -%}<span class="section-head__eyebrow t-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sorella-accordion">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            {% render 'sorella-accordion-item',
              heading: block.settings.question,
              content: block.settings.answer,
              id: forloop.index,
              open: (forloop.first and s.open_first) %}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked" },
    { "type": "checkbox", "id": "open_first", "label": "Open first question by default", "default": false }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "qa",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders are delivered across Egypt in 5–8 business days. Please don't open your parcel until the courier hands it to you.</p>"
          }
        },
        {
          "type": "qa",
          "settings": {
            "question": "How do I get the free 5ml?",
            "answer": "<p>Spend over 1,100 LE in a single order and a free 5ml is added automatically at checkout.</p>"
          }
        },
        {
          "type": "qa",
          "settings": {
            "question": "What's the difference between the oil and the spray?",
            "answer": "<p>The oil (roll-on) is more concentrated and longer-lasting on skin; the spray diffuses more and is easier to layer. Many customers keep both.</p>"
          }
        },
        {
          "type": "qa",
          "settings": {
            "question": "Can I try before buying a full bottle?",
            "answer": "<p>Yes — most scents have a 5ml tester so you can live with the fragrance before committing to 30ml or 50ml.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
