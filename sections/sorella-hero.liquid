{%- comment -%}
  sorella-hero — Glass Hero Card over media + blob field (Art Direction §9, §7.3).
  Signature moment: 2 blobs (gold + slate), hero-scrim, display-hero headline + Gold CTA.
  Renders [data-hero-sentinel] so the nav dock trigger is height-independent.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign align = s.content_align | default: 'start'
-%}
<section class="sorella-hero blob-scene surface-gradient" data-section-id="{{ section.id }}">
  {%- if s.show_blobs -%}
    {% render 'sorella-blob', scheme: s.blob_scheme %}
  {%- endif -%}

  {%- if s.image != blank or s.video_url != blank -%}
    <div class="sorella-hero__media">
      {%- if s.video_url != blank -%}
        <video autoplay muted loop playsinline poster="{{ s.image | image_url: width: 1600 }}">
          <source src="{{ s.video_url }}" type="video/mp4">
        </video>
      {%- else -%}
        {{ s.image | image_url: width: 2000 | image_tag:
          loading: 'eager', fetchpriority: 'high',
          sizes: '100vw', widths: '800, 1200, 1600, 2000',
          alt: s.heading | escape }}
      {%- endif -%}
    </div>
    <span class="sorella-hero__scrim" aria-hidden="true"></span>
  {%- endif -%}

  <div class="container container--bento sorella-hero__container">
    <div class="sorella-hero__card glass-panel glass-panel--xl glass-panel--sheen sorella-hero__card--{{ align }}">
      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h1 class="t-display-hero">{{ s.heading }}</h1>{%- endif -%}
      {%- if s.subheading != blank -%}<p class="t-lead">{{ s.subheading }}</p>{%- endif -%}
      {%- if s.cta_label != blank -%}
        <div class="sorella-hero__actions">
          {% render 'sorella-button', label: s.cta_label, href: s.cta_link, style: 'primary' %}
          {%- if s.cta2_label != blank -%}{% render 'sorella-button', label: s.cta2_label, href: s.cta2_link, style: 'ghost' %}{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <span class="sorella-hero__sentinel" data-hero-sentinel aria-hidden="true"></span>
</section>

{% stylesheet %}
  .sorella-hero {
    position: relative; display: flex; align-items: center;
    min-height: clamp(520px, 82vh, 820px);
    padding-block: calc(var(--nav-top-height) + var(--space-xxl)) var(--space-xxl);
  }
  .sorella-hero__media { position: absolute; inset: 0; z-index: 0; }
  .sorella-hero__media img, .sorella-hero__media video { width: 100%; height: 100%; object-fit: cover; }
  .sorella-hero__scrim { position: absolute; inset: 0; z-index: 0; background: var(--gradient-hero-scrim); }
  .sorella-hero__container { position: relative; z-index: 1; width: 100%; }
  .sorella-hero__card {
    display: flex; flex-direction: column; gap: var(--space-md);
    max-width: 620px; padding: var(--space-xxl);
    color: var(--color-parchment);
  }
  .sorella-hero__card--center { margin-inline: auto; text-align: center; align-items: center; }
  .sorella-hero__card--end { margin-inline-start: auto; }
  .sorella-hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-block-start: var(--space-sm); }
  .sorella-hero__sentinel { position: absolute; inset-block-end: 0; height: 1px; width: 1px; }
  @media (max-width: 640px) {
    .sorella-hero__card { padding: var(--space-xl) var(--space-lg); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Egyptian fragrance house" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From our bond to your senses" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Fragrances crafted by two sisters — made fresh in Egypt." },
    { "type": "text", "id": "cta_label", "label": "Primary button label", "default": "Shop best sellers" },
    { "type": "url", "id": "cta_link", "label": "Primary button link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button label" },
    { "type": "url", "id": "cta2_link", "label": "Secondary button link" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "url", "id": "video_url", "label": "Background video URL (mp4)" },
    { "type": "header", "content": "Atmosphere" },
    { "type": "checkbox", "id": "show_blobs", "label": "Show blob field", "default": true },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colours", "default": "gold-slate",
      "options": [
        { "value": "gold-slate", "label": "Gold + Slate" },
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "gold-rose", "label": "Gold + Rose" }
      ]
    },
    {
      "type": "select", "id": "content_align", "label": "Card alignment", "default": "start",
      "options": [
        { "value": "start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "End" }
      ]
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
