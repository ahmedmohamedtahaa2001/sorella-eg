{%- comment -%}
  sorella-product-accordion — Product details accordion (Page Templates Report §2.2).
  Details / Shipping / Ingredients etc. Shared accordion component with FAQ.
  Blocks: "item" (heading + richtext) and "description" (heading + product.description).
  Open/close JS is wired in theme.js via [data-accordion-trigger]/[data-accordion-content].
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-product-accordion surface-parchment section-pad" data-section-id="{{ section.id }}">
  <div class="container container--read">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow section-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="sorella-accordion">
      {%- for block in section.blocks -%}
        {%- liquid
          assign open = false
          if forloop.first and s.open_first
            assign open = true
          endif
          if block.type == 'description'
            assign item_content = product.description
          else
            assign item_content = block.settings.content
          endif
        -%}
        <div {{ block.shopify_attributes }}>
          {% render 'sorella-accordion-item',
            heading: block.settings.heading,
            content: item_content,
            id: forloop.index,
            open: open %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-product-accordion .section-head { margin-block-end: var(--space-lg); }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Accordion",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Good to know" },
    { "type": "checkbox", "id": "open_first", "label": "Expand first item by default", "default": true }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "description",
      "name": "Product description",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product accordion",
      "blocks": [
        { "type": "description", "settings": { "heading": "Description" } },
        { "type": "item", "settings": { "heading": "Shipping", "content": "<p>Orders ship in 5–8 business days across Egypt. Please don't open your parcel until the courier hands it to you.</p>" } },
        { "type": "item", "settings": { "heading": "How to wear it", "content": "<p>Spray onto pulse points — wrists, neck, behind the ears. Layer with the matching oil for longer wear.</p>" } }
      ]
    }
  ]
}
{% endschema %}
