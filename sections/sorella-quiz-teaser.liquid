{%- comment -%}
  Sorella — Quiz / discovery teaser (homepage). Audit §7.
  Editorial band (surface or accent) · eyebrow + heading + subtext ·
  2–4 tappable answer chips (link to quiz/collection) · primary CTA ·
  skippable note ("or shop bestsellers"). No hard gate, no dark patterns.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign band = s.band | default: 'surface'
-%}
<section class="sec quizteaser quizteaser--{{ band }}"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="quizteaser__inner">
      {%- if s.eyebrow != blank -%}<span class="eyebrow quizteaser__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="quizteaser__heading serif">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.subtext != blank -%}<p class="quizteaser__sub">{{ s.subtext }}</p>{%- endif -%}

      {%- assign chips = section.blocks | where: 'type', 'chip' -%}
      {%- if chips.size > 0 -%}
        <div class="quizteaser__chips">
          {%- for block in chips -%}
            <a class="quizteaser__chip" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
              {%- if block.settings.emoji != blank -%}<span class="quizteaser__chip-emoji" aria-hidden="true">{{ block.settings.emoji }}</span>{%- endif -%}
              <span class="quizteaser__chip-label">{{ block.settings.label | default: 'Answer' }}</span>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="quizteaser__cta">
        {%- if s.button_label != blank -%}
          <a class="btn {% if band == 'accent' %}btn--light{% else %}btn--primary{% endif %}" href="{{ s.button_url | default: routes.all_products_collection_url }}">{{ s.button_label }}</a>
        {%- endif -%}
        {%- if s.skip_label != blank -%}
          <a class="quizteaser__skip" href="{{ s.skip_url | default: '#shop' }}">{{ s.skip_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz teaser",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "band",
      "label": "Background",
      "default": "surface",
      "options": [
        { "value": "surface", "label": "Light card" },
        { "value": "accent", "label": "Black band" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "60-second scent quiz" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your signature scent" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Answer a few quick questions and we'll match you to the scents that feel most like you." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Find your scent" },
    { "type": "url", "id": "button_url", "label": "Primary button link" },
    { "type": "text", "id": "skip_label", "label": "Skip link", "default": "or shop bestsellers" },
    { "type": "url", "id": "skip_url", "label": "Skip link URL" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "quiz" }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Answer chip",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji / icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Fresh & clean" },
        { "type": "url", "id": "url", "label": "Link (quiz step or collection)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Quiz teaser",
      "blocks": [
        { "type": "chip", "settings": { "emoji": "🌊", "label": "Fresh & clean" } },
        { "type": "chip", "settings": { "emoji": "🌸", "label": "Soft florals" } },
        { "type": "chip", "settings": { "emoji": "🍯", "label": "Warm gourmand" } },
        { "type": "chip", "settings": { "emoji": "🌲", "label": "Woody & deep" } }
      ]
    }
  ]
}
{% endschema %}
