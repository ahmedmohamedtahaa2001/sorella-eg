{%- comment -%}
  Sorella — Quiz / discovery teaser (homepage). Audit §7 · voice Part III.
  Editorial two-column band: left invitation rail (eyebrow + serif heading with
  italic accent + sisterly sub + primary CTA + skip) · right 2×2 answer board of
  the four scent worlds, each a tappable tile with index + monoline glyph +
  lived Egyptian moment, linking straight into its world. No hard gate.
  All content + spacing schema-driven. Zero hardcoded values.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign band = s.band | default: 'surface'
  assign tiles = section.blocks | where: 'type', 'chip'
-%}
{%- style -%}
  #shopify-section-{{ section.id }}.sec{
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
    margin-top: {{ s.margin_top }}px;
    margin-bottom: {{ s.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .quizteaser__inner{
    max-width: {{ s.section_max_width }}px;
    gap: {{ s.item_gap }}px;
  }
  @media (max-width: 749px){
    #shopify-section-{{ section.id }}.sec{
      padding-top: {{ s.mobile_padding_top }}px;
      padding-bottom: {{ s.mobile_padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section class="sec quizteaser quizteaser--{{ band }}"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="quizteaser__inner">

      <div class="quizteaser__lead">
        {%- if s.eyebrow != blank -%}<span class="eyebrow quizteaser__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="quizteaser__heading serif">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.subtext != blank -%}<p class="quizteaser__sub">{{ s.subtext }}</p>{%- endif -%}
        <div class="quizteaser__cta">
          {%- if s.button_label != blank -%}
            <a class="btn {% if band == 'accent' %}btn--light{% else %}btn--primary{% endif %} quizteaser__btn" href="{{ s.button_url | default: routes.all_products_collection_url }}">
              {{ s.button_label }}
              <svg class="quizteaser__btn-arrow" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          {%- endif -%}
          {%- if s.skip_label != blank -%}
            <a class="quizteaser__skip" href="{{ s.skip_url | default: '#shop' }}">{{ s.skip_label }}</a>
          {%- endif -%}
        </div>
      </div>

      {%- if tiles.size > 0 -%}
        <ul class="quizteaser__grid" role="list">
          {%- for block in tiles -%}
            {%- liquid
              assign idx = forloop.index | prepend: '0' | slice: -2, 2
              assign tile_url = block.settings.url | default: routes.all_products_collection_url
            -%}
            <li class="quizteaser__grid-item" {{ block.shopify_attributes }}>
              <a class="quizteaser__tile" href="{{ tile_url }}">
                <span class="quizteaser__tile-top">
                  {%- if s.show_index -%}<span class="quizteaser__index" aria-hidden="true">{{ idx }}</span>{%- endif -%}
                  <span class="quizteaser__glyph" aria-hidden="true">
                    {%- case block.settings.glyph -%}
                      {%- when 'baklava' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 9-9 9-9-9z"/><path d="M3 12h18M12 3v18"/></svg>
                      {%- when 'sun' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.4"/><path d="M12 2v2.4M12 19.6V22M2 12h2.4M19.6 12H22M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M19.4 4.6l-1.7 1.7M6.3 17.7l-1.7 1.7"/></svg>
                      {%- when 'moon' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20.5 14.8A8.2 8.2 0 1 1 9.2 3.5 6.6 6.6 0 0 0 20.5 14.8z"/></svg>
                      {%- when 'drop' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.2c3.2 3.6 5.6 6.9 5.6 10.1a5.6 5.6 0 0 1-11.2 0c0-3.2 2.4-6.5 5.6-10.1z"/></svg>
                      {%- else -%}
                        {%- if block.settings.emoji != blank -%}<span class="quizteaser__emoji">{{ block.settings.emoji }}</span>{%- endif -%}
                    {%- endcase -%}
                  </span>
                </span>
                {%- if block.settings.family != blank -%}<span class="quizteaser__family">{{ block.settings.family }}</span>{%- endif -%}
                {%- if block.settings.label != blank -%}<span class="quizteaser__name serif">{{ block.settings.label }}</span>{%- endif -%}
                {%- if block.settings.moment != blank -%}
                  <span class="quizteaser__moment">
                    {{ block.settings.moment }}
                    <svg class="quizteaser__moment-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz teaser",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "select",
      "id": "band",
      "label": "Background",
      "default": "surface",
      "options": [
        { "value": "surface", "label": "Light panel" },
        { "value": "accent", "label": "Black band" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The 60-second scent quiz" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "info": "Italicise your accent word with <em>…</em>.", "default": "Which one already smells like <em>you</em>?" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Four worlds, one signature. Tell us where your day lives and we'll match you to the scents that feel most like home." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Find your scent" },
    { "type": "url", "id": "button_url", "label": "Primary button link" },
    { "type": "text", "id": "skip_label", "label": "Skip link", "default": "or shop bestsellers" },
    { "type": "url", "id": "skip_url", "label": "Skip link URL" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "quiz" },
    { "type": "header", "content": "Answer board" },
    { "type": "checkbox", "id": "show_index", "label": "Show answer numbers (01–04)", "default": true },
    { "type": "header", "content": "Layout & Spacing" },
    { "type": "range", "id": "section_max_width", "label": "Max width", "min": 960, "max": 1440, "step": 20, "unit": "px", "default": 1140 },
    { "type": "range", "id": "item_gap", "label": "Column gap (rail ↔ board)", "min": 24, "max": 96, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "header", "content": "Mobile Spacing" },
    { "type": "range", "id": "mobile_padding_top", "label": "Padding top (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Padding bottom (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Answer — scent world",
      "settings": [
        {
          "type": "select",
          "id": "glyph",
          "label": "Monoline glyph",
          "default": "baklava",
          "options": [
            { "value": "baklava", "label": "Baklava lattice (gourmand)" },
            { "value": "sun", "label": "Sun (solar / beachy)" },
            { "value": "moon", "label": "Crescent (evening)" },
            { "value": "drop", "label": "Drop (musks / oils)" },
            { "value": "none", "label": "None — use emoji below" }
          ]
        },
        { "type": "text", "id": "emoji", "label": "Emoji (fallback if glyph = None)" },
        { "type": "text", "id": "family", "label": "Family kicker", "default": "Gourmand" },
        { "type": "text", "id": "label", "label": "World name", "default": "Dessert Table" },
        { "type": "text", "id": "moment", "label": "Lived moment", "default": "Basbousa, warm from the tray" },
        { "type": "url", "id": "url", "label": "Link (scent-world collection)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Quiz teaser",
      "blocks": [
        { "type": "chip", "settings": { "glyph": "baklava", "family": "Gourmand", "label": "Dessert Table", "moment": "Basbousa, warm from the tray" } },
        { "type": "chip", "settings": { "glyph": "sun", "family": "Solar · Beachy", "label": "Sahel Summer", "moment": "Salt and sun still on your skin" } },
        { "type": "chip", "settings": { "glyph": "moon", "family": "Oriental · Evening", "label": "Golden Hour", "moment": "Oud on the balcony, tea poured late" } },
        { "type": "chip", "settings": { "glyph": "drop", "family": "Musks · Oils", "label": "Second Skin", "moment": "One dab at the wrist before you go" } }
      ]
    }
  ]
}
{% endschema %}
