{%- comment -%}
  sorella-page-header — generic eyebrow + heading header (Page Templates Report §2.2).
  Reused on About, Contact, Policy, FAQ, Search, 404.
  Two modes:
    • image set → cover background with hero-scrim + Parchment text (blob-scene wrapper).
    • no image  → clean section-pad header on chosen surface, optional blob on gradient.
  Zero hardcoded content; heading falls back to page.title then page_title.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign align = s.text_align | default: 'center'
  assign heading = s.heading | default: page.title | default: page_title
  assign has_image = false
  if s.image != blank
    assign has_image = true
  endif
  assign is_gradient = false
  if s.surface == 'surface-gradient'
    assign is_gradient = true
  endif

  assign section_classes = 'sorella-page-header'
  if has_image
    assign section_classes = section_classes | append: ' sorella-page-header--image blob-scene'
  else
    assign section_classes = section_classes | append: ' section-pad ' | append: s.surface
    if is_gradient and s.show_blob
      assign section_classes = section_classes | append: ' blob-scene'
    endif
  endif

  assign head_classes = 'section-head'
  if align == 'center'
    assign head_classes = head_classes | append: ' section-head--center'
  endif
-%}
<section class="{{ section_classes }}" data-section-id="{{ section.id }}">
  {%- if has_image -%}
    <div class="sorella-page-header__media">
      {{ s.image | image_url: width: 2000 | image_tag:
        loading: 'eager', fetchpriority: 'high',
        sizes: '100vw', widths: '800, 1200, 1600, 2000',
        alt: heading | escape }}
    </div>
    <span class="sorella-page-header__scrim" aria-hidden="true"></span>
  {%- elsif is_gradient and s.show_blob -%}
    {% render 'sorella-blob', scheme: s.blob_scheme, single: true %}
    <span class="sorella-page-header__veil" aria-hidden="true"></span>
  {%- endif -%}

  <div class="container container--read sorella-page-header__container">
    <div class="{{ head_classes }}">
      {%- if s.eyebrow != blank -%}
        <span class="t-eyebrow section-head__eyebrow">{{ s.eyebrow }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h1 class="t-display-lg">{{ heading }}</h1>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <div class="t-lead rte sorella-page-header__subheading">{{ s.subheading }}</div>
      {%- endif -%}
      {%- if s.cta_label != blank -%}
        <div class="sorella-page-header__actions">
          {% render 'sorella-button', label: s.cta_label, href: s.cta_link, style: 'primary' %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-page-header { position: relative; }
  .sorella-page-header--image {
    display: flex; align-items: flex-end;
    min-height: 300px;
    padding-block: var(--space-xxl);
    color: var(--color-parchment);
  }
  .sorella-page-header__media { position: absolute; inset: 0; z-index: 0; }
  .sorella-page-header__media img { width: 100%; height: 100%; object-fit: cover; }
  .sorella-page-header__scrim { position: absolute; inset: 0; z-index: 0; background: var(--gradient-hero-scrim); }
  .sorella-page-header__veil {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: radial-gradient(75% 70% at 50% 55%, var(--color-ink-35) 0%, transparent 100%);
  }
  .sorella-page-header__container { position: relative; z-index: 1; width: 100%; }
  .sorella-page-header__subheading { color: inherit; }
  .sorella-page-header__actions { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-block-start: var(--space-sm); }
  .section-head--center .sorella-page-header__actions { justify-content: center; }
{% endstylesheet %}

{% schema %}
{
  "name": "Page Header",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "info": "Leave blank to use the page title." },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },
    {
      "type": "select", "id": "text_align", "label": "Text alignment", "default": "center",
      "options": [
        { "value": "start", "label": "Start" },
        { "value": "center", "label": "Center" }
      ]
    },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_label", "label": "Button label" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Cover image", "info": "Optional. When set, renders as a full-bleed cover with a scrim." },
    { "type": "header", "content": "Appearance" },
    {
      "type": "select", "id": "surface", "label": "Surface", "default": "surface-gradient",
      "info": "Ignored when a cover image is set.",
      "options": [
        { "value": "surface-ink", "label": "Ink" },
        { "value": "surface-parchment", "label": "Parchment" },
        { "value": "surface-gradient", "label": "Gradient" }
      ]
    },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob", "default": false, "info": "Only shown on the Gradient surface without a cover image." },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "gold",
      "options": [
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "rose", "label": "Rose" }
      ]
    }
  ],
  "presets": [{ "name": "Page header" }]
}
{% endschema %}
