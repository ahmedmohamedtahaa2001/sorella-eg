{%- comment -%}
  sorella-cart-drawer — glass side panel (§10). Refreshed via ?section_id on cart change.
  Free-5ml progress, line items, subtotal, upsell slot.
{%- endcomment -%}
{%- liquid
  assign threshold = settings.free_gift_threshold | times: 100
  assign remaining = threshold | minus: cart.total_price
-%}
<aside class="sorella-drawer sorella-drawer--end" id="cart-drawer" data-panel data-scrim="[data-shared-scrim]" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
  <div class="sorella-drawer__panel glass-panel glass-panel--xl">
    <div data-cart-contents>
      <div class="sorella-cart__head">
        <span class="t-title" id="cart-drawer-title">{{ 'cart.general.title' | t }} ({{ cart.item_count }})</span>
        <button class="nav-dock__icon" type="button" data-close aria-label="{{ 'general.accessibility.close' | t }}">
          {% render 'sorella-icon', name: 'close', size: 22 %}
        </button>
      </div>

      {%- if cart.item_count > 0 -%}
        {%- if settings.free_gift_threshold > 0 -%}
          <div class="sorella-cart__progress">
            {%- if remaining > 0 -%}
              {%- assign remaining_money = remaining | money -%}
              <span class="t-caption">{{ 'cart.general.free_gift_progress' | t: amount: remaining_money }}</span>
            {%- else -%}
              <span class="t-body-strong text-gold">{{ 'cart.general.free_gift_unlocked' | t }}</span>
            {%- endif -%}
            <div class="sorella-cart__progress-track">
              {%- assign pct = cart.total_price | times: 100 | divided_by: threshold -%}
              <div class="sorella-cart__progress-fill" style="width: {% if pct > 100 %}100{% else %}{{ pct }}{% endif %}%;"></div>
            </div>
          </div>
        {%- endif -%}

        <div class="sorella-cart__body">
          <ul class="sorella-cart__lines">
            {%- for line in cart.items -%}
              {% render 'sorella-cart-line-item', line: line, index: forloop.index %}
            {%- endfor -%}
          </ul>
        </div>

        {%- if section.settings.upsell_collection != blank -%}
          {%- assign upsell = collections[section.settings.upsell_collection] -%}
          {%- if upsell.products.size > 0 -%}
            <div class="sorella-cart__upsell">
              <p class="t-caption-strong">{{ 'cart.general.upsell_heading' | t }}</p>
              {% render 'sorella-product-card', product: upsell.products.first, variant: 'quick-add' %}
            </div>
          {%- endif -%}
        {%- endif -%}

        <form action="{{ routes.cart_url }}" method="post" class="sorella-cart__foot">
          <div class="sorella-cart__subtotal">
            <span class="t-body-strong">{{ 'cart.general.subtotal' | t }}</span>
            <span class="t-price text-gold">{{ cart.total_price | money }}</span>
          </div>
          <span class="t-caption sorella-cart__legal">{{ 'cart.general.taxes_shipping' | t }}</span>
          <button type="submit" name="checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</button>
        </form>
      {%- else -%}
        <div class="sorella-cart__body">
          {%- assign cart_empty_heading = 'cart.general.empty' | t -%}
          {%- assign cart_empty_cta = 'cart.general.empty_cta' | t -%}
          {% render 'sorella-empty-state',
            heading: cart_empty_heading,
            cta_label: cart_empty_cta,
            cta_url: routes.all_products_collection_url,
            icon: 'bag' %}
        </div>
      {%- endif -%}
    </div>
  </div>
</aside>

{% stylesheet %}
  /* Guaranteed dark under-layer so parchment text never sits on parchment-through-glass (§9.6) */
  .sorella-drawer__panel.glass-panel {
    background-color: var(--color-navy-low);
    background-image: linear-gradient(var(--color-parchment-12), var(--color-parchment-12));
  }
  .sorella-cart__legal { color: var(--color-parchment-65); }
  /* 44px touch targets for line-item controls (hooks also styled in components.css) */
  .sorella-line__hit { display: inline-flex; align-items: center; justify-content: center; min-inline-size: 44px; min-block-size: 44px; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    { "type": "collection", "id": "upsell_collection", "label": "Upsell collection" }
  ]
}
{% endschema %}
