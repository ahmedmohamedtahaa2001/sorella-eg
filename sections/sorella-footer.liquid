{%- liquid
  assign s = section.settings
  assign brand = s.brand_name | default: shop.name
-%}
<footer class="footer">
  <div class="wrap">
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="serif">{{ brand }}</span>
        {%- if s.tagline != blank -%}<p>{{ s.tagline }}</p>{%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="footer__socials">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.url | default: '#' }}" aria-label="{{ block.settings.label }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- for i in (1..3) -%}
        {%- liquid
          assign heading_key = 'col_' | append: i | append: '_heading'
          assign menu_key = 'col_' | append: i | append: '_menu'
          assign heading = section.settings[heading_key]
          assign menu = section.settings[menu_key]
        -%}
        {%- if heading != blank or menu != blank -%}
          <div>
            {%- if heading != blank -%}<h4>{{ heading }}</h4>{%- endif -%}
            {%- if menu != blank and menu.links.size > 0 -%}
              <ul>
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      {%- if s.copyright != blank -%}<span>{{ s.copyright }}</span>{%- endif -%}
      {%- if s.disclaimer != blank -%}<span>{{ s.disclaimer }}</span>{%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand wordmark", "info": "Leave blank to use the store name." },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "From our bond to your senses. Fragrance made fresh in Egypt — true to the original, built to last." },
    { "type": "header", "content": "Column 1" },
    { "type": "text", "id": "col_1_heading", "label": "Heading", "default": "Shop" },
    { "type": "link_list", "id": "col_1_menu", "label": "Menu" },
    { "type": "header", "content": "Column 2" },
    { "type": "text", "id": "col_2_heading", "label": "Heading", "default": "Discover" },
    { "type": "link_list", "id": "col_2_menu", "label": "Menu" },
    { "type": "header", "content": "Column 3" },
    { "type": "text", "id": "col_3_heading", "label": "Heading", "default": "Help" },
    { "type": "link_list", "id": "col_3_menu", "label": "Menu" },
    { "type": "header", "content": "Legal" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Sorella. Made fresh in Egypt." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "Independent fragrance house — not affiliated with any brand mentioned." }
  ],
  "blocks": [
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "IG" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "social", "settings": { "label": "IG" } },
        { "type": "social", "settings": { "label": "TT" } },
        { "type": "social", "settings": { "label": "FB" } }
      ]
    }
  ]
}
{% endschema %}
