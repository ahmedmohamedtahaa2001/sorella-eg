{%- liquid
  assign s = section.settings
  assign brand = s.brand_name | default: shop.name
  assign accent = s.accent_color | default: '#FFFFFF'
  if s.bg_tone == 'charcoal'
    assign bg = '#111111'
  else
    assign bg = 'var(--chrome-bg)'
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .footer {
    --f-bg: {{ bg }};
    --f-white: {{ accent }};
  }
  #shopify-section-{{ section.id }} .footer__grid {
    padding-block: {{ s.padding_top | default: 72 }}px {{ s.padding_bottom | default: 40 }}px;
  }
  #shopify-section-{{ section.id }} .footer__logo {
    height: {{ s.logo_height | default: 60 }}px;
    width: auto;
    display: block;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .footer__grid {
      padding-block: {{ s.mobile_padding_top | default: 56 }}px {{ s.mobile_padding_bottom | default: 32 }}px;
    }
  }
{%- endstyle -%}

<footer class="footer">
  <div class="wrap">
    <div class="footer__grid">

      <div class="footer__brand">
        {%- if s.eyebrow != blank -%}<span class="footer__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.logo != blank -%}
          {{ s.logo | image_url: width: 500 | image_tag: alt: brand, class: 'footer__wordmark footer__logo', widths: '100,200,300,400,500', loading: 'lazy' }}
        {%- else -%}
          <img class="footer__wordmark footer__logo" src="{{ 'sorella-logo-white.png' | asset_url }}" alt="{{ brand | escape }}" width="310" height="537" loading="lazy">
        {%- endif -%}
        {%- if s.tagline != blank -%}<p>{{ s.tagline }}</p>{%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <div class="footer__socials">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.url | default: '#' }}" aria-label="{{ block.settings.label }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- for i in (1..3) -%}
        {%- liquid
          assign heading_key = 'col_' | append: i | append: '_heading'
          assign menu_key = 'col_' | append: i | append: '_menu'
          assign heading = section.settings[heading_key]
          assign menu = section.settings[menu_key]
        -%}
        {%- if heading != blank or menu != blank -%}
          <div class="footer__col">
            {%- if heading != blank -%}<h4>{{ heading }}</h4>{%- endif -%}
            {%- if menu != blank and menu.links.size > 0 -%}
              <ul>
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      {%- if s.copyright != blank -%}<span>{{ s.copyright }}</span>{%- endif -%}
      {%- if s.disclaimer != blank -%}<span>{{ s.disclaimer }}</span>{%- endif -%}
    </div>
  </div>

  {%- if s.show_signature -%}
    <div class="footer__signature" aria-hidden="true">
      <span class="footer__mark serif">{{ brand }}</span>
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand wordmark", "info": "Used as the logo alt text. Leave blank to use the store name." },
    { "type": "image_picker", "id": "logo", "label": "Logo image", "info": "Optional. Defaults to the built-in white Sorella wordmark, sized for the dark footer. Upload a light/white version for best contrast." },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 24, "max": 140, "step": 4, "unit": "px", "default": 60 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow line", "default": "Made fresh in Egypt" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "From our bond to your senses. Fragrance made fresh in Egypt — true to the original, built to last." },
    { "type": "header", "content": "Column 1" },
    { "type": "text", "id": "col_1_heading", "label": "Heading", "default": "Shop" },
    { "type": "link_list", "id": "col_1_menu", "label": "Menu" },
    { "type": "header", "content": "Column 2" },
    { "type": "text", "id": "col_2_heading", "label": "Heading", "default": "Discover" },
    { "type": "link_list", "id": "col_2_menu", "label": "Menu" },
    { "type": "header", "content": "Column 3" },
    { "type": "text", "id": "col_3_heading", "label": "Heading", "default": "Help" },
    { "type": "link_list", "id": "col_3_menu", "label": "Menu" },
    { "type": "header", "content": "Legal" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Sorella. Made fresh in Egypt." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "Independent fragrance house — not affiliated with any brand mentioned." },
    { "type": "header", "content": "Appearance" },
    {
      "type": "select",
      "id": "bg_tone",
      "label": "Background tone",
      "options": [
        { "value": "black", "label": "Absolute black" },
        { "value": "charcoal", "label": "Rich charcoal" }
      ],
      "default": "black"
    },
    { "type": "color", "id": "accent_color", "label": "Accent (hover / focus)", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "show_signature", "label": "Show oversized wordmark signature", "default": true },
    { "type": "header", "content": "Layout & Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top (desktop)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (desktop)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "mobile_padding_top", "label": "Padding top (mobile)", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Padding bottom (mobile)", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 32 }
  ],
  "blocks": [
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "IG" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "social", "settings": { "label": "IG" } },
        { "type": "social", "settings": { "label": "TT" } },
        { "type": "social", "settings": { "label": "FB" } }
      ]
    }
  ]
}
{% endschema %}
