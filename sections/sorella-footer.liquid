{%- comment -%} sorella-footer — dense IA area, no glass/blob (§4.3) {%- endcomment -%}
<footer class="sorella-footer" role="contentinfo">
  <div class="container container--lock">
    <div class="sorella-footer__grid">
      <div class="sorella-footer__brand">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 320 }}" width="{{ settings.logo_width }}" alt="{{ shop.name | escape }}" style="width: {{ settings.logo_width }}px; height: auto;">
        {%- else -%}
          <span class="t-title">{{ settings.brand_name | default: shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}<p class="t-body-sm text-mist">{{ section.settings.tagline }}</p>{%- endif -%}
        {% render 'sorella-social-links' %}
        {%- if section.settings.show_newsletter -%}
          <div class="sorella-footer__newsletter">
            <p class="t-caption-strong">{{ section.settings.newsletter_heading }}</p>
            {% render 'sorella-newsletter-form', layout: 'inline' %}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div class="sorella-footer__col" {{ block.shopify_attributes }}>
            <p class="sorella-footer__col-title t-eyebrow">{{ block.settings.heading }}</p>
            <ul class="sorella-footer__links t-body-sm">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="sorella-footer__bottom">
      <span class="t-fine-print text-mist">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_extra }}</span>
      <span class="t-fine-print text-mist">{{ powered_by_link }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "From our bond to your senses." },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Join our list for offers & new drops" },
    { "type": "text", "id": "copyright_extra", "label": "Copyright note", "default": "Made fresh in Egypt." }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Shop" } },
        { "type": "menu_column", "settings": { "heading": "Help" } },
        { "type": "menu_column", "settings": { "heading": "About" } }
      ]
    }
  ],
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
