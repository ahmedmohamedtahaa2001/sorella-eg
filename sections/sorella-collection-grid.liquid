{%- comment -%}
  sorella-collection-grid — uniform catalog grid, solid cards, no blur/blob (§5.2).
  Used on Collection AND Search. Empty-state when 0 products.
  NOTE: Shopify can only paginate source drops directly (collection.products /
  search.results) — never a reassigned variable — so the paginate tag is branched
  per template. The thin inner block is duplicated on purpose (correctness > DRY).
{%- endcomment -%}
{%- liquid
  assign per_page = section.settings.per_page | default: 24
-%}
<section class="sorella-collection surface-ink section-pad-b" data-section-id="{{ section.id }}">
  <div class="container container--catalog">
    {%- if template.name == 'search' -%}
      {%- paginate search.results by per_page -%}
        {%- if search.results_count > 0 -%}
          <div class="catalog-grid">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'sorella-product-card', product: item %}
              {%- endif -%}
            {%- endfor -%}
          </div>
          {% render 'sorella-pagination', paginate: paginate %}
        {%- else -%}
          {% render 'sorella-empty-state',
            heading: section.settings.search_empty_heading,
            text: section.settings.search_empty_text,
            cta_label: section.settings.empty_cta,
            cta_url: routes.all_products_collection_url,
            icon: 'droplet' %}
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      {%- paginate collection.products by per_page -%}
        {%- if collection.products.size > 0 -%}
          <div class="catalog-grid">
            {%- for product in collection.products -%}
              {% render 'sorella-product-card', product: product %}
            {%- endfor -%}
          </div>
          {% render 'sorella-pagination', paginate: paginate %}
        {%- else -%}
          {% render 'sorella-empty-state',
            heading: section.settings.empty_heading,
            text: section.settings.empty_text,
            cta_label: section.settings.empty_cta,
            cta_url: routes.all_products_collection_url,
            icon: 'droplet' %}
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "range", "id": "per_page", "min": 8, "max": 48, "step": 4, "label": "Products per page", "default": 24 },
    { "type": "header", "content": "Empty collection" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Nothing here yet." },
    { "type": "text", "id": "empty_text", "label": "Empty text", "default": "This collection is being restocked — explore the full range in the meantime." },
    { "type": "header", "content": "No search results" },
    { "type": "text", "id": "search_empty_heading", "label": "No-results heading", "default": "No matches found." },
    { "type": "text", "id": "search_empty_text", "label": "No-results text", "default": "Try another scent name, note, or category — or browse the full range." },
    { "type": "text", "id": "empty_cta", "label": "Empty button label", "default": "Shop all fragrances" }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
