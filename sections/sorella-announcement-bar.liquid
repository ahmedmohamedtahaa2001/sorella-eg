{%- comment -%}
  sorella-announcement-bar — top strip, schema-driven copy.
  Publishes its height into --announcement-height so the fixed nav dock
  (chrome.css) can sit below it while the page is at the top.
{%- endcomment -%}
{%- if section.settings.enabled and section.settings.message != blank -%}
  <style>:root { --announcement-height: 40px; }</style>
  <div class="sorella-announcement" style="--announcement-bg: {{ section.settings.bg_color }}; --announcement-fg: {{ section.settings.text_color }};">
    {%- if section.settings.link != blank -%}<a class="sorella-announcement__link" href="{{ section.settings.link }}">{%- endif -%}
      <span class="sorella-announcement__text t-caption">{{ section.settings.message }}</span>
    {%- if section.settings.link != blank -%}{% render 'sorella-icon', name: 'arrow-right', size: 14 %}</a>{%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .sorella-announcement {
    display: flex; align-items: center; justify-content: center; gap: var(--space-xs);
    height: var(--announcement-height, 40px);
    padding-inline: var(--space-md); text-align: center;
    background: var(--announcement-bg, var(--color-navy));
    color: var(--announcement-fg, var(--color-parchment));
  }
  .sorella-announcement__text {
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sorella-announcement__link {
    display: inline-flex; align-items: center; gap: var(--space-xs); min-width: 0;
  }
  .sorella-announcement__link:hover { color: var(--color-gold); }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "message", "label": "Message", "default": "Get a free 5ml perfume for orders over 1,100 LE." },
    { "type": "url", "id": "link", "label": "Link (optional)" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a1420" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F2EEE7" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
