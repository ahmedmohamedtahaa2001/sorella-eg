{%- comment -%}
  sorella-announcement-bar — top strip, schema-driven, monochrome.
  Publishes its height into --announcement-height so the fixed nav dock
  (chrome.css) sits below it while the page is at the top.

  Variants:
    Style   — solid-dark (default) · solid-light · accent (white) · bordered
    Display — static · rotate (auto-cycles message blocks) · marquee (scrolls)
  Messages come from "Message" blocks (add several to rotate); the single
  Message setting is the fallback when no blocks exist. Brand voice: one beat —
  offer + warmth, seasonal-honest (no out-of-season promo).
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign msg_blocks = section.blocks | where: 'type', 'message'
  assign has_blocks = false
  if msg_blocks.size > 0
    assign has_blocks = true
  endif
  unless s.enabled
    assign hide = true
  endunless
-%}
{%- unless hide -%}
  {%- if has_blocks or s.message != blank -%}
    <style>:root { --announcement-height: {{ s.height | default: 40 }}px; }</style>
    <div
      class="sorella-announcement sorella-announcement--{{ s.style }} sorella-announcement--{{ s.display }}"
      data-announcement
      {% if s.display == 'rotate' %}data-rotate="{{ s.rotate_interval | default: 5 }}"{% endif %}
      role="region"
      aria-label="{{ 'general.accessibility.announcement' | t }}">
      <div class="sorella-announcement__track">
        {%- if has_blocks -%}
          {%- for block in msg_blocks -%}
            <div class="sorella-announcement__slide" {{ block.shopify_attributes }} {% if s.display == 'rotate' and forloop.first == false %}hidden{% endif %}>
              {%- if block.settings.link != blank -%}<a class="sorella-announcement__link" href="{{ block.settings.link }}">{%- endif -%}
                {%- if block.settings.icon != 'none' -%}{% render 'sorella-icon', name: block.settings.icon, size: 14 %}{%- endif -%}
                <span class="sorella-announcement__text t-caption">{{ block.settings.message }}</span>
                {%- if block.settings.link != blank -%}{% render 'sorella-icon', name: 'arrow-right', size: 14 %}{%- endif -%}
              {%- if block.settings.link != blank -%}</a>{%- endif -%}
            </div>
          {%- endfor -%}
          {%- comment -%} marquee duplicates the run for a seamless loop {%- endcomment -%}
          {%- if s.display == 'marquee' -%}
            {%- for block in msg_blocks -%}
              <div class="sorella-announcement__slide" aria-hidden="true">
                {%- if block.settings.icon != 'none' -%}{% render 'sorella-icon', name: block.settings.icon, size: 14 %}{%- endif -%}
                <span class="sorella-announcement__text t-caption">{{ block.settings.message }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- else -%}
          <div class="sorella-announcement__slide">
            {%- if s.link != blank -%}<a class="sorella-announcement__link" href="{{ s.link }}">{%- endif -%}
              <span class="sorella-announcement__text t-caption">{{ s.message }}</span>
              {%- if s.link != blank -%}{% render 'sorella-icon', name: 'arrow-right', size: 14 %}{%- endif -%}
            {%- if s.link != blank -%}</a>{%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
    {%- if s.display == 'rotate' and has_blocks and msg_blocks.size > 1 -%}
      <script>
        (function () {
          var bar = document.currentScript.previousElementSibling;
          while (bar && !bar.hasAttribute('data-rotate')) { bar = bar.previousElementSibling; }
          if (!bar) return;
          var slides = bar.querySelectorAll('.sorella-announcement__slide');
          if (slides.length < 2) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          var i = 0, ms = (parseInt(bar.getAttribute('data-rotate'), 10) || 5) * 1000;
          setInterval(function () {
            slides[i].hidden = true;
            i = (i + 1) % slides.length;
            slides[i].hidden = false;
          }, ms);
        })();
      </script>
    {%- endif -%}
  {%- endif -%}
{%- endunless -%}

{% stylesheet %}
  .sorella-announcement {
    height: var(--announcement-height, 40px);
    padding-inline: var(--space-md);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    background: var(--announcement-bg, var(--color-navy));
    color: var(--announcement-fg, var(--color-parchment));
    border-block-end: 1px solid transparent;
  }
  /* Style variants */
  .sorella-announcement--solid-dark  { --announcement-bg: var(--color-navy);      --announcement-fg: var(--color-parchment); }
  .sorella-announcement--solid-light { --announcement-bg: var(--color-ivory);     --announcement-fg: var(--color-ink); }
  .sorella-announcement--accent      { --announcement-bg: var(--color-gold);      --announcement-fg: var(--color-ink); }
  .sorella-announcement--bordered    { --announcement-bg: transparent;            --announcement-fg: var(--color-parchment); border-block-end-color: var(--color-mist-25); }

  .sorella-announcement__track { display: flex; align-items: center; gap: var(--space-xxl); min-width: 0; }
  .sorella-announcement__slide { display: inline-flex; align-items: center; gap: var(--space-xs); min-width: 0; }
  .sorella-announcement__slide[hidden] { display: none; }
  .sorella-announcement__text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sorella-announcement__link { display: inline-flex; align-items: center; gap: var(--space-xs); min-width: 0; }
  .sorella-announcement__link:hover { color: var(--color-gold); text-decoration: underline; text-underline-offset: 3px; }
  .sorella-announcement .sorella-icon { flex: none; opacity: 0.85; }

  /* static — center a single line */
  .sorella-announcement--static .sorella-announcement__track { justify-content: center; }

  /* marquee — continuous scroll of duplicated run */
  .sorella-announcement--marquee { justify-content: flex-start; }
  .sorella-announcement--marquee .sorella-announcement__track { flex-wrap: nowrap; will-change: transform; }
  @media (prefers-reduced-motion: no-preference) {
    .sorella-announcement--marquee .sorella-announcement__track { animation: sorella-marquee 28s linear infinite; }
  }
  @keyframes sorella-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show announcement bar", "default": true },
    { "type": "select", "id": "style", "label": "Style", "default": "solid-dark", "options": [
      { "value": "solid-dark", "label": "Solid dark (Absolute Black)" },
      { "value": "solid-light", "label": "Solid light (Ivory)" },
      { "value": "accent", "label": "Accent (Pure White)" },
      { "value": "bordered", "label": "Transparent + hairline" }
    ] },
    { "type": "select", "id": "display", "label": "Display", "default": "static", "options": [
      { "value": "static", "label": "Static (single line)" },
      { "value": "rotate", "label": "Rotate messages" },
      { "value": "marquee", "label": "Marquee (scroll)" }
    ] },
    { "type": "range", "id": "rotate_interval", "label": "Rotate every", "min": 3, "max": 10, "step": 1, "unit": "s", "default": 5 },
    { "type": "range", "id": "height", "label": "Bar height", "min": 32, "max": 64, "step": 2, "unit": "px", "default": 40 },
    { "type": "header", "content": "Fallback message" },
    { "type": "text", "id": "message", "label": "Message (used when no Message blocks are added)", "default": "Free 5ml perfume on orders over LE 1,100 — pick it in your cart." },
    { "type": "url", "id": "link", "label": "Link (optional)" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "message", "label": "Message", "default": "Made fresh in Egypt · ships in 2–4 days" },
        { "type": "url", "id": "link", "label": "Link (optional)" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "none", "options": [
          { "value": "none", "label": "None" },
          { "value": "gift", "label": "Gift" },
          { "value": "truck", "label": "Truck" },
          { "value": "sparkle", "label": "Sparkle" },
          { "value": "leaf", "label": "Leaf" },
          { "value": "shield", "label": "Shield" }
        ] }
      ]
    }
  ],
  "max_blocks": 5,
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
