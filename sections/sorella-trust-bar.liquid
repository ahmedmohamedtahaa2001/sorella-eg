{%- comment -%}
  sorella-trust-bar — trio of trust/stat cells (§9). Ink surface by default.
  Cells rendered via sorella-trust-cell snippet; glass toggled per section.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-trust-bar surface-ink section-pad" data-section-id="{{ section.id }}">
  <div class="container container--lock">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head section-head--center">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow section-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="sorella-trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="sorella-trust-bar__item" {{ block.shopify_attributes }}>
          {% render 'sorella-trust-cell', icon: block.settings.icon, heading: block.settings.heading, text: block.settings.text, glass: s.use_glass %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }
  @media (max-width: 735px) {
    .sorella-trust-bar__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "checkbox", "id": "use_glass", "label": "Use glass cells", "default": false }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Cell",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "gift",
          "options": [
            { "value": "gift", "label": "Gift" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "heart", "label": "Heart" },
            { "value": "mail", "label": "Mail" }
          ]
        },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Trust claim" },
        { "type": "text", "id": "text", "label": "Text", "default": "Short supporting detail." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "cell", "settings": { "icon": "gift", "heading": "Free 5ml gift", "text": "On every order over 1,100 LE." } },
        { "type": "cell", "settings": { "icon": "leaf", "heading": "Made fresh in Egypt", "text": "Small-batch, crafted by two sisters." } },
        { "type": "cell", "settings": { "icon": "truck", "heading": "Fast local shipping", "text": "Delivered across Egypt in 5–8 days." } }
      ]
    }
  ]
}
{% endschema %}
