{%- comment -%}
  sorella-essences — equal-thirds "Explore Our Essences" grid (reference §Essences).
  Replaces the old fake 3×(1x1) bento row (which filled only 9/12 columns).
  Card anatomy per reference: top ~2/3 image region, bottom text panel
  (Fraunces headline + description + gold CTA row with arrow).
  All copy/images from settings or the linked collection — nothing hardcoded.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-essences surface-ink" data-section-id="{{ section.id }}">
  <div class="container container--bento section-pad">
    {%- if s.eyebrow != blank or s.heading != blank -%}
      <div class="section-head section-head--center">
        {%- if s.eyebrow != blank -%}<span class="t-eyebrow t-eyebrow--wide section-head__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="t-display-md">{{ s.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="sorella-essences__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign b = block.settings
          assign coll = collections[b.collection]
          assign card_link = b.link | default: coll.url | default: routes.all_products_collection_url
          assign card_heading = b.heading | default: coll.title
          assign card_image = b.image | default: coll.featured_image
          assign ph = 'collection-' | append: forloop.index
        -%}
        <a class="glass-panel sorella-essence" href="{{ card_link }}" {{ block.shopify_attributes }}>
          <div class="sorella-essence__media">
            {%- if card_image != blank -%}
              {{ card_image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                sizes: '(max-width: 833px) 100vw, 33vw',
                widths: '400, 600, 900, 1200',
                alt: card_heading | default: card_image.alt | escape }}
            {%- else -%}
              {{ ph | placeholder_svg_tag: 'media__placeholder' }}
            {%- endif -%}
            <span class="sorella-essence__overlay" aria-hidden="true"></span>
          </div>
          <div class="sorella-essence__panel">
            {%- if card_heading != blank -%}
              <h3 class="t-headline sorella-essence__heading">{{ card_heading }}</h3>
            {%- endif -%}
            {%- if b.text != blank -%}
              <p class="t-body-sm text-mist sorella-essence__text">{{ b.text }}</p>
            {%- endif -%}
            {%- if b.cta_label != blank -%}
              <span class="t-eyebrow text-gold sorella-essence__cta">
                {{ b.cta_label }}
                {% render 'sorella-icon', name: 'arrow-right', size: 15 %}
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-essences__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 834px) {
    .sorella-essences__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xl);
    }
  }

  .sorella-essence {
    display: flex;
    flex-direction: column;
    min-height: 450px;
    overflow: hidden;
    color: var(--color-parchment);
    transition: border-color var(--dur-hover) var(--ease-out);
  }
  .sorella-essence:hover { border-color: var(--color-gold-40); }

  .sorella-essence__media {
    position: relative;
    overflow: hidden;
    flex: 2 1 0;
    min-height: 260px;
    background: var(--color-slate);
  }
  .sorella-essence__media img,
  .sorella-essence__media .media__placeholder {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  .sorella-essence__overlay {
    position: absolute; inset: 0;
    background: color-mix(in srgb, var(--color-ink) 20%, transparent);
    pointer-events: none;
  }

  .sorella-essence__panel {
    flex: 1 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-xl);
  }
  .sorella-essence__text { margin: 0; }

  .sorella-essence__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    margin-block-start: auto;
    padding-block-start: var(--space-sm);
  }
  .sorella-essence:hover .sorella-essence__cta { gap: var(--space-md); }

  @media (prefers-reduced-motion: no-preference) {
    .sorella-essence__media img { transition: transform 1000ms var(--ease-out); }
    .sorella-essence:hover .sorella-essence__media img { transform: scale(1.10); }
    .sorella-essence__cta { transition: gap 250ms var(--ease-out); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Essences",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore Our Essences" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Overrides the collection featured image." },
        { "type": "text", "id": "heading", "label": "Heading", "info": "Overrides the collection title." },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Discover" },
        { "type": "url", "id": "link", "label": "Link", "info": "Overrides the collection link." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Essences",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Essence for Her",
            "text": "Delicate florals and ancient resins crafted for the feminine spirit.",
            "cta_label": "Shop Her Ritual"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Spirit for Him",
            "text": "Bold woods and desert spices for the modern explorer.",
            "cta_label": "Shop His Ritual"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "The Unisex Ritual",
            "text": "Transcendent blends that defy boundaries and celebrate the soul.",
            "cta_label": "Shop All"
          }
        }
      ]
    }
  ]
}
{% endschema %}
