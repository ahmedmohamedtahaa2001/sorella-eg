{%- liquid
  assign s = section.settings
  assign p = s.product
  assign variant = p.selected_or_first_available_variant
  assign name = p.title | default: s.name_fallback
-%}
<section class="sec sec--tight">
  <div class="wrap">
    <div class="spot">
      <div class="spot__media" data-gallery>
        <div class="spot__main" data-gallery-main>
          {%- if p != blank and p.featured_image != blank -%}
            {{ p.featured_image | image_url: width: 700 | image_tag: class: 'spot__img', loading: 'lazy', sizes: '(max-width: 820px) 100vw, 48vw', widths: '360, 540, 700, 900' }}
          {%- else -%}
            <div class="b"></div>
          {%- endif -%}
        </div>
        {%- comment -%} Only show the thumb strip for a real multi-image gallery — a lone thumb over a single hero is clutter. {%- endcomment -%}
        {%- if p != blank and p.images.size > 1 -%}
          <div class="spot__thumbs">
            {%- for image in p.images limit: 4 -%}
              <button type="button" class="spot__thumb{% if forloop.first %} on{% endif %}" data-gallery-thumb data-full="{{ image | image_url: width: 900 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | default: name | escape }}" width="46" height="56" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- elsif p == blank -%}
          <div class="spot__thumbs"><i></i><i></i><i></i></div>
        {%- endif -%}
      </div>

      <div class="spot__info">
        <div class="spot__head">
          {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
          <h3 class="spot__name">{{ name }}</h3>
        </div>
        {%- if s.rating != blank -%}
          <div class="stars">★★★★★ <span class="n">{{ s.rating }}{% if s.reviews_text != blank %} · {{ s.reviews_text }}{% endif %}</span></div>
        {%- endif -%}

        <div class="spot__pr">
          {%- if p != blank -%}
            <span class="now">{{ p.price | money }}</span>
          {%- elsif s.price_fallback != blank -%}
            <span class="now">{{ s.price_fallback }}</span>
          {%- endif -%}
          {%- if s.anchor_text != blank -%}<span class="anchor">{{ s.anchor_text }}</span>{%- endif -%}
        </div>

        {%- if s.note_top != blank or s.note_heart != blank or s.note_base != blank -%}
          <div class="notes">
            {%- if s.note_top != blank -%}<div class="note"><k>Top</k><p>{{ s.note_top }}</p></div>{%- endif -%}
            {%- if s.note_heart != blank -%}<div class="note"><k>Heart</k><p>{{ s.note_heart }}</p></div>{%- endif -%}
            {%- if s.note_base != blank -%}<div class="note"><k>Base</k><p>{{ s.note_base }}</p></div>{%- endif -%}
          </div>
        {%- endif -%}

        {%- capture spot_buybox -%}
          {%- if section.blocks.size > 0 -%}
            <div class="sizes" data-sizes>
              {%- for block in section.blocks -%}
                <button type="button" class="size{% if block.settings.selected %} on{% endif %}" data-size {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if variant != blank -%}<input type="hidden" name="id" value="{{ variant.id }}">{%- endif -%}
          <div class="buyrow">
            <div class="qty" data-qty>
              <button type="button" data-qty-step="-1" aria-label="Decrease">−</button>
              <input class="qty__in" data-qty-input type="number" name="quantity" value="1" min="1" inputmode="numeric" aria-label="Quantity">
              <button type="button" data-qty-step="1" aria-label="Increase">+</button>
            </div>
            <button class="btn btn--primary btn--full" type="submit"{% if p != blank and variant.available == false %} disabled{% endif %}>
              {%- if p != blank and variant.available == false -%}
                Sold out
              {%- else -%}
                {{ s.add_label }}{% if p != blank %} — {{ p.price | money }}{% endif %}
              {%- endif -%}
            </button>
          </div>
        {%- endcapture -%}
        {%- if p != blank -%}
          {%- form 'product', p -%}{{ spot_buybox }}{%- endform -%}
        {%- else -%}
          <div class="spot__buybox-preview">{{ spot_buybox }}</div>
        {%- endif -%}

        {%- if s.tester_text != blank -%}
          <div class="tester-line"><span>{{ s.tester_text }}</span>{% if s.tester_price != blank %}<b>{{ s.tester_price }}</b>{% endif %}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .spot__img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  #shopify-section-{{ section.id }} .spot__thumb{ width:46px; height:56px; padding:0; border-radius:8px; overflow:hidden; cursor:pointer; background:var(--surface); border:1px solid var(--line); box-shadow:var(--shadow-sm); transition:outline-color .2s; }
  #shopify-section-{{ section.id }} .spot__thumb.on{ outline:2px solid var(--accent); outline-offset:1px; }
  #shopify-section-{{ section.id }} .spot__thumb img{ display:block; width:100%; height:100%; object-fit:cover; }
  #shopify-section-{{ section.id }} .qty__in{ width:40px; height:52px; text-align:center; font-weight:600; border:0; background:none; font:inherit; color:var(--ink); -moz-appearance:textfield; }
  #shopify-section-{{ section.id }} .qty__in::-webkit-outer-spin-button,
  #shopify-section-{{ section.id }} .qty__in::-webkit-inner-spin-button{ -webkit-appearance:none; margin:0; }
</style>

{% schema %}
{
  "name": "Product spotlight",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Featured product" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "This week's spotlight" },
    { "type": "text", "id": "name_fallback", "label": "Name (no product)", "default": "Bordeaux" },
    { "type": "text", "id": "price_fallback", "label": "Price (no product)", "default": "LE 850" },
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "reviews_text", "label": "Reviews label", "default": "1,288 reviews" },
    { "type": "text", "id": "anchor_text", "label": "Price anchor", "default": "Performs like bottles at four times the price" },
    { "type": "header", "content": "Notes pyramid" },
    { "type": "text", "id": "note_top", "label": "Top", "default": "Saffron, bitter almond" },
    { "type": "text", "id": "note_heart", "label": "Heart", "default": "Egyptian jasmine, cedar" },
    { "type": "text", "id": "note_base", "label": "Base", "default": "Amberwood, fir resin, oud" },
    { "type": "header", "content": "Buy box" },
    { "type": "text", "id": "add_label", "label": "Add button", "default": "Add to bag" },
    { "type": "inline_richtext", "id": "tester_text", "label": "Tester line", "default": "Not sure yet? <b>Try it first — add the 5ml tester</b>" },
    { "type": "text", "id": "tester_price", "label": "Tester price", "default": "LE 85" }
  ],
  "blocks": [
    {
      "type": "size",
      "name": "Size option",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "50ml · LE 850" },
        { "type": "checkbox", "id": "selected", "label": "Selected by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product spotlight",
      "blocks": [
        { "type": "size", "settings": { "label": "5ml · LE 85", "selected": false } },
        { "type": "size", "settings": { "label": "50ml · LE 850", "selected": true } },
        { "type": "size", "settings": { "label": "Bundle · LE 2,200", "selected": false } }
      ]
    }
  ]
}
{% endschema %}
