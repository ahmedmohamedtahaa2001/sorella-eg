{%- comment -%}
  sorella-product-info — main PDP section (Full Redesign Report §5.3).
  2-col: gallery (left) + glass price/variant/add-to-cart card (right) over one blob (§7.3).
  Variant + add-to-cart hooks wired to theme.js.
{%- endcomment -%}
{%- liquid
  assign product = section.settings.product | default: product
  assign current_variant = product.selected_or_first_available_variant
  assign inspired = product.metafields.sorella.inspired_by
-%}
<section class="sorella-pdp blob-scene surface-gradient" data-section-id="{{ section.id }}">
  {%- if section.settings.show_blob -%}
    {% render 'sorella-blob', single: true, scheme: section.settings.blob_scheme %}
  {%- endif -%}

  <div class="container container--catalog sorella-pdp__grid">
    <div class="sorella-pdp__media">
      {% render 'sorella-product-gallery', product: product %}
    </div>

    <div class="sorella-pdp__info glass-panel glass-panel--xl">
      {%- if section.settings.show_vendor and product.vendor != blank -%}
        <span class="t-eyebrow text-gold">{{ product.vendor }}</span>
      {%- endif -%}

      <h1 class="sorella-pdp__title t-display-md">{{ product.title }}</h1>

      {%- if inspired != blank -%}
        {% render 'sorella-inspired-by-tag', name: inspired %}
      {%- endif -%}

      <div class="sorella-pdp__price" data-variant-price>
        {% render 'sorella-price', variant: current_variant, product: product, context: 'pdp', on_dark: true %}
      </div>
      {%- comment -%}
        Variant-id → fully-rendered price HTML map, consumed by theme.js on variant
        change so .t-price styling and compare-at strikethrough survive swaps.
      {%- endcomment -%}
      <script type="application/json" data-variant-price-map>
        {
          {%- for v in product.variants -%}
            {%- capture variant_price_html -%}{% render 'sorella-price', variant: v, product: product, context: 'pdp', on_dark: true %}{%- endcapture -%}
            {%- assign variant_id_key = v.id | append: '' -%}
            {{ variant_id_key | json }}: {{ variant_price_html | strip | json }}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        }
      </script>

      {%- if product.metafields.sorella.rating -%}
        {% render 'sorella-star-rating', value: product.metafields.sorella.rating, count: product.metafields.sorella.rating_count %}
      {%- endif -%}

      {%- if product.description != blank and section.settings.show_short_desc -%}
        <div class="sorella-pdp__desc rte t-body">{{ product.description | strip_html | truncatewords: 40 }}</div>
      {%- endif -%}

      {%- form 'product', product, class: 'sorella-pdp__form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

        {% render 'sorella-variant-selector', product: product %}

        <div class="sorella-pdp__buy">
          {% render 'sorella-quantity-selector', id: 'pdp-qty' %}
          <button type="submit" name="add" class="btn btn--primary btn--full"
            data-label-add="{{ 'products.product.add_to_bag' | t }}"
            data-label-sold="{{ 'products.product.sold_out' | t }}"
            {% unless current_variant.available %}aria-disabled="true"{% endunless %}>
            <span data-btn-label>
              {%- if current_variant.available -%}{{ 'products.product.add_to_bag' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
            </span>
          </button>
        </div>
      {%- endform -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="sorella-pdp__trust">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust' -%}
              <li class="sorella-pdp__trust-item" {{ block.shopify_attributes }}>
                {% render 'sorella-icon', name: block.settings.icon, size: 18 %}
                <span class="t-body-sm">{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sorella-pdp { position: relative; padding-block: calc(var(--nav-height-scrolled) + var(--space-xxl)) var(--space-section); }
  .sorella-pdp__grid { position: relative; z-index: 1; display: grid; grid-template-columns: 55fr 45fr; gap: var(--space-xxl); align-items: start; }
  .sorella-pdp__info { display: flex; flex-direction: column; gap: var(--space-md); padding: var(--space-xxl); position: sticky; top: calc(var(--nav-height-scrolled) + var(--space-lg)); color: var(--color-parchment); }
  .sorella-pdp__buy { display: flex; gap: var(--space-sm); align-items: stretch; }
  .sorella-pdp__buy .btn { flex: 1; }
  .sorella-pdp__trust { display: flex; flex-direction: column; gap: var(--space-xs); margin-block-start: var(--space-sm); padding-block-start: var(--space-md); border-block-start: var(--border-hairline); }
  .sorella-pdp__trust-item { display: flex; align-items: center; gap: var(--space-xs); color: var(--color-mist); }
  .sorella-pdp__trust-item .sorella-icon { color: var(--color-gold); flex: none; }

  /* Gallery */
  .sorella-gallery { display: flex; flex-direction: column; gap: var(--space-md); }
  .sorella-gallery__main { border-radius: var(--radius-lg); box-shadow: var(--shadow-product); }
  .sorella-gallery__thumbs { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
  .sorella-gallery__thumb { width: 72px; border-radius: var(--radius-sm); border: 1px solid transparent; cursor: pointer; overflow: hidden; }
  .sorella-gallery__thumb.is-active { border-color: var(--color-gold); }

  @media (max-width: 990px) {
    .sorella-pdp__grid { grid-template-columns: 1fr; gap: var(--space-xl); }
    .sorella-pdp__info { position: static; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product info",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Product (leave blank to use current)" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_short_desc", "label": "Show short description", "default": true },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob behind price card", "default": true },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "slate",
      "options": [
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "rose", "label": "Rose" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust line",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "truck",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "gift", "label": "Gift" },
            { "value": "shield", "label": "Shield" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "droplet", "label": "Droplet" }
          ] },
        { "type": "text", "id": "text", "label": "Text", "default": "Free 5ml gift over 1,100 LE" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product info",
      "blocks": [
        { "type": "trust", "settings": { "icon": "gift", "text": "Free 5ml gift over 1,100 LE" } },
        { "type": "trust", "settings": { "icon": "truck", "text": "Ships across Egypt in 5–8 days" } },
        { "type": "trust", "settings": { "icon": "leaf", "text": "Made fresh in Egypt" } }
      ]
    }
  ]
}
{% endschema %}
