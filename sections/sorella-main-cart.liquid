{%- comment -%}
  sorella-main-cart — full-page cart (Page Templates Report §3.4).
  Fallback when the drawer is off or JS is unavailable; the drawer mirrors this logic.
  Quantity / remove links reuse theme.js data-line hooks (they POST on the cart page too).
{%- endcomment -%}
{%- liquid
  assign threshold = settings.free_gift_threshold | times: 100
  assign remaining = threshold | minus: cart.total_price
-%}
<section class="sorella-main-cart surface-ink" data-cart-contents>
  <div class="container container--lock section-pad sorella-main-cart__inner">
    <h1 class="t-display-lg sorella-main-cart__title">{{ 'cart.general.title' | t }} ({{ cart.item_count }})</h1>

    {%- if cart.item_count == 0 -%}
      {%- assign cart_empty_heading = 'cart.general.empty' | t -%}
      {%- assign cart_empty_cta = 'cart.general.empty_cta' | t -%}
      {% render 'sorella-empty-state',
        heading: cart_empty_heading,
        cta_label: cart_empty_cta,
        cta_url: routes.all_products_collection_url,
        icon: 'bag' %}
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" class="sorella-main-cart__form">
        {%- if settings.free_gift_threshold > 0 -%}
          <div class="sorella-cart__progress">
            {%- if remaining > 0 -%}
              <span class="t-caption">{{ 'cart.general.free_gift_progress' | t: amount: remaining | money }}</span>
            {%- else -%}
              <span class="t-caption text-gold">{{ 'cart.general.free_gift_unlocked' | t }}</span>
            {%- endif -%}
            <div class="sorella-cart__progress-track">
              {%- assign pct = cart.total_price | times: 100 | divided_by: threshold -%}
              <div class="sorella-cart__progress-fill" style="inline-size: {% if pct > 100 %}100{% else %}{{ pct }}{% endif %}%;"></div>
            </div>
          </div>
        {%- endif -%}

        <ul class="sorella-cart__lines sorella-main-cart__lines">
          {%- for line in cart.items -%}
            {% render 'sorella-cart-line-item', line: line, index: forloop.index %}
          {%- endfor -%}
        </ul>

        <div class="sorella-cart__foot sorella-main-cart__foot glass-panel glass-panel--md">
          <div class="sorella-cart__subtotal">
            <span class="t-body-strong">{{ 'cart.general.subtotal' | t }}</span>
            <span class="t-price text-gold">{{ cart.total_price | money }}</span>
          </div>
          <span class="t-fine-print text-mist">{{ 'cart.general.taxes_shipping' | t }}</span>
          <button type="submit" name="checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.sorella-main-cart .section-pad { padding-block-start: calc(var(--nav-dock-height) + var(--space-xxl)); }
.sorella-main-cart__inner { display: flex; flex-direction: column; gap: var(--space-xl); }
.sorella-main-cart__form { display: flex; flex-direction: column; gap: var(--space-lg); }
.sorella-main-cart__lines { max-inline-size: var(--container-read); }
.sorella-main-cart__foot { max-inline-size: var(--container-read); padding: var(--space-lg); }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart Page",
  "tag": "section",
  "settings": [],
  "presets": [
    { "name": "Cart" }
  ]
}
{% endschema %}
