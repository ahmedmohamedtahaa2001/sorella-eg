{%- comment -%}
  Sorella — Bundles spotlight (audit §2.6 / §6)
  Row/grid of bundle cards from a collection OR from product blocks.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign coll = s.collection
  assign use_blocks = false
  if section.blocks.size > 0
    assign use_blocks = true
  endif
-%}
<section class="sec"{% if s.anchor_id != blank %} id="{{ s.anchor_id }}"{% endif %}>
  <div class="wrap">
    <div class="sec__head">
      <div>
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
        {%- if s.subheading != blank -%}<p>{{ s.subheading }}</p>{%- endif -%}
      </div>
      {%- if s.link_label != blank -%}<a class="link-arrow" href="{{ s.link_url | default: coll.url | default: '#' }}">{{ s.link_label }} →</a>{%- endif -%}
    </div>

    <div class="bundlegrid">
      {%- if use_blocks -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {% render 'sorella-bundle-card', product: block.settings.product, items: block.settings.items, badge: block.settings.badge %}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif coll != blank and coll.products.size > 0 -%}
        {%- for product in coll.products limit: s.product_count -%}
          {% render 'sorella-bundle-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundles spotlight",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Save when they layer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bundles built to wear together" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our best-anchored value — the scents our sisters reach for as a pair." },
    { "type": "collection", "id": "collection", "label": "Bundles collection", "info": "Used when no bundle blocks are added." },
    { "type": "range", "id": "product_count", "label": "Bundles shown (from collection)", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop all bundles" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "bundles" }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "product", "id": "product", "label": "Bundle product" },
        { "type": "text", "id": "items", "label": "Layering / what's inside line", "info": "e.g. Bordeaux + Baklava · layer for evening" },
        { "type": "text", "id": "badge", "label": "Badge override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundles spotlight",
      "blocks": [{ "type": "bundle" }, { "type": "bundle" }, { "type": "bundle" }]
    }
  ]
}
{% endschema %}
