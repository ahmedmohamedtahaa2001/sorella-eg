{%- comment -%}
  Sorella — "The details" accordion (.acc, native <details>). Block-driven
  (title + richtext). First open block expands by default.
{%- endcomment -%}
<div class="pdp">
  <section class="pdp-sec">
    <h2 class="pdp-sec__h">{{ section.settings.heading | default: 'The details' }}</h2>
    <div class="acc">
      {%- for block in section.blocks -%}
        <details{% if block.settings.open %} open{% endif %} {{ block.shopify_attributes }}>
          <summary>{{ block.settings.title }}</summary>
          <div class="acc__body">{{ block.settings.body }}</div>
        </details>
      {%- endfor -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Product — details",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The details" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "The story" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Our reading of a modern icon — masterfully reimagined and made the عطّار way, on rich oils rather than alcohol, so it stays true to the original and lasts far longer. Blended in small batches in Egypt and poured to order.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product — details",
      "blocks": [
        { "type": "item", "settings": { "title": "The story", "open": true, "body": "<p>Our reading of a modern icon — masterfully reimagined and made the عطّار way, on rich oils rather than alcohol, so it stays true to the original and lasts far longer. Blended in small batches in Egypt and poured to order.</p>" } },
        { "type": "item", "settings": { "title": "How to wear it", "body": "<p>Spray on pulse points — wrists, neck, and once on the fabric of your scarf or collar, where oil-based scent lingers for days. Two sprays is plenty; this one carries.</p>" } },
        { "type": "item", "settings": { "title": "Ingredients", "body": "<p>Alcohol-free perfume oil base. Full INCI on the carton.</p>" } },
        { "type": "item", "settings": { "title": "Shipping & returns", "body": "<p>Ships from Egypt in 2–4 days. Because fragrance is personal, we can't accept opened returns — which is exactly why we offer the 5ml tester: try it first, commit only when you love it.</p>" } }
      ]
    }
  ]
}
{% endschema %}
