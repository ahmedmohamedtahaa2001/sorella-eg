{%- comment -%}
  sorella-inspiration — "The Art of Inspiration" statement (StitchDesign §homepage-6).
  8-col statement glass card + 4-col column of value cards. Zero hardcoded content.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="sorella-inspiration blob-scene surface-ink section-pad" data-section-id="{{ section.id }}">
  {%- if s.show_blob -%}
    {%- if s.blob_scheme == 'gold-slate' -%}
      {%- comment -%} Two-blob reference scheme: gold top-right + slate bottom-left (mirrored via scoped CSS below) {%- endcomment -%}
      {% render 'sorella-blob', scheme: s.blob_scheme %}
    {%- else -%}
      {% render 'sorella-blob', scheme: s.blob_scheme, single: true, position: 'tr', size: 'large' %}
    {%- endif -%}
  {%- endif -%}

  <div class="container container--bento sorella-inspiration__grid">
    <div class="sorella-inspiration__main glass-panel glass-panel--xl glass-panel--sheen">
      {%- if s.eyebrow != blank -%}<span class="t-eyebrow text-gold">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank or s.heading_accent != blank -%}
        <h2 class="t-display-lg sorella-inspiration__heading">
          {{ s.heading }}{% if s.heading_accent != blank %}<br><span class="sorella-inspiration__accent">{{ s.heading_accent }}</span>{% endif %}
        </h2>
      {%- endif -%}
      {%- if s.lead != blank -%}<p class="t-lead sorella-inspiration__lead">{{ s.lead }}</p>{%- endif -%}
      {%- if s.tagline != blank -%}
        <div class="sorella-inspiration__tagline text-gold">
          {%- if s.tagline_icon != blank -%}{% render 'sorella-icon', name: s.tagline_icon, size: 20 %}{%- endif -%}
          <span class="t-eyebrow">{{ s.tagline }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="sorella-inspiration__aside">
        {%- for block in section.blocks -%}
          <article class="sorella-inspiration__value glass-panel glass-panel--md glass-panel--sheen" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="sorella-inspiration__value-icon">{% render 'sorella-icon', name: block.settings.icon, size: 30 %}</span>
            {%- endif -%}
            <div>
              {%- if block.settings.heading != blank -%}<h3 class="t-title">{{ block.settings.heading }}</h3>{%- endif -%}
              {%- if block.settings.text != blank -%}<p class="t-body-sm">{{ block.settings.text }}</p>{%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* Two-blob reference placement: mirror the snippet's fixed tl/br pair to
     gold ~600px top-right + slate ~400px bottom-left (scoped to this section). */
  .sorella-inspiration > .blob-field .blob--tl {
    inset-inline-start: auto; inset-inline-end: -8%;
    width: clamp(380px, 42vw, 600px);
  }
  .sorella-inspiration > .blob-field .blob--br {
    inset-inline-end: auto; inset-inline-start: -8%;
    width: clamp(240px, 28vw, 400px);
  }
  .sorella-inspiration__grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-lg); align-items: stretch;
  }
  .sorella-inspiration__main {
    display: flex; flex-direction: column; justify-content: center; gap: var(--space-md);
    padding: var(--space-xxl); min-height: 400px; color: var(--color-parchment);
  }
  .sorella-inspiration__accent { font-style: italic; color: var(--color-gold); }
  .sorella-inspiration__lead { color: var(--color-parchment-65); max-width: 580px; }
  .sorella-inspiration__tagline { display: inline-flex; align-items: center; gap: var(--space-xs); margin-block-start: var(--space-sm); }
  .sorella-inspiration__aside { display: flex; flex-direction: column; gap: var(--space-lg); }
  .sorella-inspiration__value {
    display: flex; flex-direction: column; justify-content: space-between; gap: var(--space-md);
    padding: var(--space-lg); flex: 1; color: var(--color-parchment);
    transition: transform var(--dur-hover) var(--ease-out), border-color var(--dur-hover) var(--ease-out);
  }
  .sorella-inspiration__value:hover { transform: translateY(-3px); border-color: var(--color-gold-40); }
  .sorella-inspiration__value-icon { color: var(--color-gold); display: inline-flex; }
  .sorella-inspiration__value p { color: var(--color-parchment-65); margin-block-start: var(--space-xxs); }
  @media (max-width: 1023px) {
    .sorella-inspiration__grid { grid-template-columns: 1fr; }
    .sorella-inspiration__aside { flex-direction: row; flex-wrap: wrap; }
    .sorella-inspiration__value { flex: 1 1 220px; }
  }
  @media (max-width: 640px) {
    .sorella-inspiration__main { padding: var(--space-xl) var(--space-lg); }
    .sorella-inspiration__aside { flex-direction: column; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Art of Inspiration",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Art Direction" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Art of" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic gold)", "default": "Inspiration" },
    { "type": "textarea", "id": "lead", "label": "Lead paragraph", "default": "We recreate the world's most iconic, high-end fragrances with Egyptian botanical mastery. Experience the same olfactory complexity and longevity of luxury houses, crafted with local soul." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Masterfully Reimagined" },
    {
      "type": "select", "id": "tagline_icon", "label": "Tagline icon", "default": "sparkle",
      "options": [
        { "value": "sparkle", "label": "Sparkle" },
        { "value": "star", "label": "Star" },
        { "value": "shield", "label": "Shield" },
        { "value": "", "label": "None" }
      ]
    },
    { "type": "header", "content": "Atmosphere" },
    { "type": "checkbox", "id": "show_blob", "label": "Show blob", "default": true },
    {
      "type": "select", "id": "blob_scheme", "label": "Blob colour", "default": "gold-slate",
      "options": [
        { "value": "gold", "label": "Gold" },
        { "value": "slate", "label": "Slate" },
        { "value": "gold-slate", "label": "Gold + Slate (reference)" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value card",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "heart", "label": "Heart" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "verified", "label": "Verified badge" }
          ]
        },
        { "type": "text", "id": "heading", "label": "Heading", "default": "True to the Original" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Faithful renditions built on rich perfume oils, so the scent lasts on skin and clothes for days." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Art of Inspiration",
      "blocks": [
        { "type": "value", "settings": { "icon": "sparkle", "heading": "Accessible Luxury", "text": "Premium quality without the prestige markup. High-end scents for every day." } },
        { "type": "value", "settings": { "icon": "verified", "heading": "True to the Original", "text": "Faithful renditions built on rich perfume oils, so the scent lasts on skin and clothes for days." } }
      ]
    }
  ]
}
{% endschema %}
