{%- comment -%}
  sorella-pagination — param-driven pagination (§9).
  DEFAULT ('numbered') reproduces the original numbered nav exactly.

  Params:
    paginate (object, required) — Shopify paginate drop
    variant  (string) — 'numbered' (default) | 'prev-next' | 'load-more'
                       | 'infinite' | 'minimal' | 'compact' | 'count'
    load_url (string) — override next url for 'load-more' (defaults to paginate.next.url)
    label    (string) — button text for 'load-more' (default 'Load more')
{%- endcomment -%}
{%- liquid
  assign pg_variant = variant | default: 'numbered'
  assign pg_class = 'sorella-pagination'
  if pg_variant != 'numbered'
    assign pg_class = pg_class | append: ' sorella-pagination--' | append: pg_variant
  endif
-%}
{%- case pg_variant -%}

  {%- when 'load-more' -%}
    {%- if paginate.next -%}
      <div class="{{ pg_class }}">
        <a class="btn btn--ghost sorella-pagination__more" href="{{ load_url | default: paginate.next.url }}" data-load-more rel="next">
          {{ label | default: 'Load more' }}
        </a>
      </div>
    {%- endif -%}

  {%- when 'infinite' -%}
    {%- if paginate.next -%}
      <div class="{{ pg_class }}" data-infinite-scroll data-next-url="{{ paginate.next.url }}" aria-hidden="true">
        <span class="sorella-pagination__sentinel"></span>
      </div>
    {%- endif -%}

  {%- when 'count' -%}
    {%- if paginate.pages > 1 -%}
      <nav class="{{ pg_class }}" role="navigation" aria-label="{{ 'general.accessibility.pagination' | t }}">
        {%- if paginate.previous -%}<a class="sorella-pagination__link" href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">{% render 'sorella-icon', name: 'chevron-left', size: 18 %}</a>{%- endif -%}
        <span class="sorella-pagination__count t-caption text-mist">{{ 'general.meta.page' | t: page: paginate.current_page }} / {{ paginate.pages }}</span>
        {%- if paginate.next -%}<a class="sorella-pagination__link" href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">{% render 'sorella-icon', name: 'chevron-right', size: 18 %}</a>{%- endif -%}
      </nav>
    {%- endif -%}

  {%- when 'prev-next' -%}
    {%- if paginate.pages > 1 -%}
      <nav class="{{ pg_class }}" role="navigation" aria-label="{{ 'general.accessibility.pagination' | t }}">
        {%- if paginate.previous -%}
          <a class="sorella-pagination__link t-caption" href="{{ paginate.previous.url }}" rel="prev">{% render 'sorella-icon', name: 'chevron-left', size: 18 %} {{ 'general.pagination.previous' | t }}</a>
        {%- else -%}<span class="sorella-pagination__link is-disabled t-caption" aria-hidden="true">{% render 'sorella-icon', name: 'chevron-left', size: 18 %} {{ 'general.pagination.previous' | t }}</span>{%- endif -%}
        {%- if paginate.next -%}
          <a class="sorella-pagination__link t-caption" href="{{ paginate.next.url }}" rel="next">{{ 'general.pagination.next' | t }} {% render 'sorella-icon', name: 'chevron-right', size: 18 %}</a>
        {%- else -%}<span class="sorella-pagination__link is-disabled t-caption" aria-hidden="true">{{ 'general.pagination.next' | t }} {% render 'sorella-icon', name: 'chevron-right', size: 18 %}</span>{%- endif -%}
      </nav>
    {%- endif -%}

  {%- when 'minimal' -%}
    {%- if paginate.pages > 1 -%}
      {%- assign current_page_title = paginate.current_page | append: '' -%}
      <nav class="{{ pg_class }}" role="navigation" aria-label="{{ 'general.accessibility.pagination' | t }}">
        {%- for part in paginate.parts -%}
          {%- if part.title == current_page_title -%}
            <span class="sorella-pagination__dot is-current" aria-current="page" aria-label="{{ 'general.meta.page' | t: page: part.title }}"></span>
          {%- elsif part.is_link -%}
            <a class="sorella-pagination__dot" href="{{ part.url }}" aria-label="{{ 'general.meta.page' | t: page: part.title }}"></a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

  {%- else -%}
    {%- comment -%} numbered (default) + compact (same markup, tighter CSS) {%- endcomment -%}
    {%- if paginate.pages > 1 -%}
      {%- assign current_page_title = paginate.current_page | append: '' -%}
      <nav class="{{ pg_class }}" role="navigation" aria-label="{{ 'general.accessibility.pagination' | t }}">
        {%- if paginate.previous -%}
          <a class="sorella-pagination__link" href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
            {% render 'sorella-icon', name: 'chevron-left', size: 18 %}
          </a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a class="sorella-pagination__link t-caption" href="{{ part.url }}" aria-label="{{ 'general.meta.page' | t: page: part.title }}">{{ part.title }}</a>
          {%- elsif part.title == current_page_title -%}
            <span class="sorella-pagination__link is-current t-caption-strong" aria-current="page" aria-label="{{ 'general.meta.page' | t: page: part.title }}">{{ part.title }}</span>
          {%- else -%}
            <span class="sorella-pagination__ellipsis t-caption" aria-hidden="true">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a class="sorella-pagination__link" href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
            {% render 'sorella-icon', name: 'chevron-right', size: 18 %}
          </a>
        {%- endif -%}
      </nav>
    {%- endif -%}

{%- endcase -%}
