{%- comment -%}
  Sorella — product card (.pcard) — real Shopify product data
  Params:
    product (object, required)
    variant (string, default 'plus') — one of:
        'default'  Add-to-bag reveals on hover (.pcard__add)
        'add'      single visible Add to bag (.pcard__actions)
        'cta'      Add to bag + Buy it now
        'plus'     round "+" quick-add on the price row (.pcard__plus)
        'shelf'    rich collection card — world pill, hook, value chips, rating, anchor, Add to bag
        'feature'  landscape hero card (spans 2×2) — world pill, hook, three-act facts, anchor, Add to bag
        'soldout'  desaturated, "Notify me" (.pcard--soldout)
        'compact'  dense grid tile
        'row'      horizontal list / cart upsell
        'overlay'  editorial, copy over the image
        'swatch'   size pills (.pcard__sizes) + Add to bag
        'wish'     wishlist heart (.pcard__wish) + Add to bag
    badge   (string, optional) — overrides the corner tag
    flag    (string, optional) — feature card corner flag (e.g. "Bestseller")
  Selling-value data (shelf/feature): metafields.sorella.world, .longevity,
    .tagline, .notes, .rating, .review_count; compare-at anchor; LE 85 tester nudge.
{%- endcomment -%}
{%- liquid
  assign v = variant | default: 'plus'

  assign pclass = 'pcard'
  unless v == 'default'
    assign pclass = pclass | append: ' pcard--' | append: v
  endunless

  comment
    gradient backdrop behind the image — cycle m1..m4 by product id
  endcomment
  assign mgrad = product.id | modulo: 4 | plus: 1

  assign img = product.featured_image
  assign iw = 640
  if v == 'feature'
    assign iw = 1100
  endif
  assign ih = 800
  if img
    assign ih = iw | divided_by: img.aspect_ratio | round
  endif

  assign notes = product.metafields.sorella.notes.value
  if notes == blank
    assign notes = product.tags | slice: 0, 3 | join: ' · '
  endif

  # short tagline / description used by the quick-add + shelf card body
  assign desc = product.metafields.sorella.tagline.value
  if desc == blank
    assign desc = product.description | strip_html | truncatewords: 22
  endif

  assign rating = product.metafields.sorella.rating
  assign review_count = product.metafields.sorella.review_count

  assign vid = product.selected_or_first_available_variant.id
  assign avail = product.available

  assign on_sale = false
  if product.compare_at_price != blank and product.compare_at_price > product.price
    assign on_sale = true
  endif

  # sold-out state: explicit variant OR out of stock
  assign is_soldout = false
  if v == 'soldout' or avail == false
    assign is_soldout = true
  endif

  # which variants render the .pcard__actions block
  assign has_actions = false
  if v == 'add' or v == 'cta' or v == 'swatch' or v == 'wish' or v == 'soldout'
    assign has_actions = true
  endif

  # "New" badge — product tagged 'new' or a sorella.badge metafield override
  assign custom_badge = product.metafields.sorella.badge
  assign is_new = false
  if product.tags contains 'new' or product.tags contains 'New' or product.tags contains 'NEW'
    assign is_new = true
  endif

  # wishlist heart on the portrait cards
  assign show_wish = false
  unless v == 'row' or v == 'compact' or v == 'overlay'
    assign show_wish = true
  endunless

  # --- selling-value data (shelf + feature cards) ---
  assign is_rich = false
  if v == 'shelf' or v == 'feature'
    assign is_rich = true
  endif
  assign world = product.metafields.sorella.world.value
  assign longevity = product.metafields.sorella.longevity.value
  assign save_amt = 0
  if on_sale
    assign save_amt = product.compare_at_price | minus: product.price
  endif
  # tester nudge only on full-size bottles, never on a tester itself
  assign show_try = false
  if is_rich and product.price > 55000
    unless product.handle contains 'tester' or product.handle contains '5ml' or product.title contains '5ml' or product.title contains 'Tester'
      assign show_try = true
    endunless
  endif
  assign show_world = false
  if is_rich and world != blank
    assign show_world = true
  endif
  assign is_original = product.metafields.sorella.is_original.value
-%}
<article class="{{ pclass }}"{% if product != blank %} data-quick-buy="{{ product.handle }}"{% endif %}>
  <div class="pcard__media pcard__m{{ mgrad }}">
    {%- if badge != blank -%}
      <div class="pcard__tags"><span class="tag tag--solid">{{ badge }}</span></div>
    {%- elsif flag != blank and v == 'feature' -%}
      <div class="pcard__tags"><span class="tag tag--solid">{{ flag }}</span></div>
    {%- elsif custom_badge != blank -%}
      <div class="pcard__tags"><span class="tag tag--out">{{ custom_badge }}</span></div>
    {%- elsif is_soldout -%}
      <div class="pcard__tags"><span class="tag tag--muted">Sold out</span></div>
    {%- elsif on_sale -%}
      <div class="pcard__tags"><span class="tag tag--solid">Sale</span></div>
    {%- elsif is_new -%}
      <div class="pcard__tags"><span class="tag tag--out">New</span></div>
    {%- endif -%}

    {%- liquid
      # resolve the real URL. Some products carry an image record whose file
      # never imported (image_url returns a URL that 404s) — Liquid can't tell.
      # So the branded bottle placeholder is always rendered as a backdrop and
      # the <img> removes itself on load error, revealing it.
      assign img_src = ''
      if img
        assign img_src = img | image_url: width: iw
      endif
      assign ph_size = 'ph'
      if v == 'feature'
        assign ph_size = 'lg'
      elsif v == 'row'
        assign ph_size = 'sm'
      endif
    -%}
    <a href="{{ product.url }}" class="pcard__mediaLink" aria-label="{{ product.title | escape }}">
      {% render 'sorella-bottle', product: product, world: world, notes: notes, size: ph_size %}
      {%- if img_src != blank -%}
        <img class="pcard__img" src="{{ img_src }}" alt="{{ img.alt | default: product.title | escape }}" width="{{ iw }}" height="{{ ih }}" loading="lazy" onerror="this.remove()">
      {%- endif -%}
    </a>

    {%- if show_world -%}
      <span class="pcard__world">{{ world }}</span>
    {%- endif -%}

    {%- if show_wish -%}
      <button type="button" data-no-quickbuy data-wish class="pcard__wish" aria-label="Save {{ product.title | escape }} to wishlist" aria-pressed="false"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 20s-7-4.4-9.4-8.9C1 8 2.6 4.6 6 4.6c2 0 3.2 1.2 4 2.3.8-1.1 2-2.3 4-2.3 3.4 0 5 3.4 3.4 6.5C19 15.6 12 20 12 20Z"/></svg></button>
    {%- endif -%}

    {%- if v == 'default' and is_soldout == false -%}
      <div class="pcard__add">
        <form action="{{ routes.cart_add_url }}" method="post">
          <input type="hidden" name="id" value="{{ vid }}">
          <button type="submit" name="add" data-no-quickbuy class="btn btn--primary btn--sm btn--full">Add to bag · {{ product.price | money }}</button>
        </form>
      </div>
    {%- endif -%}
  </div>

  <div class="pcard__body">
    {%- if v == 'plus' -%}
      {%- comment -%} quick-add card: notes → name → description → price + "+" {%- endcomment -%}
      {%- if notes != blank -%}<span class="pcard__notes">{{ notes }}</span>{%- endif -%}
      <h3 class="pcard__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
      {%- if desc != blank -%}<p class="pcard__desc">{{ desc }}</p>{%- endif -%}
      <div class="pcard__row">
        <span class="pcard__price">{% if on_sale %}<s>{{ product.compare_at_price | money }}</s>{% endif %}{{ product.price | money }}</span>
        {%- if is_soldout == false -%}
          <form action="{{ routes.cart_add_url }}" method="post">
            <input type="hidden" name="id" value="{{ vid }}">
            <button type="submit" name="add" data-no-quickbuy class="pcard__plus" aria-label="Add {{ product.title | escape }} to bag"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
          </form>
        {%- endif -%}
      </div>

    {%- elsif is_rich -%}
      {%- comment -%} shelf / feature: sell the value, not just the name {%- endcomment -%}
      {%- unless show_world -%}
        {%- if notes != blank -%}<span class="pcard__notes">{{ notes }}</span>{%- endif -%}
      {%- endunless -%}

      <h3 class="pcard__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
      {%- comment -%} originals don't need the badge on every tile — keep it for the hero + renditions {%- endcomment -%}
      {%- if v == 'feature' or is_original == false -%}
        {% render 'sorella-inspired-by', product: product %}
      {%- endif -%}

      {%- comment -%} description only on the landscape feature — keeps grid tiles short {%- endcomment -%}
      {%- if desc != blank and v == 'feature' -%}<p class="pcard__desc">{{ desc }}</p>{%- endif -%}

      {%- if v == 'feature' -%}
        <ul class="pcard__facts">
          <li>Composed in three acts on an oil-rich base — made fresh in Egypt.</li>
          <li>{{ longevity | default: 'Built to last for days on your clothes.' }}</li>
        </ul>
      {%- endif -%}

      {%- comment -%} keep chips to one short row on grid tiles; longevity chip is verbose, drop it {%- endcomment -%}
      {%- if v == 'feature' and longevity != blank -%}
        <div class="pcard__chips"><span class="pcard__chip">{{ longevity }}</span></div>
      {%- endif -%}
      {%- if save_amt > 0 or show_try -%}
        <div class="pcard__chips">
          {%- if save_amt > 0 -%}<span class="pcard__chip pcard__chip--save">Save {{ save_amt | money }}</span>{%- endif -%}
          {%- if show_try -%}<span class="pcard__chip pcard__chip--try">Try first · LE 85</span>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="pcard__row">
        {%- if rating != blank -%}{% render 'sorella-stars', rating: rating, count: review_count %}{%- endif -%}
        <span class="pcard__price">{% if on_sale %}<s>{{ product.compare_at_price | money }}</s>{% endif %}{{ product.price | money }}</span>
      </div>

      {%- if is_soldout -%}
        <div class="pcard__cta"><button type="button" class="btn btn--ghost btn--full">✉ Notify me</button></div>
      {%- else -%}
        <div class="pcard__cta">
          <form action="{{ routes.cart_add_url }}" method="post">
            <input type="hidden" name="id" value="{{ vid }}">
            <button type="submit" name="add" data-no-quickbuy class="btn btn--primary btn--full">Add to bag</button>
          </form>
        </div>
      {%- endif -%}

    {%- else -%}
    {%- unless v == 'compact' -%}
      {%- if notes != blank -%}<span class="pcard__notes">{{ notes }}</span>{%- endif -%}
    {%- endunless -%}

    <h3 class="pcard__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>

    {%- unless v == 'compact' or v == 'overlay' -%}
      {% render 'sorella-inspired-by', product: product %}
    {%- endunless -%}

    {%- if v == 'swatch' -%}
      <div class="pcard__sizes"><button type="button">5ml</button><button type="button" class="on">50ml</button><button type="button">Bundle</button></div>
    {%- endif -%}

    <div class="pcard__row">
      {%- if v == 'row' -%}
        <span class="pcard__price">{% if on_sale %}<s>{{ product.compare_at_price | money }}</s>{% endif %}{{ product.price | money }}</span>
        {%- if is_soldout -%}
          <a href="{{ product.url }}" class="btn btn--ghost btn--sm">View</a>
        {%- else -%}
          <form action="{{ routes.cart_add_url }}" method="post">
            <input type="hidden" name="id" value="{{ vid }}">
            <button type="submit" name="add" data-no-quickbuy class="btn btn--primary btn--sm">Add to bag</button>
          </form>
        {%- endif -%}
      {%- elsif v == 'compact' or v == 'swatch' -%}
        {% render 'sorella-stars', rating: rating, size: 'sm' %}
        <span class="pcard__price">{% if on_sale %}<s>{{ product.compare_at_price | money }}</s>{% endif %}{{ product.price | money }}</span>
      {%- else -%}
        {% render 'sorella-stars', rating: rating, count: review_count %}
        <span class="pcard__price">{% if on_sale %}<s>{{ product.compare_at_price | money }}</s>{% endif %}{{ product.price | money }}</span>
      {%- endif -%}
    </div>

    {%- if has_actions -%}
      {%- if is_soldout -%}
        <div class="pcard__actions"><button type="button" class="btn btn--ghost btn--full">✉ Notify me</button></div>
      {%- else -%}
        <form action="{{ routes.cart_add_url }}" method="post" class="pcard__actions">
          <input type="hidden" name="id" value="{{ vid }}">
          <button type="submit" name="add" data-no-quickbuy class="btn btn--primary btn--full">Add to bag</button>
          {%- if v == 'cta' -%}<button type="submit" name="checkout" data-no-quickbuy class="btn btn--ghost btn--full">Buy it now</button>{%- endif -%}
        </form>
      {%- endif -%}
    {%- endif -%}
    {%- endif -%}
  </div>
</article>
