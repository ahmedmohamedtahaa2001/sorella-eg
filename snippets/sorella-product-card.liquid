{%- comment -%}
  sorella-product-card — solid catalog card, gold hover border, no blur (§9).
  Variants: default / quick-add / compact — sold-out demotion is automatic.
  Quick add lives INSIDE the media as a bottom-center parchment pill,
  revealed on hover/focus (always visible on touch and for 'compact').
  Params:
    product  (object, required)
    variant  (string) — 'default' (default) | 'quick-add' | 'compact'
    ratio    (string) — media ratio class; falls back to settings.card_image_ratio
    quick_add (boolean) — override settings.card_quick_add
    lazy     (boolean) — lazy-load image (default true)
{%- endcomment -%}
{%- liquid
  assign card_variant = variant | default: 'default'
  assign ratio_class = ratio | default: settings.card_image_ratio | default: 'media--4x5'
  assign is_available = product.available
  assign show_quick_add = quick_add
  if quick_add == nil
    assign show_quick_add = settings.card_quick_add
  endif
  if card_variant == 'compact'
    assign show_quick_add = true
  endif
  assign loading = 'lazy'
  if lazy == false
    assign loading = 'eager'
  endif
  assign inspired = product.metafields.sorella.inspired_by
  assign notes_summary = product.metafields.sorella.notes_summary

  assign hover_media = blank
  if settings.card_hover_image and product.media.size > 1
    assign hover_media = product.media[1]
    if hover_media.media_type != 'image' or hover_media.id == product.featured_media.id
      assign hover_media = blank
    endif
  endif

  assign rating_data = blank
  if settings.card_show_rating
    assign rating_data = product.metafields.reviews.rating.value
    assign rating_count = product.metafields.reviews.rating_count.value
  endif
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
-%}
<article class="sorella-card sorella-card--{{ card_variant }}{% unless is_available %} sorella-card--sold-out{% endunless %}">
  <div class="sorella-card__media-wrap">
    <a class="sorella-card__link" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
      <div class="media {{ ratio_class }} sorella-card__media">
        {%- if product.featured_media -%}
          {{ product.featured_media.preview_image | image_url: width: 600 | image_tag:
            loading: loading,
            sizes: '(max-width: 640px) 45vw, 280px',
            widths: '240, 320, 400, 600',
            alt: product.featured_media.alt | default: product.title | escape }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'media__placeholder' }}
        {%- endif -%}
        {%- if hover_media != blank -%}
          {{ hover_media.preview_image | image_url: width: 600 | image_tag:
            loading: 'lazy',
            class: 'sorella-card__media-hover',
            sizes: '(max-width: 640px) 45vw, 280px',
            widths: '240, 320, 400, 600',
            alt: hover_media.alt | default: product.title | escape }}
        {%- endif -%}
      </div>
    </a>

    <div class="sorella-card__badges">
      {%- if on_sale and is_available -%}{% render 'sorella-badge', variant: 'sale' %}{%- endif -%}
      {%- unless is_available -%}{% render 'sorella-badge', variant: 'sold-out' %}{%- endunless -%}
    </div>

    {%- if is_available and show_quick_add -%}
      <div class="sorella-card__actions">
        {%- if product.variants.size > 1 -%}
          {%- assign choose_label = 'products.product.choose_options' | t -%}
          {% render 'sorella-button', label: choose_label, href: product.url, style: 'primary', size: 'sm', full: true %}
        {%- else -%}
          {%- assign quick_label = 'products.product.quick_add' | t -%}
          {%- form 'product', product, class: 'sorella-card__form' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {% render 'sorella-button', label: quick_label, style: 'primary', size: 'sm', full: true, type: 'submit' %}
          {%- endform -%}
        {%- endif -%}
      </div>
    {%- elsif is_available == false -%}
      {%- assign notify_label = 'products.product.notify_me' | t -%}
      <div class="sorella-card__actions">
        {% render 'sorella-button', label: notify_label, href: product.url, style: 'primary', size: 'sm', full: true %}
      </div>
    {%- endif -%}
  </div>

  <div class="sorella-card__body">
    {%- if inspired != blank -%}{% render 'sorella-inspired-by-tag', name: inspired %}{%- endif -%}
    <div class="sorella-card__meta">
      <div class="sorella-card__id">
        <h3 class="sorella-card__title t-headline">
          <a href="{{ product.url }}" dir="auto">{{ product.title }}</a>
        </h3>
        {%- if rating_data != blank -%}
          <div class="sorella-card__rating">
            {% render 'sorella-star-rating', value: rating_data.rating, count: rating_count %}
          </div>
        {%- endif -%}
        {%- if notes_summary != blank -%}
          <p class="sorella-card__notes" dir="auto">{{ notes_summary }}</p>
        {%- endif -%}
      </div>
      <div class="sorella-card__price">
        {% render 'sorella-price', product: product, context: 'card' %}
      </div>
    </div>
  </div>
</article>
