{%- comment -%}
  sorella-newsletter-form — Shopify customer (newsletter) email capture (§9).
  DEFAULT (layout 'inline') reproduces the original markup exactly.

  Params:
    layout  (string) — 'inline' (default) | 'stacked' | 'minimal' | 'boxed'
                       | 'glass' | 'footer' | 'hero' | 'split'
    button_label (string) · field_id (string, unique id)
    consent (boolean) — append a consent checkbox row
    heading (string) · text (string) — optional lead copy (hero/boxed/glass)
{%- endcomment -%}
{%- liquid
  assign nl_layout = layout | default: 'inline'
  assign nl_field_id = field_id | default: 'newsletter-email'
-%}
<div class="sorella-newsletter-form sorella-newsletter-form--{{ nl_layout }}">
  {%- if heading != blank or text != blank -%}
    <div class="sorella-newsletter-form__lead">
      {%- if heading != blank -%}<p class="t-display-sm">{{ heading }}</p>{%- endif -%}
      {%- if text != blank -%}<p class="t-body-sm text-mist">{{ text }}</p>{%- endif -%}
    </div>
  {%- endif -%}
  {%- form 'customer', class: 'sorella-newsletter-form__form' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    {%- if form.posted_successfully? -%}
      <p class="t-body-strong text-gold sorella-newsletter-form__success" role="status">{{ 'general.newsletter.success' | t }}</p>
    {%- else -%}
      {%- if form.errors -%}
        <p class="t-body-sm text-gold sorella-newsletter-form__error" role="alert">
          {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
        </p>
      {%- endif -%}
      <div class="sorella-field sorella-newsletter-form__field">
        <label class="visually-hidden" for="{{ nl_field_id }}">{{ 'general.newsletter.label' | t }}</label>
        <input type="email" id="{{ nl_field_id }}" name="contact[email]" required
          class="sorella-newsletter-form__input"
          placeholder="{{ 'general.newsletter.placeholder' | t }}" autocomplete="email"
          {%- if form.errors %} aria-invalid="true" autofocus{% endif %}>
      </div>
      {%- if button_label != blank -%}
        {%- assign newsletter_submit_label = button_label -%}
      {%- else -%}
        {%- assign newsletter_submit_label = 'general.newsletter.submit' | t -%}
      {%- endif -%}
      {% render 'sorella-button', label: newsletter_submit_label, style: 'primary', type: 'submit' %}
      {%- if consent -%}
        <label class="sorella-newsletter-form__consent t-caption text-mist">
          <input type="checkbox" name="contact[accepts_marketing]" value="true" required>
          <span>{{ 'general.newsletter.label' | t }}</span>
        </label>
      {%- endif -%}
    {%- endif -%}
  {%- endform -%}
</div>
{% style %}
  .sorella-newsletter-form__form { flex-wrap: wrap; }
  .sorella-newsletter-form__error, .sorella-newsletter-form__success { flex-basis: 100%; }
{% endstyle %}
