{%- comment -%}
  sorella-button — primary (gold fill) / ghost / text (Design System §9).
  Params:
    label (string, required)
    href  (string) — renders <a> if present, else <button>
    style (string) — 'primary' (default) | 'ghost' | 'text'
    size  (string) — '' | 'sm'
    full  (boolean) — full width
    type  (string) — button type when not a link (default 'button')
    icon  (string) — optional trailing icon name
    id, data (string) — passthrough attributes
{%- endcomment -%}
{%- liquid
  assign btn_style = style | default: 'primary'
  assign classes = 'btn btn--' | append: btn_style
  if size == 'sm'
    assign classes = classes | append: ' btn--sm'
  endif
  if full
    assign classes = classes | append: ' btn--full'
  endif
-%}
{%- if href != blank -%}
  <a href="{{ href }}" class="{{ classes }}"{% if id %} id="{{ id }}"{% endif %}{% if data %} {{ data }}{% endif %}>
    {{ label }}{% if icon %} {% render 'sorella-icon', name: icon, size: 16 %}{% endif %}
  </a>
{%- else -%}
  <button type="{{ type | default: 'button' }}" class="{{ classes }}"{% if id %} id="{{ id }}"{% endif %}{% if data %} {{ data }}{% endif %}>
    {{ label }}{% if icon %} {% render 'sorella-icon', name: icon, size: 16 %}{% endif %}
  </button>
{%- endif -%}
