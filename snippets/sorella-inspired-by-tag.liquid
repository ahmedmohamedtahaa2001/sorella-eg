{%- comment -%}
  sorella-inspired-by-tag — the "dupe referencing" component, brand-safe by design.

  Sorella brand law: NEVER "dupe / copy / clone / smells like [Brand]" and never
  name a trademark as marketing. The Renditions line is referenced only as craft —
  "true to the original", "masterfully reimagined", "the Art of Inspiration".
  So the DEFAULT here is the neutral craft badge; the literal "Inspired by {name}"
  mode exists only as an explicit merchant opt-in (fed from a metafield), paired
  with the legal-hedge 'disclaimer' variant when a name is shown.

  Params:
    variant (string) — one of 8 (default 'craft'):
      'craft'       Pill · "True to the original" (Renditions only). Default.
      'reimagined'  Pill · "Masterfully reimagined".
      'art'         Pill · "The Art of Inspiration".
      'original'    Pill · "A Sorella Original" (for the Originals line).
      'inspired'    Pill · "Inspired by {name}" — needs `name`; merchant opt-in.
      'line'        Quiet underlined line under a product name.
      'stamp'       Engraved square seal (uppercase) for the PDP.
      'disclaimer'  Legal fine-print hedge line (pair with 'inspired').
    name  (string) — the referenced fragrance, for 'inspired' (e.g. product.metafields.sorella.inspired_by).
    label (string) — overrides the copy for 'line'/'stamp'.
{%- endcomment -%}

{%- liquid
  assign v = variant | default: 'craft'
  assign t_craft = 'products.product.true_to_original' | t
  assign t_reimagined = 'products.product.reimagined' | t
  assign t_art = 'products.product.art_of_inspiration' | t
  assign t_original = 'products.product.a_sorella_original' | t
-%}

{%- case v -%}

  {%- when 'reimagined' -%}
    <span class="sorella-inspired-by t-caption">
      {%- render 'sorella-icon', name: 'diamond', size: 13 -%} {{ t_reimagined }}
    </span>

  {%- when 'art' -%}
    <span class="sorella-inspired-by t-caption">
      {%- render 'sorella-icon', name: 'sparkle', size: 13 -%} {{ t_art }}
    </span>

  {%- when 'original' -%}
    <span class="sorella-inspired-by sorella-inspired-by--original t-caption">
      {%- render 'sorella-icon', name: 'verified', size: 13 -%} {{ t_original }}
    </span>

  {%- when 'inspired' -%}
    {%- if name != blank -%}
      <span class="sorella-inspired-by t-caption">
        {%- render 'sorella-icon', name: 'sparkle', size: 13 -%}
        {{ 'products.product.inspired_by' | t: name: name }}
      </span>
    {%- endif -%}

  {%- when 'line' -%}
    <span class="sorella-inspired-by__line t-caption text-mist">{{ label | default: t_craft }}</span>

  {%- when 'stamp' -%}
    <span class="sorella-inspired-by__stamp">
      <span class="sorella-inspired-by__stamp-inner t-eyebrow">{{ label | default: t_craft }}</span>
    </span>

  {%- when 'disclaimer' -%}
    <p class="sorella-inspired-by__disclaimer t-micro-legal text-mist">{{ 'products.product.disclaimer' | t }}</p>

  {%- else -%}
    {%- comment -%} craft (default) {%- endcomment -%}
    <span class="sorella-inspired-by t-caption">
      {%- render 'sorella-icon', name: 'droplet', size: 13 -%} {{ t_craft }}
    </span>

{%- endcase -%}
