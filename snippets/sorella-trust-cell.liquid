{%- comment -%}
  sorella-trust-cell — icon + short claim (§9).
  Layout modifier classes live in assets/sorella-lib-layout.css.

  Params:
    icon    (string)  — sorella-icon name (truck gift leaf shield droplet sparkle
                        heart diamond verified check star arrow-right)
    heading (string)
    text    (string)
    number  (string)  — used by 'numbered' variant in place of the icon
    glass   (boolean, REQUIRED — pass explicitly; omitted/false renders a plain
                        cell, true wraps it in a glass panel. No silent glass default.)
    variant (string)  — see table below (default '' = stacked icon + claim)

  Variants (9):
    (default)     — icon over heading + text, left-aligned
    horizontal    — icon beside a heading/text column
    stacked-center— centered icon + claim column
    inline-badge  — heading rendered as a pill badge above text
    bar-item      — compact horizontal item for a trust-bar row
    numbered      — big numeral (from `number`) in place of the icon
    large         — roomier padding + larger heading
    minimal       — no padding, tight icon + heading only
    with-divider  — trailing hairline divider under the claim
{%- endcomment -%}
{%- liquid
  assign v = variant | default: ''
  assign cell_class = 'sorella-trust-cell'
  case v
    when 'horizontal'
      assign cell_class = cell_class | append: ' sorella-trust-cell--horizontal'
    when 'stacked-center'
      assign cell_class = cell_class | append: ' sorella-trust-cell--center'
    when 'inline-badge'
      assign cell_class = cell_class | append: ' sorella-trust-cell--inline-badge'
    when 'bar-item'
      assign cell_class = cell_class | append: ' sorella-trust-cell--bar-item'
    when 'numbered'
      assign cell_class = cell_class | append: ' sorella-trust-cell--numbered'
    when 'large'
      assign cell_class = cell_class | append: ' sorella-trust-cell--large'
    when 'minimal'
      assign cell_class = cell_class | append: ' sorella-trust-cell--minimal'
    when 'with-divider'
      assign cell_class = cell_class | append: ' sorella-trust-cell--divider'
  endcase
-%}
{%- capture trust_inner -%}
  {%- if v == 'numbered' and number != blank -%}
    <span class="sorella-trust-cell__num t-display-md text-gold">{{ number }}</span>
  {%- elsif icon != blank -%}
    <span class="sorella-trust-cell__icon">{% render 'sorella-icon', name: icon, size: 24 %}</span>
  {%- endif -%}
  {%- if heading != blank -%}
    {%- if v == 'inline-badge' -%}
      <span class="sorella-trust-cell__badge t-caption text-gold">{{ heading }}</span>
    {%- else -%}
      <span class="t-body-strong">{{ heading }}</span>
    {%- endif -%}
  {%- endif -%}
  {%- if text != blank -%}<span class="t-body-sm text-mist">{{ text }}</span>{%- endif -%}
{%- endcapture -%}
{%- if glass -%}
  {% render 'sorella-glass-panel', content: trust_inner, variant: 'card', class: cell_class %}
{%- else -%}
  <div class="{{ cell_class }}">{{ trust_inner }}</div>
{%- endif -%}
