{%- comment -%}
  sorella-atc-button — the add-to-cart action + its satellite microcopy.
  Monochrome system: Pure White fill / Absolute Black label is the one loud mark.
  Drop inside a product <form action="/cart/add">; this renders the button
  (and, per variant, the trust line / tester cross-sell / free-gift nudge beneath it).
  Copy stays brand-voice: no "dupe", anchor against prestige (never discount),
  and the tester line is the no-returns trust contract.

  Params:
    variant (string) — one of 10 (default 'solid'):
      'solid'          Pure White pill, full-width. Default primary add.
      'solid-price'    Label left, price right on one pill (in-button price anchor).
      'ghost'          Quiet outline add (Graphite hover) — secondary placement.
      'stacked'        Solid button + one trust microcopy line beneath.
      'gift-threshold' Solid button + "Free 5ml over LE 1,100" nudge beneath.
      'tester'         Low-commitment cross-sell: "Try it first for LE 85" (renders <a> to tester).
      'split'          Add to Cart + "Buy it now" (dynamic checkout) stacked.
      'preorder'       Solid "Pre-order" + ships-by subtext.
      'sold-out'       Disabled ghost: "Sold out — notify me".
      'mini'           Compact one-tap "Add" for cards / quick-add.
    label       (string) — button text; falls back to a sensible per-variant default.
    price       (string, money) — rendered in 'solid-price'.
    subtext     (string) — overrides the default microcopy line (stacked/gift-threshold/preorder).
    threshold   (string, money) — free-gift threshold copy value (gift-threshold).
    tester_url  (string) · tester_price (string, money) — the tester cross-sell target.
    available   (boolean, default true) — false forces the sold-out treatment.
    full        (boolean, default true) — full-width.
    id, form, data (string) — passthrough attributes (form= associates a button outside its form).
{%- endcomment -%}

{%- liquid
  assign v = variant | default: 'solid'
  if available == false
    assign v = 'sold-out'
  endif

  assign wide = ' btn--full'
  if full == false
    assign wide = ''
  endif

  assign attrs = ''
  if id != blank
    assign attrs = attrs | append: ' id="' | append: id | append: '"'
  endif
  if form != blank
    assign attrs = attrs | append: ' form="' | append: form | append: '"'
  endif
  if data != blank
    assign attrs = attrs | append: ' ' | append: data
  endif

  assign l_add = 'products.product.add_to_bag' | t
  assign l_soldout = 'products.product.notify_me' | t
-%}

{%- case v -%}

  {%- when 'solid-price' -%}
    <button type="submit" class="btn btn--primary sorella-atc__solid-price{{ wide }}"{{ attrs }}>
      <span class="sorella-atc__label">{{ label | default: l_add }}</span>
      {%- if price != blank -%}<span class="sorella-atc__price t-price">{{ price }}</span>{%- endif -%}
    </button>

  {%- when 'ghost' -%}
    <button type="submit" class="btn btn--ghost{{ wide }}"{{ attrs }}>{{ label | default: l_add }}</button>

  {%- when 'stacked' -%}
    <div class="sorella-atc sorella-atc--stacked">
      <button type="submit" class="btn btn--primary{{ wide }}"{{ attrs }}>{{ label | default: l_add }}</button>
      <p class="sorella-atc__note t-caption text-mist">
        {% render 'sorella-icon', name: 'sparkle', size: 13 %}
        {{ subtext | default: 'Made fresh in Egypt · stays on all evening' }}
      </p>
    </div>

  {%- when 'gift-threshold' -%}
    <div class="sorella-atc sorella-atc--gift">
      <button type="submit" class="btn btn--primary{{ wide }}"{{ attrs }}>{{ label | default: l_add }}</button>
      <p class="sorella-atc__note sorella-atc__note--gift t-caption">
        {% render 'sorella-icon', name: 'gift', size: 14 %}
        {{ subtext | default: 'Free 5ml perfume on orders over LE 1,100 — pick it in your cart' }}
      </p>
    </div>

  {%- when 'tester' -%}
    {%- assign tester_label = label | default: 'Try it first — add the 5ml tester' -%}
    <a class="sorella-atc__tester" href="{{ tester_url | default: '#' }}"{{ attrs }}>
      <span class="sorella-atc__tester-lead">
        {% render 'sorella-icon', name: 'sparkle', size: 14 %}
        {{ tester_label }}
      </span>
      {%- if tester_price != blank -%}<span class="sorella-atc__tester-price t-price">{{ tester_price }}</span>{%- endif -%}
    </a>

  {%- when 'split' -%}
    <div class="sorella-atc sorella-atc--split">
      <button type="submit" class="btn btn--ghost{{ wide }}"{{ attrs }}>{{ label | default: l_add }}</button>
      <button type="submit" name="checkout" class="btn btn--primary{{ wide }} sorella-atc__buynow"{% if form != blank %} form="{{ form }}"{% endif %}>{{ 'products.product.buy_now' | t }}</button>
    </div>

  {%- when 'preorder' -%}
    <div class="sorella-atc sorella-atc--preorder">
      <button type="submit" class="btn btn--primary{{ wide }}"{{ attrs }}>{{ label | default: 'Pre-order' }}</button>
      <p class="sorella-atc__note t-caption text-mist">{{ subtext | default: 'Ships in 2–3 weeks — first batch, made fresh' }}</p>
    </div>

  {%- when 'sold-out' -%}
    <button type="button" class="btn btn--ghost sorella-atc__soldout{{ wide }}" aria-disabled="true"{{ attrs }}>
      {% render 'sorella-icon', name: 'mail', size: 16 %}
      {{ label | default: l_soldout }}
    </button>

  {%- when 'mini' -%}
    <button type="submit" class="btn btn--sm sorella-atc__mini"{{ attrs }}>{{ label | default: 'Add' }}</button>

  {%- else -%}
    {%- comment -%} solid (default) {%- endcomment -%}
    <button type="submit" class="btn btn--primary{{ wide }}"{{ attrs }}>{{ label | default: l_add }}</button>

{%- endcase -%}
