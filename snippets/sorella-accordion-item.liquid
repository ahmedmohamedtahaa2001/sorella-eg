{%- comment -%}
  sorella-accordion-item — Q/A or label/content (§9). Shared by FAQ + product accordion.
  Params:
    heading (string, required) · content (string, required — HTML) · id (string, required)
    open (boolean) — start expanded
{%- endcomment -%}
<div class="sorella-accordion__item" data-accordion-item>
  <h3>
    <button type="button" class="sorella-accordion__trigger t-body-strong"
      aria-expanded="{% if open %}true{% else %}false{% endif %}"
      aria-controls="acc-{{ id }}" data-accordion-trigger>
      <span>{{ heading }}</span>
      {% render 'sorella-icon', name: 'chevron-down', size: 20 %}
    </button>
  </h3>
  <div class="sorella-accordion__content" id="acc-{{ id }}" data-accordion-content{% if open %} style="max-height:none"{% endif %}>
    <div class="sorella-accordion__content-inner rte t-body">{{ content }}</div>
  </div>
</div>
