{%- comment -%}
  sorella-badge — cart-count (gold) / "Sold out" pill / generic tag (§9).
  Params:
    variant (string) — 'cart' | 'sold-out' | 'sale' | 'tag'
    label   (string) — text
    count   (number) — for cart variant
    hidden  (boolean)
{%- endcomment -%}
{%- liquid
  assign v = variant | default: 'tag'
-%}
{%- case v -%}
  {%- when 'cart' -%}
    <span class="sorella-badge sorella-badge--cart" data-cart-count{% if count == 0 %} hidden{% endif %}>{{ count | default: 0 }}</span>
  {%- when 'sold-out' -%}
    {%- assign sold_out_label = 'products.product.sold_out' | t -%}
    <span class="sorella-badge sorella-badge--sold-out t-caption-strong">{{ label | default: sold_out_label }}</span>
  {%- when 'sale' -%}
    {%- assign sale_label = 'products.product.sale' | t -%}
    <span class="sorella-badge sorella-badge--sale t-caption-strong">{{ label | default: sale_label }}</span>
  {%- else -%}
    <span class="sorella-badge sorella-badge--tag t-caption">{{ label }}</span>
{%- endcase -%}
