{%- comment -%}
  sorella-note-tier — one tier of the notes pyramid (§9).
  Solid surface (navy container + hairline border), NOT glass. Base rules in
  components.css (.sorella-note-tier*); variant treatments in sorella-lib-pdp.css.

  Params:
    tier   ('top'|'heart'|'base')  — pyramid position (indent + default icon)
    label  (string)                — tier label ("Top", "Heart", "Base")
    notes  (string comma-list OR array) — the note names
    style  (string)                — visual treatment, default 'pyramid-row'

  Variants (style:):
    pyramid-row    indented solid card, comma text        ← current output, unchanged
    stacked-card   full-width card, no indent
    chip-row       notes rendered as individual chips
    numbered       notes as a numbered list
    minimal        borderless inline label + notes
    with-icon      leaf/droplet/sparkle icon before label (by tier)
    accent-label   label with leading accent bar
    plain-row      pyramid-row without indentation
{%- endcomment -%}
{%- if notes != blank -%}
  {%- liquid
    assign s = style | default: 'pyramid-row'

    comment
      Normalise notes into a list for chip/numbered treatments.
    endcomment
    assign note_list = notes
    if notes.first == blank
      assign note_list = notes | split: ','
    endif

    case tier
      when 'top'
        assign tier_icon = 'sparkle'
      when 'heart'
        assign tier_icon = 'droplet'
      when 'base'
        assign tier_icon = 'leaf'
      else
        assign tier_icon = 'diamond'
    endcase
  -%}

  {%- case s -%}

  {%- when 'chip-row' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--chip-row">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <div class="sorella-note-tier__chips">
        {%- for note in note_list -%}
          <span class="sorella-note-tier__chip t-caption">{{ note | strip }}</span>
        {%- endfor -%}
      </div>
    </div>

  {%- when 'numbered' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--numbered">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <ol class="sorella-note-tier__list">
        {%- for note in note_list -%}
          <li class="t-body">{{ note | strip }}</li>
        {%- endfor -%}
      </ol>
    </div>

  {%- when 'with-icon' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--with-icon">
      <span class="sorella-note-tier__label t-eyebrow">
        {% render 'sorella-icon', name: tier_icon, size: 14 %}{{ label }}
      </span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>

  {%- when 'accent-label' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--accent-label">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>

  {%- when 'minimal' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--minimal">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>

  {%- when 'stacked-card' -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }} sorella-note-tier--stacked-card" style="background: var(--color-navy-container);">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>

  {%- when 'plain-row' -%}
    <div class="sorella-note-tier sorella-note-tier--plain-row" style="background: var(--color-navy-container);">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>

  {%- else -%}
    {%- comment -%} pyramid-row — current output, unchanged {%- endcomment -%}
    <div class="sorella-note-tier sorella-note-tier--{{ tier }}" style="background: var(--color-navy-container);">
      <span class="sorella-note-tier__label t-eyebrow">{{ label }}</span>
      <span class="sorella-note-tier__notes t-body">{{ notes }}</span>
    </div>
  {%- endcase -%}
{%- endif -%}
