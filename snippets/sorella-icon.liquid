{%- comment -%}
  sorella-icon — inline SVG icon set (Design System §9, "sorella-icon").
  Usage: {% render 'sorella-icon', name: 'bag', size: 20, class: 'foo' %}
  Params:
    name  (string, required) — icon key
    size  (number)  — px, default 20
    class (string)  — extra classes
  Icons are decorative by default (aria-hidden). Pass label to make it labelled.
{%- endcomment -%}
{%- liquid
  assign icon_size = size | default: 20
  assign extra = class | default: ''
-%}
{%- capture svg_attrs -%}width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="sorella-icon {{ extra }}"{%- if label != blank %} role="img" aria-label="{{ label | escape }}"{%- else %} aria-hidden="true" focusable="false"{%- endif -%}{%- endcapture -%}
<svg {{ svg_attrs }}>
  {%- case name -%}
    {%- when 'search' -%}<circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>
    {%- when 'bag' -%}<path d="M6 8h12l-1 12H7L6 8z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/>
    {%- when 'user' -%}<circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
    {%- when 'menu' -%}<path d="M3 6h18M3 12h18M3 18h18"/>
    {%- when 'close' -%}<path d="M6 6l12 12M18 6L6 18"/>
    {%- when 'chevron-down' -%}<path d="M6 9l6 6 6-6"/>
    {%- when 'chevron-right' -%}<path d="M9 6l6 6-6 6"/>
    {%- when 'chevron-left' -%}<path d="M15 6l-6 6 6 6"/>
    {%- when 'arrow-right' -%}<path d="M4 12h16"/><path d="M14 6l6 6-6 6"/>
    {%- when 'minus' -%}<path d="M5 12h14"/>
    {%- when 'plus' -%}<path d="M12 5v14M5 12h14"/>
    {%- when 'check' -%}<path d="M4 12l5 5 11-11"/>
    {%- when 'star' -%}<path d="M12 3l2.7 5.5 6 .9-4.3 4.2 1 6-5.4-2.8-5.4 2.8 1-6L3.3 9.4l6-.9L12 3z" fill="currentColor" stroke="none"/>
    {%- when 'star-outline' -%}<path d="M12 3l2.7 5.5 6 .9-4.3 4.2 1 6-5.4-2.8-5.4 2.8 1-6L3.3 9.4l6-.9L12 3z"/>
    {%- when 'truck' -%}<path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/>
    {%- when 'gift' -%}<path d="M4 11h16v9H4z"/><path d="M4 11V8h16v3"/><path d="M12 8v12"/><path d="M12 8S9 3 6.5 5 12 8 12 8zM12 8s3-5 5.5-3S12 8 12 8z"/>
    {%- when 'leaf' -%}<path d="M4 20C4 10 12 4 20 4c0 10-8 16-16 16z"/><path d="M4 20c4-6 8-8 12-10"/>
    {%- when 'sparkle' -%}<path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z" fill="currentColor" stroke="none"/>
    {%- when 'heart' -%}<path d="M12 20s-7-4.5-9-9a4.5 4.5 0 0 1 9-2 4.5 4.5 0 0 1 9 2c-2 4.5-9 9-9 9z"/>
    {%- when 'shield' -%}<path d="M12 3l8 3v6c0 5-4 8-8 9-4-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>
    {%- when 'droplet' -%}<path d="M12 3s6 6 6 11a6 6 0 0 1-12 0c0-5 6-11 6-11z"/>
    {%- when 'instagram' -%}<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
    {%- when 'tiktok' -%}<path d="M14 4v9.5a3.5 3.5 0 1 1-3-3.46"/><path d="M14 4c.5 2.5 2 4 4.5 4.2"/>
    {%- when 'facebook' -%}<path d="M14 8h2V5h-2c-2 0-3 1.2-3 3v2H9v3h2v6h3v-6h2.2l.4-3H14v-1.5c0-.6.2-1 .9-1z" fill="currentColor" stroke="none"/>
    {%- when 'mail' -%}<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>
    {%- when 'phone' -%}<path d="M5 4h4l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/>
    {%- when 'filter' -%}<path d="M4 6h16M7 12h10M10 18h4"/>
    {%- else -%}<circle cx="12" cy="12" r="9"/>
  {%- endcase -%}
</svg>
