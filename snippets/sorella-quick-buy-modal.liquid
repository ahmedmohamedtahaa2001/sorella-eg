{%- comment -%}
  sorella-quick-buy-modal — per-product quick-add dialog opened from a card's
  Buy Now button ([data-open-target="quick-buy-{uid}-{product.id}"]). Uses the
  shared scrim + theme.js panel choreography (data-panel / data-close / Esc).
  Styles live in components.css (.sorella-modal__*). Monochrome: glass panel,
  white variant selection, Pure White add button.

  Params:
    product (object, required)
    uid (string, required) — section.id, to namespace the modal + input ids
    description_words (number) — truncation length for the blurb
{%- endcomment -%}
{%- liquid
  assign modal_id = 'quick-buy-' | append: uid | append: '-' | append: product.id
  assign words = description_words | default: 18
  assign inspired = product.metafields.sorella.inspired_by
-%}
<div class="sorella-modal" id="{{ modal_id }}" data-panel data-scrim="[data-shared-scrim]"
  role="dialog" aria-modal="true" aria-hidden="true" aria-label="{{ 'products.product.quick_add' | t }}: {{ product.title | escape }}">
  <div class="sorella-modal__panel glass-panel glass-panel--xl">
    <div class="sorella-modal__head">
      <span class="sorella-modal__title t-headline">{{ product.title }}</span>
      <button class="sorella-nav__icon" type="button" data-close aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'sorella-icon', name: 'close', size: 22 %}
      </button>
    </div>
    <div class="sorella-modal__body">
      <div class="sorella-modal__media media media--1x1">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 360 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="180" height="180" loading="lazy">
        {%- endif -%}
      </div>
      <div class="sorella-modal__info">
        {%- if inspired != blank -%}{% render 'sorella-inspired-by-tag', variant: 'inspired', name: inspired %}{%- endif -%}
        {% render 'sorella-price', product: product, context: 'pdp' %}
        {%- if product.description != blank -%}
          <p class="sorella-modal__desc t-body-sm">{{ product.description | strip_html | truncatewords: words }}</p>
        {%- endif -%}

        <form class="sorella-modal__form" action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" data-quick-add-form>
          {%- if product.variants.size > 1 -%}
            <fieldset class="sorella-modal__options">
              <legend class="t-caption-strong">{{ 'products.product.choose_options' | t }}</legend>
              <div class="sorella-modal__option-grid">
                {%- for variant in product.variants -%}
                  <input class="visually-hidden" type="radio" name="id" value="{{ variant.id }}"
                    id="qb-{{ uid }}-{{ variant.id }}"
                    {% if variant == product.selected_or_first_available_variant %}checked{% endif %}
                    {% unless variant.available %}disabled{% endunless %}>
                  <label class="sorella-modal__option" for="qb-{{ uid }}-{{ variant.id }}">
                    <span class="sorella-modal__option-name t-caption-strong">{{ variant.title }}</span>
                    <span class="sorella-modal__option-price t-caption">{{ variant.price | money }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endif -%}

          <div class="sorella-modal__qty-row">
            {% render 'sorella-quantity-selector', id: 'qb-qty-' | append: uid | append: '-' | append: product.id %}
            {% render 'sorella-atc-button', variant: 'solid', available: product.available %}
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
